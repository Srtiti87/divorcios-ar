---
// src/components/Footer.astro
const barrios = [
    "Agronomía", "Almagro", "Balvanera", "Barracas", "Belgrano", "Boedo", "Caballito", "Chacarita", "Coghlan", "Colegiales", 
    "Constitución", "Flores", "Floresta", "La Boca", "La Paternal", "Liniers", "Mataderos", "Monte Castro", "Monserrat", 
    "Nueva Pompeya", "Núñez", "Palermo", "Parque Avellaneda", "Parque Chacabuco", "Parque Chas", "Parque Patricios", 
    "Puerto Madero", "Recoleta", "Retiro", "Saavedra", "San Cristóbal", "San Nicolás", "San Telmo", "Vélez Sarsfield", 
    "Versalles", "Villa Crespo", "Villa del Parque", "Villa Devoto", "Villa General Mitre", "Villa Lugano", "Villa Luro", 
    "Villa Ortúzar", "Villa Pueyrredón", "Villa Real", "Villa Riachuelo", "Villa Santa Rita", "Villa Soldati", "Villa Urquiza"
];

// URL de tu ubicación en Google Maps para el enlace
const googleMapsUrl = "https://www.google.com/maps/search/Abogados+AG+Capital+Federal";
---

<section class="bg-indigo-950 px-6 pb-12">
    <div class="max-w-7xl mx-auto rounded-[2.5rem] overflow-hidden border border-white/10 shadow-2xl h-[350px] relative group">
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="block w-full h-full relative">
            <img 
                src="/img/mapa-estatico-caba.webp" 
                alt="Mapa de cobertura en CABA"
                class="absolute inset-0 w-full h-full object-cover grayscale-[0.5] contrast-[1.1] brightness-[0.8] transition-all duration-700 group-hover:grayscale-0 group-hover:brightness-100"
                loading="lazy"
                width="1280"
                height="350"
            />
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <span class="bg-indigo-600 text-white px-6 py-3 rounded-full font-black uppercase text-[10px] tracking-widest shadow-2xl">
                    Ver ubicación en Google Maps
                </span>
            </div>
        </a>
        
        <div class="absolute inset-0 pointer-events-none border-[12px] border-indigo-950/20 rounded-[2.5rem]"></div>
        <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-indigo-950 via-transparent to-indigo-950/20"></div>
    </div>
</section>

<footer class="bg-indigo-950 pt-12 pb-8 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12">
            <div>
                <a href="/" class="flex items-center gap-2 mb-4">
                    <span class="text-xl font-black text-white tracking-tighter">
                        divorcios<span class="text-indigo-400">.ar</span>
                    </span>
                </a>
                <div class="flex flex-col sm:flex-row gap-4 sm:gap-8">
                    <a href="mailto:contacto@divorcios.ar" class="text-indigo-300 hover:text-white transition-colors font-bold text-xs uppercase tracking-widest flex items-center gap-2">
                        contacto@divorcios.ar
                    </a>
                    <span class="text-indigo-100/30 text-xs font-bold uppercase tracking-widest">
                        Ciudad de Buenos Aires, CABA
                    </span>
                </div>
            </div>

            <nav class="flex gap-6 text-[10px] font-black uppercase tracking-[0.2em]">
                <a href="/#servicios" class="text-indigo-100/30 hover:text-white transition-colors">Servicios</a>
                <a href="https://wa.me/5491141689773" class="text-indigo-100/30 hover:text-white transition-colors">WhatsApp</a>
            </nav>
        </div>

        <div class="text-[9px] text-indigo-100/5 leading-relaxed text-center md:text-left mb-8">
            {barrios.map((barrio, index) => (
                <span key={barrio}>
                    Abogado de familia en {barrio}, CABA{index < barrios.length - 1 ? " • " : ""}
                </span>
            ))}
        </div>

        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-indigo-100/10 text-[9px] font-black uppercase tracking-[0.4em]">
                © 2026 divorcios.ar
            </p>
            <nav class="flex gap-6">
                <a href="/privacidad" class="text-indigo-100/20 hover:text-indigo-400 text-[9px] font-black uppercase tracking-[0.3em] transition-colors">Privacidad</a>
                <a href="/terminos" class="text-indigo-100/20 hover:text-indigo-400 text-[9px] font-black uppercase tracking-[0.3em] transition-colors">Términos</a>
            </nav>
            <p class="text-indigo-100/10 text-[9px] font-black uppercase tracking-[0.4em]">
                Atención en toda Capital Federal
            </p>
        </div>
    </div>
</footer>