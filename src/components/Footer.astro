---
// src/components/Footer.astro
const barrios = [
    "Agronomía", "Almagro", "Balvanera", "Barracas", "Belgrano", "Boedo", "Caballito", "Chacarita", "Coghlan", "Colegiales", 
    "Constitución", "Flores", "Floresta", "La Boca", "La Paternal", "Liniers", "Mataderos", "Monte Castro", "Monserrat", 
    "Nueva Pompeya", "Núñez", "Palermo", "Parque Avellaneda", "Parque Chacabuco", "Parque Chas", "Parque Patricios", 
    "Puerto Madero", "Recoleta", "Retiro", "Saavedra", "San Cristóbal", "San Nicolás", "San Telmo", "Vélez Sarsfield", 
    "Versalles", "Villa Crespo", "Villa del Parque", "Villa Devoto", "Villa General Mitre", "Villa Lugano", "Villa Luro", 
    "Villa Ortúzar", "Villa Pueyrredón", "Villa Real", "Villa Riachuelo", "Villa Santa Rita", "Villa Soldati", "Villa Urquiza"
];

// REEMPLAZA ESTA URL por el link de tu oficina en Google Maps
const googleMapsUrl = "https://goo.gl/maps/TuLinkAqui"; 
---

<section class="bg-indigo-950 px-6 pb-12">
    <div class="max-w-7xl mx-auto rounded-[2.5rem] overflow-hidden border border-white/10 shadow-2xl h-[351px] relative group bg-indigo-900/50">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent opacity-50"></div>
        
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="block w-full h-full relative" aria-label="Ver nuestra ubicación en Google Maps">
            <img 
                src="/img/mapa-estatico-caba.webp" 
                alt="Mapa de cobertura legal en Ciudad de Buenos Aires"
                class="absolute inset-0 w-full h-full object-cover grayscale-[0.3] contrast-[1.1] brightness-[0.7] transition-all duration-700 group-hover:grayscale-0 group-hover:brightness-100"
                onerror="this.style.opacity='0'" 
                loading="lazy"
                decoding="async"
                width="812" 
                height="351"
            />
            
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-indigo-950/40 group-hover:bg-indigo-950/20 transition-all duration-500">
                <p class="text-white/60 text-[10px] font-black uppercase tracking-[0.5em] mb-4">Jurisdicción CABA</p>
                <span class="bg-white text-indigo-950 px-8 py-4 rounded-2xl font-black uppercase text-xs tracking-widest shadow-2xl transform scale-100 group-hover:scale-110 transition-all duration-500 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    Ver en Google Maps
                </span>
            </div>
        </a>
        
        <div class="absolute inset-0 pointer-events-none border-[1px] border-white/10 rounded-[2.5rem]"></div>
    </div>
</section>

<footer class="bg-indigo-950 pt-12 pb-8 border-t border-white/5">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12">
            <div>
                <a href="/" class="flex items-center gap-2 mb-4">
                    <span class="text-2xl font-black text-white tracking-tighter">
                        divorcios<span class="text-indigo-400">.ar</span>
                    </span>
                </a>
                <address class="not-italic flex flex-col sm:flex-row gap-4 sm:gap-8">
                    <a href="mailto:contacto@divorcios.ar" class="text-indigo-300 hover:text-white transition-colors font-bold text-xs uppercase tracking-widest flex items-center gap-2">
                        contacto@divorcios.ar
                    </a>
                    <span class="text-indigo-100/40 text-xs font-bold uppercase tracking-widest">
                        CABA, Argentina
                    </span>
                </address>
            </div>

            <nav class="flex gap-6 text-[10px] font-black uppercase tracking-[0.2em]">
                <a href="/#servicios" class="text-indigo-100/30 hover:text-white transition-colors">Servicios</a>
                <a href="/blog" class="text-indigo-100/30 hover:text-white transition-colors">Blog</a>
                <a href="https://wa.me/5491141689773" class="text-indigo-400 hover:text-white transition-colors font-bold">WhatsApp</a>
            </nav>
        </div>

        <div class="mb-12 border-y border-white/5 py-8">
            <p class="mb-6 font-black uppercase tracking-[0.3em] text-indigo-500/50 text-[9px] text-center md:text-left">Jurisdicción y Cobertura CABA:</p>
            <div class="flex flex-wrap justify-center md:justify-start gap-x-4 gap-y-2 opacity-20 hover:opacity-100 transition-opacity duration-700">
                {barrios.map((barrio) => (
                    <span key={barrio} class="text-[9px] font-medium text-indigo-200 uppercase tracking-tighter whitespace-nowrap">
                        Abogado {barrio}
                    </span>
                ))}
            </div>
        </div>

        <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="text-indigo-100/10 text-[9px] font-black uppercase tracking-[0.4em]">
                © {new Date().getFullYear()} divorcios.ar
            </p>
            <nav class="flex gap-6">
                <a href="/privacidad" class="text-indigo-100/20 hover:text-indigo-400 text-[9px] font-black uppercase tracking-[0.3em] transition-colors">Privacidad</a>
                <a href="/terminos" class="text-indigo-100/20 hover:text-indigo-400 text-[9px] font-black uppercase tracking-[0.3em] transition-colors">Términos</a>
            </nav>
            <p class="text-indigo-100/10 text-[9px] font-black uppercase tracking-[0.4em]">
                Derecho de Familia y Sucesiones
            </p>
        </div>
    </div>
</footer>