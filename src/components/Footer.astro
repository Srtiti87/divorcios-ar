---
// src/components/Footer.astro
const barrios = [
    "Agronomía", "Almagro", "Balvanera", "Barracas", "Belgrano", "Boedo", "Caballito", "Chacarita", "Coghlan", "Colegiales",
    "Constitución", "Flores", "Floresta", "La Boca", "La Paternal", "Liniers", "Mataderos", "Monte Castro", "Monserrat",
    "Nueva Pompeya", "Núñez", "Palermo", "Parque Avellaneda", "Parque Chacabuco", "Parque Chas", "Parque Patricios",
    "Puerto Madero", "Recoleta", "Retiro", "Saavedra", "San Cristóbal", "San Nicolás", "San Telmo", "Vélez Sarsfield",
    "Versalles", "Villa Crespo", "Villa del Parque", "Villa Devoto", "Villa General Mitre", "Villa Lugano", "Villa Luro",
    "Villa Ortúzar", "Villa Pueyrredón", "Villa Real", "Villa Riachuelo", "Villa Santa Rita", "Villa Soldati", "Villa Urquiza"
];

const googleMapsUrl = "https://maps.app.goo.gl/TuLinkReal";
---

<section class="bg-ink px-6 pb-12">
    <div class="max-w-7xl mx-auto rounded-sm overflow-hidden border border-white/10 shadow-2xl h-[280px] relative group bg-ink-2">
        <a href={googleMapsUrl} target="_blank" rel="noopener noreferrer" class="block w-full h-full relative" aria-label="Ver nuestra ubicación en Google Maps">
            <img
                src="/img/mapa-estatico-caba.webp"
                alt="Mapa de cobertura legal en Ciudad de Buenos Aires"
                class="absolute inset-0 w-full h-full object-cover grayscale opacity-35 transition-all duration-700 group-hover:grayscale-0 group-hover:opacity-90"
                loading="lazy"
                width="812"
                height="351"
            />

            <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/40 group-hover:bg-black/10 transition-all duration-500">
                <p class="text-gold text-[10px] font-bold uppercase tracking-[0.4em] mb-4 drop-shadow-lg text-center">Jurisdicción CABA</p>
                <span class="bg-gold text-ink px-7 py-3.5 rounded-sm font-bold uppercase text-xs tracking-widest shadow-2xl transform group-hover:scale-105 transition-all duration-500 flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                    Ver Oficina Virtual
                </span>
            </div>
        </a>
    </div>
</section>

<footer class="bg-ink pt-16 pb-8 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6">

        <div class="flex flex-col lg:flex-row justify-between items-start gap-12 mb-16">
            <div class="max-w-md">
                <a href="/" class="flex items-baseline gap-1 mb-6">
                    <span class="font-serif text-2xl font-light text-cream tracking-tight">divorcios<span class="font-semibold text-gold">.ar</span></span>
                </a>
                <div class="space-y-4">
                    <p class="text-cream/60 text-[10px] font-medium uppercase tracking-[0.15em] leading-relaxed">
                        DR. HECTOR DAVID SANTIBAÑEZ <br/>
                        <span class="text-gold/70">T°124 F°535 C.P.A.C.F</span>
                    </p>
                    <address class="not-italic space-y-2">
                        <div class="flex flex-col gap-1">
                             <a href="tel:1159360995" class="text-cream/70 hover:text-cream transition-colors text-sm font-medium tracking-tight">11-5936-0995</a>
                             <a href="tel:1141689773" class="text-cream/70 hover:text-cream transition-colors text-sm font-medium tracking-tight">11-4168-9773</a>
                        </div>
                        <a href="mailto:contacto@divorcios.ar" class="block text-gold/90 hover:text-gold transition-colors text-[10px] font-bold uppercase tracking-widest mt-4">
                            contacto@divorcios.ar
                        </a>
                    </address>
                </div>
            </div>

            <nav class="grid grid-cols-2 gap-x-12 gap-y-4">
                <div class="flex flex-col gap-3">
                    <span class="text-gold text-[10px] font-bold uppercase tracking-[0.25em] mb-2">Estudio</span>
                    <a href="/#servicios" class="text-cream/60 hover:text-cream text-[11px] font-medium uppercase tracking-widest transition-colors">Servicios</a>
                    <a href="/costo-divorcio-buenos-aires" class="text-cream/60 hover:text-cream text-[11px] font-medium uppercase tracking-widest transition-colors">Honorarios</a>
                </div>
                <div class="flex flex-col gap-3">
                    <span class="text-gold text-[10px] font-bold uppercase tracking-[0.25em] mb-2">Recursos</span>
                    <a href="/blog" class="text-cream/60 hover:text-cream text-[11px] font-medium uppercase tracking-widest transition-colors">Blog Jurídico</a>
                    <a href="/cuanto-tarda-un-divorcio-en-argentina" class="text-cream/60 hover:text-cream text-[11px] font-medium uppercase tracking-widest transition-colors">¿Cuánto tarda?</a>
                    <a href="/requisitos-divorcio-caba" class="text-cream/60 hover:text-cream text-[11px] font-medium uppercase tracking-widest transition-colors">Requisitos</a>
                    <a href="https://wa.me/5491159360995" class="text-[#25D366] hover:text-[#20ba5a] text-[11px] font-medium uppercase tracking-widest transition-colors">WhatsApp</a>
                </div>
            </nav>
        </div>

        <div class="mb-12 border-t border-white/10 pt-8">
            <div class="flex items-center justify-between mb-4">
                <h5 class="font-bold uppercase tracking-[0.25em] text-cream/60 text-[10px]">Cobertura Legal en CABA:</h5>
                <span class="text-cream/55 text-[9px] uppercase tracking-widest">Deslizar →</span>
            </div>

            <div class="flex overflow-x-auto gap-3 pb-4 no-scrollbar select-none">
                {barrios.map((barrio) => (
    <span class="text-[9px] font-medium text-cream/50 uppercase tracking-tight border border-white/10 px-3 py-1.5 rounded-sm whitespace-nowrap hover:text-gold hover:border-gold/30 transition-all">
        Abogado {barrio}
    </span>
))}
            </div>
        </div>

        <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-6 border-t border-white/10">
            <p class="text-cream/55 text-[10px] font-bold uppercase tracking-[0.3em]">
                © {new Date().getFullYear()} divorcios.ar
            </p>
            <div class="flex gap-6">
                <a href="/privacidad" class="text-cream/55 hover:text-cream text-[10px] font-bold uppercase tracking-[0.2em] transition-colors">Privacidad</a>
                <a href="/terminos" class="text-cream/55 hover:text-cream text-[10px] font-bold uppercase tracking-[0.2em] transition-colors">Términos</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
