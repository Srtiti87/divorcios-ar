---
// src/components/Header.astro
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent bg-transparent">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        
        <div class="flex items-center">
            <a href="/" class="group flex items-center gap-2" aria-label="Inicio divorcios.ar">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center group-hover:bg-amber-400 transition-all duration-300 shadow-lg shadow-indigo-500/20 group-hover:shadow-amber-400/20">
                    <span class="text-white group-hover:text-indigo-950 font-black text-xs">D.AR</span>
                </div>
                <span class="text-xl font-black text-white tracking-tighter transition-colors">
                    divorcios<span class="text-amber-400 group-hover:text-white transition-colors">.ar</span>
                </span>
            </a>
        </div>

        <nav class="hidden md:flex items-center gap-8">
            <a href="/#servicios" class="text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-amber-400 transition-colors">Servicios</a>
            <a href="/honorarios" class="text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-amber-400 transition-colors">Honorarios</a>
            <a href="/costo-de-un-divorcio" class="text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-amber-400 transition-colors">Costo Divorcio</a>
            <a href="/blog" class="text-[10px] font-black uppercase tracking-widest text-white/70 hover:text-amber-400 transition-colors">Blog</a>
            
            <a href="https://wa.me/5491159360995" class="bg-[#25D366] text-white px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-[#128C7E] transition-all shadow-lg hover:shadow-[#25D366]/20 hover:scale-105 active:scale-95">
                Consultar ahora
            </a>
        </nav>

        <button id="menu-button" class="md:hidden text-white focus:outline-none p-2" aria-label="Abrir menú" aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full border-b border-white/10 backdrop-blur-2xl md:hidden bg-[#05051a]/95">
        <nav class="flex flex-col p-6 gap-6">
            <a href="/#servicios" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-white/70 hover:text-amber-400">Servicios</a>
            <a href="/honorarios" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-white/70 hover:text-amber-400">Honorarios</a>
            <a href="/costo-de-un-divorcio" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-white/70 hover:text-amber-400">Costo Divorcio</a>
            <a href="/blog" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-white/70 hover:text-amber-400">Blog</a>
            <a href="https://wa.me/5491159360995" class="bg-[#25D366] text-white text-center py-4 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] shadow-xl">
                Consultar ahora
            </a>
        </nav>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    function updateHeader() {
        if (window.scrollY > 50) {
            header?.classList.add('bg-[#05051a]/90', 'backdrop-blur-md', 'shadow-2xl', 'border-white/5');
            header?.classList.remove('bg-transparent', 'border-transparent');
        } else {
            if (mobileMenu?.classList.contains('hidden')) {
                header?.classList.add('bg-transparent', 'border-transparent');
                header?.classList.remove('bg-[#05051a]/90', 'backdrop-blur-md', 'shadow-2xl', 'border-white/5');
            }
        }
    }

    window.addEventListener('scroll', () => {
        window.requestAnimationFrame(updateHeader);
    }, { passive: true });

    menuBtn?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!isHidden));
        
        if (!isHidden) {
            header?.classList.add('bg-[#05051a]');
        } else if (window.scrollY <= 50) {
            header?.classList.remove('bg-[#05051a]');
        }
    });

    // Cerrar menú al hacer click en un link (útil para anclas)
    document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
            mobileMenu?.classList.add('hidden');
            menuBtn?.setAttribute('aria-expanded', 'false');
        });
    });
</script>

<style>
    #main-header {
        will-change: background-color, border-color;
    }
</style>