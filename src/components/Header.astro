---
// src/components/Header.astro
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 border-b border-transparent">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        
        <div class="flex items-center">
            <a href="/" class="group flex items-center gap-2">
                <div class="w-8 h-8 bg-indigo-500 rounded-lg flex items-center justify-center group-hover:bg-white transition-all duration-300">
                    <span class="text-white group-hover:text-indigo-950 font-black text-xs">D.AR</span>
                </div>
                <span class="text-xl font-black text-white tracking-tighter transition-colors group-hover:text-indigo-400">
                    divorcios<span class="text-indigo-400 group-hover:text-white">.ar</span>
                </span>
            </a>
        </div>

        <nav class="hidden md:flex items-center gap-8">
            <a href="/#servicios" class="text-[10px] font-black uppercase tracking-widest text-indigo-100/70 hover:text-white transition-colors">Servicios</a>
            <a href="/honorarios" class="text-[10px] font-black uppercase tracking-widest text-indigo-100/70 hover:text-white transition-colors">Honorarios</a>
            <a href="/costo-de-un-divorcio" class="text-[10px] font-black uppercase tracking-widest text-indigo-100/70 hover:text-white transition-colors">Costo Divorcio</a>
            <a href="/blog" class="text-[10px] font-black uppercase tracking-widest text-indigo-100/70 hover:text-white transition-colors">Blog</a>
            
            <a href="https://wa.me/5491141689773" class="bg-indigo-600 text-white px-6 py-3 rounded-xl text-[10px] font-black uppercase tracking-[0.2em] hover:bg-white hover:text-indigo-950 transition-all shadow-lg hover:scale-105">
                Consultar ahora
            </a>
        </nav>

        <button id="menu-button" class="md:hidden text-white/80 focus:outline-none" aria-label="Abrir menú">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full border-b border-white/10 backdrop-blur-xl md:hidden">
        <nav class="flex flex-col p-6 gap-6">
            <a href="/#servicios" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-indigo-100/70">Servicios</a>
            <a href="/honorarios" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-indigo-100/70">Honorarios</a>
            <a href="/costo-de-un-divorcio" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-indigo-100/70">Costo Divorcio</a>
            <a href="/blog" class="mobile-link text-[10px] font-black uppercase tracking-[0.2em] text-indigo-100/70">Blog</a>
            
            <a href="https://wa.me/5491141689773" class="bg-indigo-600 text-white text-center py-4 rounded-xl text-[10px] font-black uppercase tracking-[0.2em]">
                Consultar ahora
            </a>
        </nav>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    // Lógica del Scroll
    window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
            header?.classList.add('bg-indigo-950', 'shadow-2xl', 'border-white/10');
            header?.classList.remove('bg-transparent', 'border-transparent');
        } else {
            // Solo removemos el fondo si el menú móvil está cerrado
            if (mobileMenu?.classList.contains('hidden')) {
                header?.classList.add('bg-transparent', 'border-transparent');
                header?.classList.remove('bg-indigo-950', 'shadow-2xl', 'border-white/10');
            }
        }
    });

    // Lógica del Menú Móvil
    menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        
        // Si el menú se abre, forzamos fondo sólido para que los links se vean siempre claros
        if (!mobileMenu?.classList.contains('hidden')) {
            header?.classList.add('bg-indigo-950');
            header?.classList.remove('bg-transparent');
        } else if (window.scrollY <= 50) {
            header?.classList.add('bg-transparent');
            header?.classList.remove('bg-indigo-950');
        }
    });

    // Cerrar menú al clickear un enlace
    mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
            mobileMenu?.classList.add('hidden');
            if (window.scrollY <= 50) {
                header?.classList.add('bg-transparent');
                header?.classList.remove('bg-indigo-950');
            }
        });
    });
</script>

<style>
    #main-header {
        will-change: background-color, border-color;
    }
    
    #mobile-menu {
        /* Color sólido de respaldo por si el blur no carga */
        background-color: rgba(30, 27, 75, 0.98);
        backdrop-filter: blur(15px);
    }

    /* Aseguramos que los links móviles no hereden colores extraños */
    .mobile-link {
        color: rgba(224, 231, 255, 0.7); /* text-indigo-100/70 */
    }
</style>
