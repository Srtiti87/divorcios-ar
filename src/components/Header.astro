---
// src/components/Header.astro
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent bg-transparent">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">

        <a href="/" class="group flex items-baseline gap-1" aria-label="Inicio divorcios.ar">
            <span class="font-serif text-2xl font-light text-cream tracking-tight transition-colors">divorcios</span><span class="font-serif text-2xl font-semibold text-gold tracking-tight transition-colors">.ar</span>
        </a>

        <nav class="hidden md:flex items-center gap-8">
            <a href="/#servicios" class="text-[11px] font-medium uppercase tracking-[0.15em] text-cream/70 hover:text-gold transition-colors">Servicios</a>
            <a href="/costo-divorcio-buenos-aires" class="text-[11px] font-medium uppercase tracking-[0.15em] text-cream/70 hover:text-gold transition-colors">Honorarios</a>
            <a href="/blog" class="text-[11px] font-medium uppercase tracking-[0.15em] text-cream/70 hover:text-gold transition-colors">Blog</a>

            <a href="https://wa.me/5491159360995" class="bg-gold text-ink px-5 py-2.5 rounded-sm text-[11px] font-bold uppercase tracking-[0.1em] hover:bg-gold-light transition-all shadow-lg shadow-gold/10 hover:-translate-y-px">
                Consultar ahora
            </a>
        </nav>

        <button id="menu-button" class="md:hidden text-cream focus:outline-none p-2 border border-white/15 rounded-sm" aria-label="Abrir menú" aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full border-b border-white/10 backdrop-blur-2xl md:hidden bg-[#14151f]/97 max-h-[calc(100vh-5rem)] overflow-y-auto">
        <nav class="flex flex-col p-6 gap-1">
            <a href="/#servicios" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Servicios</a>
            <a href="/costo-divorcio-buenos-aires" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">¿Cuánto cuesta un divorcio?</a>
            <a href="/cuanto-cuesta-divorcio-sin-bienes" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Costo sin bienes</a>
            <a href="/cuanto-tarda-un-divorcio-en-argentina" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">¿Cuánto tarda?</a>
            <a href="/divorcio-express-caba" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">¿Qué es el divorcio express?</a>
            <a href="/puedo-divorciarme-sin-que-firme-mi-pareja" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Divorcio sin firma de mi pareja</a>
            <a href="/requisitos-divorcio-caba" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Requisitos en CABA</a>
            <a href="/divorcio-con-hijos-ciudad-buenos-aires" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Divorcio con hijos</a>
            <a href="/blog" class="mobile-link py-3 border-b border-white/5 text-[12px] font-medium uppercase tracking-[0.12em] text-cream/70 hover:text-gold font-serif text-base">Blog Jurídico</a>
            <a href="https://wa.me/5491159360995" class="mt-4 bg-gold text-ink text-center py-3.5 rounded-sm text-[11px] font-bold uppercase tracking-[0.15em] shadow-xl">
                Consultar ahora
            </a>
        </nav>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    function updateHeader() {
        if (window.scrollY > 50) {
            header?.classList.add('bg-[#14151f]/94', 'backdrop-blur-md', 'shadow-2xl', 'border-white/10');
            header?.classList.remove('bg-transparent', 'border-transparent');
        } else {
            if (mobileMenu?.classList.contains('hidden')) {
                header?.classList.add('bg-transparent', 'border-transparent');
                header?.classList.remove('bg-[#14151f]/94', 'backdrop-blur-md', 'shadow-2xl', 'border-white/10');
            }
        }
    }

    window.addEventListener('scroll', () => {
        window.requestAnimationFrame(updateHeader);
    }, { passive: true });

    menuBtn?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!isHidden));

        if (!isHidden) {
            header?.classList.add('bg-[#14151f]');
        } else if (window.scrollY <= 50) {
            header?.classList.remove('bg-[#14151f]');
        }
    });

    // Cerrar menú al hacer click en un link (útil para anclas)
    document.querySelectorAll('.mobile-link').forEach(link => {
        link.addEventListener('click', () => {
            mobileMenu?.classList.add('hidden');
            menuBtn?.setAttribute('aria-expanded', 'false');
        });
    });
</script>

<style>
    #main-header {
        will-change: background-color, border-color;
    }
</style>
