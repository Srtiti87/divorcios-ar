---
// src/components/Hero.astro
---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-indigo-950 text-white">
    <canvas id="canvas-particles" class="absolute inset-0 z-0 opacity-60"></canvas>
    
    <div class="absolute inset-0 z-10 bg-gradient-to-b from-indigo-950/20 via-indigo-950/80 to-indigo-950"></div>

    <div class="relative z-20 max-w-6xl mx-auto text-center px-6 w-full">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-8 backdrop-blur-sm animate-fade-in">
            <span class="text-[10px] font-black uppercase tracking-[0.4em] text-indigo-300">Derecho de Familia • CABA</span>
        </div>

        <h1 class="text-5xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-[0.85] mb-12">
            ABOGADOS <br class="md:block" />
            <div class="relative h-[1.2em] md:h-[1em] mt-2 flex justify-center items-center">
                <span class="word-fade animate-fade-1 text-amber-400 drop-shadow-[0_0_15px_rgba(251,191,36,0.4)]">Divorcio Express</span>
                <span class="word-fade animate-fade-2 text-amber-400 drop-shadow-[0_0_15px_rgba(251,191,36,0.4)]">Cuidado Personal</span>
                <span class="word-fade animate-fade-3 text-amber-400 drop-shadow-[0_0_15px_rgba(251,191,36,0.4)]">División de Bienes</span>
                <span class="word-fade animate-fade-4 text-amber-400 drop-shadow-[0_0_15px_rgba(251,191,36,0.4)]">Compensación Económica</span>
            </div>
        </h1>

        <p class="text-base md:text-xl text-indigo-100/70 mb-12 max-w-2xl mx-auto leading-relaxed font-medium">
            Atención jurídica estratégica y reserva absoluta en procesos de alta complejidad. <span class="text-white font-bold">Tu voz cuenta.</span>
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="https://wa.me/5491141689773" class="w-full sm:w-auto px-10 py-5 bg-white text-indigo-950 rounded-2xl font-black uppercase tracking-widest text-xs hover:bg-indigo-400 hover:text-white transition-all shadow-2xl flex items-center justify-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 1 1-7.6-11.7 8.38 8.38 0 0 1 3.8.9L21 3z"></path></svg>
                Consulta Privada
            </a>
        </div>
    </div>
</section>

<script>
    const canvas = document.getElementById('canvas-particles') as HTMLCanvasElement;
    const ctx = canvas?.getContext('2d');
    let particles = [];

    function resize() {
        if (!canvas) return;
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }

    class Particle {
        x: number; y: number; vx: number; vy: number;
        constructor() {
            this.x = Math.random() * (canvas?.width || 0);
            this.y = Math.random() * (canvas?.height || 0);
            this.vx = (Math.random() - 0.5) * 0.7;
            this.vy = (Math.random() - 0.5) * 0.7;
        }
        update() {
            this.x += this.vx;
            this.y += this.vy;
            if (this.x < 0 || this.x > (canvas?.width || 0)) this.vx *= -1;
            if (this.y < 0 || this.y > (canvas?.height || 0)) this.vy *= -1;
        }
    }

    function init() {
        if (!canvas || !ctx) return;
        resize();
        particles = Array.from({ length: 110 }, () => new Particle());
        loop();
    }

    function loop() {
        if (!ctx || !canvas) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        ctx.strokeStyle = 'rgba(165, 180, 252, 0.6)'; 
        ctx.lineWidth = 1.2;

        particles.forEach((p, i) => {
            p.update();
            
            ctx.fillStyle = 'rgba(199, 210, 254, 0.8)';
            ctx.beginPath();
            ctx.arc(p.x, p.y, 2, 0, Math.PI * 2);
            ctx.fill();

            for (let j = i + 1; j < particles.length; j++) {
                const p2 = particles[j];
                const dist = Math.hypot(p.x - p2.x, p.y - p2.y);
                if (dist < 190) {
                    ctx.globalAlpha = 1 - (dist / 190); 
                    ctx.beginPath();
                    ctx.moveTo(p.x, p.y);
                    ctx.lineTo(p2.x, p2.y);
                    ctx.stroke();
                    ctx.globalAlpha = 1;
                }
            }
        });
        requestAnimationFrame(loop);
    }

    window.addEventListener('resize', resize);
    init();
</script>

<style>
    .word-fade {
        position: absolute;
        opacity: 0;
        width: 100%;
        display: block;
        transform: translateY(15px);
        filter: blur(4px);
        will-change: transform, opacity, filter;
    }

    @keyframes wordAnimation {
        0% { opacity: 0; transform: translateY(15px); filter: blur(4px); }
        5% { opacity: 1; transform: translateY(0); filter: blur(0); }
        20% { opacity: 1; transform: translateY(0); filter: blur(0); }
        25% { opacity: 0; transform: translateY(-15px); filter: blur(4px); }
        100% { opacity: 0; }
    }

    .animate-fade-1 { animation: wordAnimation 8s infinite 0s; }
    .animate-fade-2 { animation: wordAnimation 8s infinite 2s; }
    .animate-fade-3 { animation: wordAnimation 8s infinite 4s; }
    .animate-fade-4 { animation: wordAnimation 8s infinite 6s; }

    .animate-fade-in {
        animation: fadeIn 1.5s ease-out forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>