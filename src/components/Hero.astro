---
// src/components/Hero.astro
---
<section class="relative min-h-[100vh] flex items-center justify-center overflow-hidden bg-indigo-950 text-white w-full">
    <div class="absolute inset-0 z-0 bg-indigo-950"></div>
    <div class="absolute inset-0 z-10 aura-glow opacity-40"></div>

    <div class="relative z-30 max-w-6xl mx-auto text-center px-4 w-full flex flex-col items-center">
        <h1 class="text-5xl md:text-8xl lg:text-9xl font-black tracking-tighter leading-[0.9] mb-12">
            <span class="block">ABOGADOS</span>
            <div class="relative h-[60px] md:h-[120px] mt-2 flex justify-center items-center overflow-hidden">
                <span class="word-fade animate-fade-1 text-amber-400">Divorcio Express</span>
                <span class="word-fade animate-fade-2 text-amber-400">Cuidado Personal</span>
                <span class="word-fade animate-fade-3 text-amber-400">División de Bienes</span>
                <span class="word-fade animate-fade-4 text-amber-400 text-fluid-long">Compensación Económica</span>
            </div>
        </h1>
        <a href="https://wa.me/5491141689773" class="px-10 py-5 bg-white text-indigo-950 rounded-2xl font-black uppercase tracking-widest text-xs">
            Consulta Privada
        </a>
    </div>
</section>

<style>
    /* Usamos transformaciones 3D para que el navegador no recalcule el diseño */
    .aura-glow {
        background: radial-gradient(circle, #4338ca 0%, transparent 70%);
        filter: blur(40px);
        animation: auraMove 10s infinite alternate;
        will-change: transform;
    }
    @keyframes auraMove { 
        from { transform: translate3d(-1%, -1%, 0); } 
        to { transform: translate3d(1%, 1%, 0); } 
    }
    .word-fade {
        position: absolute; opacity: 0; width: 100%;
        transform: translate3d(0, 10px, 0);
        will-change: transform, opacity;
    }
    .text-fluid-long { font-size: clamp(1.4rem, 6.5vw, 1em); }
    @keyframes wordAnimation {
        0%, 100% { opacity: 0; transform: translate3d(0, 10px, 0); }
        10%, 25% { opacity: 1; transform: translate3d(0, 0, 0); }
        35% { opacity: 0; transform: translate3d(0, -10px, 0); }
    }
    .animate-fade-1 { animation: wordAnimation 8s infinite 0s; }
    .animate-fade-2 { animation: wordAnimation 8s infinite 2s; }
    .animate-fade-3 { animation: wordAnimation 8s infinite 4s; }
    .animate-fade-4 { animation: wordAnimation 8s infinite 6s; }
</style>