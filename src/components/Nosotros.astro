---
const fortalezas = [
  "Abogados matriculados en CPACF (CABA).",
  "Especialistas en Derecho de Familia y Sucesiones.",
  "Confidencialidad y reserva absoluta en cada caso.",
  "Atención directa y personalizada sin intermediarios."
];
---

<section id="nosotros" class="py-24 bg-[#05051a] text-white border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      
      <div class="flex flex-col items-center lg:items-start text-center lg:text-left space-y-8">
        <div class="inline-block px-4 py-1.5 text-[10px] md:text-xs font-bold tracking-widest text-amber-400 uppercase bg-amber-400/10 border border-amber-400/20 rounded-full">
          Respaldo Jurídico de Excelencia
        </div>
        
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter leading-none text-white">
          ABOGADOS <br />
          <span class="text-amber-400 italic">A&G</span>
        </h2>

        <p class="text-lg md:text-xl text-indigo-100/70 leading-relaxed font-light max-w-lg">
          En el estudio del <strong> Dr. Santibáñez </strong>, entendemos que un divorcio es más que un trámite; es el inicio de una nueva etapa. Somos profesionales egresados de la <strong>Universidad de Buenos Aires (UBA)</strong>, comprometidos con la ética y la celeridad procesal.
        </p>

        <ul class="space-y-4 self-start lg:self-auto text-left">
          {fortalezas.map(item => (
            <li class="flex items-start gap-3 group">
              <svg class="w-6 h-6 text-amber-400 mt-1 shrink-0 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="font-bold text-indigo-50/90">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
        <div class="group p-8 bg-white/[0.03] rounded-[2.5rem] border border-white/10 flex flex-col items-center text-center transition-all hover:bg-white/[0.05] hover:border-amber-400/30 duration-300">
          <span class="text-5xl font-black text-amber-400 mb-2 group-hover:scale-110 transition-transform tracking-tighter">+15</span>
          <span class="text-[10px] font-black uppercase tracking-widest text-indigo-300/60 leading-tight">Años de Trayectoria <br/> Profesional</span>
        </div>
        
        <div class="group p-8 bg-indigo-600 rounded-[2.5rem] text-white flex flex-col items-center text-center shadow-xl shadow-indigo-500/20 transition-all hover:bg-indigo-500 hover:scale-105 duration-300">
          <span class="text-5xl font-black mb-2 group-hover:scale-110 transition-transform tracking-tighter">UBA</span>
          <span class="text-[10px] font-black uppercase tracking-widest text-indigo-100 leading-tight">Egresados de la <br/> Facultad de Derecho</span>
        </div>

        <div class="group p-8 bg-white/[0.03] rounded-[2.5rem] border border-white/10 flex flex-col items-center text-center transition-all hover:border-amber-400/30 duration-300">
          <div class="flex gap-1 mb-3">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-amber-500 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
            ))}
          </div>
          <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white">Reserva y Confianza</span>
          <p class="text-[9px] uppercase font-bold text-indigo-300/40 tracking-wider mt-1">Compromiso ético profesional</p>
        </div>

        <div class="group p-2 bg-white rounded-[2.5rem] flex items-center justify-center transition-all hover:scale-105 shadow-2xl active:scale-95 overflow-hidden">
          <a 
            href="https://wa.me/5491159360995" 
            target="_blank" 
            rel="noopener noreferrer"
            class="w-full h-full rounded-[2.2rem] border-2 border-dashed border-indigo-600/20 flex flex-col items-center justify-center py-6 px-4 group-hover:border-indigo-600/40 transition-colors"
          >
            <span class="text-indigo-600 font-black uppercase tracking-[0.1em] text-xs text-center leading-tight">
              Consulte por su caso <br/> <span class="text-lg">ahora</span>
            </span>
            <div class="mt-3 flex items-center gap-2">
              <div class="w-8 h-8 bg-[#25D366] rounded-full flex items-center justify-center text-white shadow-lg group-hover:bg-[#128C7E] transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 0 5.414 0 12.05c0 2.123.553 4.197 1.603 6.034L0 24l6.135-1.61a11.81 11.81 0 005.911 1.569h.005c6.636 0 12.05-5.414 12.05-12.051a11.817 11.817 0 00-3.488-8.522z"/>
                </svg>
              </div>
              <span class="text-[9px] font-black text-indigo-300 uppercase tracking-widest">Respuesta inmediata</span>
            </div>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>