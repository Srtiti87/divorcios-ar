---
const items = [
  {
    title: "100% Digital",
    desc: "Tramitación online sin necesidad de asistir a Tribunales.",
    icon: "M-12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"
  },
  {
    title: "Honorarios Fijos",
    desc: "Transparencia total. Planes de pago en cuotas fijas en pesos.",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "Plazo Rápido",
    desc: "Resolución ágil en CABA, generalmente entre 60 y 90 días.",
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];
---

<section class="py-12 bg-[#05051a] border-y border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {items.map(item => (
        <div class="group p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-amber-400/30 transition-all duration-300">
          <div class="w-10 h-10 mb-4 rounded-lg bg-amber-400/10 flex items-center justify-center text-amber-400 group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2 uppercase tracking-tight">{item.title}</h3>
          <p class="text-sm text-indigo-100/60 leading-relaxed italic">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>