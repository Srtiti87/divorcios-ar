---
// src/components/ProcesoEtapas.astro
const etapas = [
  { title: "Contacto Inicial", desc: "Análisis profundo de su situación y diseño de la estrategia legal a medida." },
  { title: "Documentación", desc: "Gestión experta de partidas, documentación y acuerdos preliminares de patrimonio." },
  { title: "Inicio Judicial", desc: "Presentación formal ante el Juzgado de Familia con seguimiento y reporte." },
  { title: "Gestión Procesal", desc: "Control riguroso de plazos, notificaciones y audiencias." },
  { title: "Sentencia e Inscripción", desc: "Finalización del proceso con la debida inscripción registral para su tranquilidad." }
];
---

<section class="py-24 px-4 bg-indigo-950 overflow-hidden">
  <div class="max-w-3xl mx-auto">
    
    <div class="text-center mb-20">
      <h2 class="text-4xl md:text-6xl font-black text-white uppercase tracking-tighter mb-4">
        Proceso en <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 to-purple-400">Marcha</span>
      </h2>
      <p class="text-indigo-300/50 uppercase tracking-[0.2em] text-[10px] font-black italic">Un camino claro hacia su solución legal</p>
    </div>

    <div class="relative">
      <div class="absolute left-1/2 top-0 bottom-0 w-[2px] bg-white/5 -translate-x-1/2 z-0"></div>
      
      <div 
        id="main-progress-line" 
        class="absolute left-1/2 top-0 w-[2px] bg-gradient-to-b from-indigo-500 via-purple-500 to-pink-500 -translate-x-1/2 transition-all duration-[4000ms] ease-linear z-0"
        style="height: 0%"
      ></div>

      <div class="space-y-12 relative z-10">
        {etapas.map((etapa, index) => (
          <div class="step-container opacity-0 translate-y-10 transition-all duration-700">
            
            <div class="relative group">
              <div class="flex justify-center mb-[-20px] relative z-20">
                <div class="w-10 h-10 rounded-full bg-indigo-600 border-4 border-indigo-950 flex items-center justify-center shadow-xl">
                  <span class="text-white font-black text-sm">{index + 1}</span>
                </div>
              </div>

              <div class="bg-white/[0.03] border-2 border-white/10 p-8 md:p-12 rounded-[3rem] text-center hover:border-indigo-500/50 transition-all duration-500 backdrop-blur-md relative">
                
                <div class="absolute inset-0 rounded-[2.8rem] border border-white/5 pointer-events-none"></div>
                
                <h3 class="text-white font-black uppercase tracking-tight text-2xl mb-4">{etapa.title}</h3>
                <p class="text-indigo-100/60 text-lg leading-relaxed font-light max-w-xl mx-auto">
                  {etapa.desc}
                </p>

                <div class="absolute -inset-1 bg-gradient-to-b from-indigo-500/20 to-purple-500/20 rounded-[3rem] -z-10 opacity-0 group-hover:opacity-100 transition-opacity blur-xl"></div>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  function startAnimation() {
    const progressLine = document.getElementById('main-progress-line');
    const steps = document.querySelectorAll('.step-container');

    // Forzamos la visibilidad si hay problemas de carga
    if (progressLine) progressLine.style.height = '100%';
    
    steps.forEach((step, i) => {
      setTimeout(() => {
        step.classList.remove('opacity-0', 'translate-y-10');
        step.classList.add('opacity-100', 'translate-y-0');
      }, i * 400);
    });
  }

  // Ejecutar cuando el scroll llegue o si la página ya cargó arriba
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        startAnimation();
      }
    });
  }, { threshold: 0.1 });

  const section = document.querySelector('section');
  if (section) observer.observe(section);
  
  // Backup: si por alguna razón el observer falla, mostrar igual tras 2 segundos
  setTimeout(startAnimation, 2000);
</script>