---
// src/components/Servicios.astro
---
<section id="servicios" class="py-24 px-6 bg-slate-50">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 tracking-tight uppercase">Áreas de Especialización</h2>
            <div class="w-24 h-1.5 bg-indigo-600 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            
            <a href="/servicios/divorcio-express" class="bg-white p-8 rounded-[2.5rem] shadow-lg border-2 border-slate-500 flex flex-col items-center text-center group hover:border-indigo-600 hover:shadow-2xl transition-all duration-300">
                <div class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center text-amber-400 mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <h3 class="text-[13px] font-black text-slate-900 mb-4 tracking-widest uppercase">Divorcio Express</h3>
                <p class="text-slate-700 text-xs leading-relaxed font-bold mb-4">
                    Gestión ágil de divorcios unilaterales o por presentación conjunta.
                </p>
                <span class="text-[10px] font-black text-indigo-600 uppercase tracking-tighter group-hover:underline">Saber más +</span>
            </a>

            <a href="/servicios/division-de-bienes" class="bg-white p-8 rounded-[2.5rem] shadow-lg border-2 border-slate-500 flex flex-col items-center text-center group hover:border-indigo-600 hover:shadow-2xl transition-all duration-300">
                <div class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center text-amber-400 mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                </div>
                <h3 class="text-[13px] font-black text-slate-900 mb-4 tracking-widest uppercase">División de Bienes</h3>
                <p class="text-slate-700 text-xs leading-relaxed font-bold mb-4">
                    Liquidación de la sociedad conyugal y protección de activos patrimoniales.
                </p>
                <span class="text-[10px] font-black text-indigo-600 uppercase tracking-tighter group-hover:underline">Saber más +</span>
            </a>

            <a href="/servicios/compensacion-economica" class="bg-white p-8 rounded-[2.5rem] shadow-lg border-2 border-slate-500 flex flex-col items-center text-center group hover:border-indigo-600 hover:shadow-2xl transition-all duration-300">
                <div class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center text-amber-400 mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                    <span class="font-black text-xl">$</span>
                </div>
                <h3 class="text-[13px] font-black text-slate-900 mb-4 tracking-widest uppercase">Compensación Económica</h3>
                <p class="text-slate-700 text-xs leading-relaxed font-bold mb-4">
                    Reclamo por desequilibrio patrimonial tras la ruptura del vínculo.
                </p>
                <span class="text-[10px] font-black text-indigo-600 uppercase tracking-tighter group-hover:underline">Saber más +</span>
            </a>

            <a href="/servicios/cuidado-personal" class="bg-white p-8 rounded-[2.5rem] shadow-lg border-2 border-slate-500 flex flex-col items-center text-center group hover:border-indigo-600 hover:shadow-2xl transition-all duration-300">
                <div class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center text-amber-400 mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <h3 class="text-[13px] font-black text-slate-900 mb-4 tracking-widest uppercase">Cuidado Personal</h3>
                <p class="text-slate-700 text-xs leading-relaxed font-bold mb-4">
                    Acuerdos de responsabilidad parental y régimen de comunicación.
                </p>
                <span class="text-[10px] font-black text-indigo-600 uppercase tracking-tighter group-hover:underline">Saber más +</span>
            </a>

        </div>

        <div class="mt-16 text-center">
            <a href="https://wa.me/5491141689773" class="inline-flex items-center gap-2 text-indigo-800 font-black uppercase tracking-widest text-[11px] hover:gap-4 transition-all border-b-2 border-indigo-800 pb-1">
                CONSULTAR POR OTROS SERVICIOS LEGALES 
                <span>→</span>
            </a>
        </div>
    </div>
</section>