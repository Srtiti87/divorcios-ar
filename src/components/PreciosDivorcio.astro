---
// src/components/PreciosDivorcio.astro
---
<section class="bg-ink-2 py-12 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8 items-stretch">

            <div class="bg-ink border border-white/10 rounded-sm p-8 shadow-xl flex flex-col order-2 lg:order-1">
                <h3 class="font-serif text-xl font-semibold text-cream tracking-tight mb-1">Divorcio Conjunto</h3>
                <p class="text-cream/40 text-[10px] font-bold uppercase mb-6 tracking-widest">Plan Cuotas Fijas</p>

                <div class="mb-8 flex items-baseline gap-1">
                    <span class="font-serif text-4xl font-light text-cream tracking-tight">$125.000</span>
                    <span class="text-cream/40 font-bold text-xs uppercase">/ mes</span>
                </div>

                <ul class="space-y-3 mb-10 flex-grow">
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Plan de pago mensual
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Sin audiencias, sin ir al juzgado
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Inscripción incluida
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Convenio Regulador incluido
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Consulte valor división de bienes
                    </li>
                </ul>

                <a href="https://wa.me/5491159360995" class="block text-center border border-white/20 text-cream font-bold py-4 rounded-sm uppercase text-[10px] tracking-widest hover:bg-white/5 hover:border-gold/40 transition-all">
                    Ver Plan
                </a>
            </div>

            <div class="bg-ink border-2 border-gold/50 rounded-sm p-8 shadow-2xl flex flex-col relative overflow-hidden order-1 lg:order-2 lg:scale-105 z-10 animate-soft-beat">
                <div class="absolute top-0 right-0 bg-gold text-ink text-[9px] font-black px-4 py-1.5 rounded-bl-sm uppercase tracking-widest">
                    RECOMENDADO
                </div>

                <h3 class="font-serif text-2xl font-semibold text-cream tracking-tight mb-1">Pago de Contado</h3>
                <p class="text-gold text-[10px] font-black uppercase mb-8 tracking-widest leading-relaxed">
                    Efectivo o 2 cuotas
                </p>

                <div class="mb-6">
                    <p class="text-cream/40 text-[10px] font-bold uppercase mb-1 tracking-widest">Mejor Precio</p>
                    <span class="font-serif text-3xl md:text-4xl font-light text-cream leading-none tracking-tight italic block">$999.000</span>
                </div>

                <p class="text-[11px] font-medium text-cream/55 mb-8 leading-relaxed">
                    Ahorro máximo abonando el total o en dos pagos. Sujeto a la complejidad del caso.
                </p>

                <ul class="space-y-4 mb-10 flex-grow">
                    <li class="flex items-center gap-3 text-sm font-medium text-cream/85">
                        <span class="bg-gold/15 p-1 rounded-full text-gold text-[10px]">✓</span> Bonificación Contado
                    </li>
                    <li class="flex items-center gap-3 text-sm font-medium text-cream/85">
                        <span class="bg-gold/15 p-1 rounded-full text-gold text-[10px]">✓</span> Inicio Online
                    </li>
                    <li class="flex items-center gap-3 text-sm font-medium text-cream/85">
                        <span class="bg-gold/15 p-1 rounded-full text-gold text-[10px]">✓</span> Trámite Urgente
                    </li>
                    <li class="flex items-center gap-3 text-sm font-medium text-cream/85">
                        <span class="bg-gold/15 p-1 rounded-full text-gold text-[10px]">✓</span> Prioridad de Trámite
                    </li>
                </ul>

                <a href="https://wa.me/5491159360995" class="block text-center bg-gold text-ink font-bold py-5 rounded-sm uppercase text-xs tracking-widest hover:bg-gold-light transition-all shadow-lg">
                    Consultar Descuento
                </a>
            </div>

            <div class="bg-ink border border-white/10 rounded-sm p-8 shadow-xl flex flex-col order-3">
                <h3 class="font-serif text-xl font-semibold text-cream tracking-tight mb-1">Divorcio Unilateral</h3>
                <p class="text-cream/40 text-[10px] font-bold uppercase mb-6 tracking-widest">Plan Cuotas Fijas</p>

                <div class="mb-8 flex items-baseline gap-1">
                    <span class="font-serif text-4xl font-light text-cream tracking-tight">$149.000</span>
                    <span class="text-cream/40 font-bold text-xs uppercase">/ mes</span>
                </div>

                <ul class="space-y-3 mb-10 flex-grow">
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Plan de pago mensual
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Patrocinio Exclusivo
                    </li>
                    <li class="flex items-center gap-2 text-xs font-medium text-cream/65">
                        <span class="text-gold font-black">✓</span> Sentencia e Inscripción
                    </li>
                </ul>

                <a href="https://wa.me/5491159360995" class="block text-center border border-white/20 text-cream font-bold py-4 rounded-sm uppercase text-[10px] tracking-widest hover:bg-white/5 hover:border-gold/40 transition-all">
                    Ver Plan
                </a>
            </div>
        </div>

        <p class="text-center text-[10px] text-cream/30 font-bold uppercase mt-12 tracking-[0.4em]">Tasa de justicia no incluida</p>
    </div>
</section>

<style>
    @keyframes softBeat {
        0%, 100% { transform: scale(1.05); }
        50% { transform: scale(1.06); }
    }

    @media (max-width: 1023px) {
        .lg\:scale-105 {
            transform: scale(1) !important;
        }
        .animate-soft-beat {
            animation: none !important;
        }
    }

    @media (min-width: 1024px) {
        .animate-soft-beat {
            animation: softBeat 4s infinite ease-in-out;
        }
    }
</style>
