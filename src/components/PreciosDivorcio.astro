---
// src/components/PreciosDivorcio.astro
---
<section class="bg-indigo-950 py-12 md:py-20 px-6">
    <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8 items-stretch">
            
            <div class="bg-white border-2 border-slate-100 rounded-[2.5rem] p-8 shadow-xl flex flex-col order-2 lg:order-1">
                <h3 class="text-lg font-black text-slate-900 uppercase tracking-tighter mb-1">Divorcio Conjunto</h3>
                <p class="text-slate-500 text-[10px] font-bold uppercase mb-6 tracking-widest">Plan Cuotas Fijas</p>
                
                <div class="mb-8 flex items-baseline gap-1">
                    <span class="text-4xl font-black text-slate-900 tracking-tighter">$99.000</span>
                    <span class="text-slate-500 font-bold text-xs uppercase">/ mes</span>
                </div>

                <ul class="space-y-3 mb-10 flex-grow">
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-indigo-600 font-black">✓</span> Plan de pago mensual
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-indigo-600 font-black">✓</span> Sin audiencias, sin ir al juzgado
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-indigo-600 font-black">✓</span> Inscripción incluida
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-indigo-600 font-black">✓</span> Convenio Regulador incluido
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-indigo-600 font-black">✓</span> Consulte valor división de bienes
                    </li>
                </ul>

                <a href="https://wa.me/5491141689773" class="block text-center border-2 border-slate-900 text-slate-900 font-black py-4 rounded-xl uppercase text-[10px] tracking-widest hover:bg-slate-900 hover:text-white transition-all">
                    Ver Plan
                </a>
            </div>

            <div class="bg-white border-[3px] border-indigo-500 rounded-[2.5rem] p-8 shadow-2xl flex flex-col relative overflow-hidden order-1 lg:order-2 lg:scale-105 z-10 animate-soft-beat">
                <div class="absolute top-0 right-0 bg-indigo-600 text-white text-[9px] font-black px-4 py-1.5 rounded-bl-xl uppercase tracking-widest">
                    RECOMENDADO
                </div>
                
                <h3 class="text-xl font-black text-slate-900 uppercase tracking-tighter mb-1">Pago EFECTIVO</h3>
                <p class="text-indigo-600 text-[10px] font-black uppercase mb-8 tracking-widest leading-relaxed">
                    Efectivo o 2 cuotas
                </p>
                
                <div class="mb-6">
                    <p class="text-slate-400 text-[10px] font-bold uppercase mb-1 tracking-widest">Mejor Precio</p>
                    <span class="text-2xl md:text-3xl font-black text-slate-900 leading-none tracking-tighter italic block">CONSULTAR PRECIO CONTADO </span>
                </div>

                <p class="text-[11px] font-bold text-slate-500 mb-8 leading-relaxed">
                    Ahorro máximo abonando el total o en dos pagos. Sujeto a la complejidad del caso.
                </p>

                <ul class="space-y-4 mb-10 flex-grow">
                    <li class="flex items-center gap-3 text-sm font-black text-indigo-700">
                        <span class="bg-indigo-50 p-1 rounded-full text-indigo-600 text-[10px]">✓</span> Bonificación Contado
                    </li>
                    <li class="flex items-center gap-3 text-sm font-black text-indigo-700">
                        <span class="bg-indigo-50 p-1 rounded-full text-indigo-600 text-[10px]">✓</span> Inicio Online
                    </li>
                    <li class="flex items-center gap-3 text-sm font-black text-indigo-700">
                        <span class="bg-indigo-50 p-1 rounded-full text-indigo-600 text-[10px]">✓</span> Tramite Urgente
                    </li>
                    <li class="flex items-center gap-3 text-sm font-black text-indigo-700">
                        <span class="bg-indigo-50 p-1 rounded-full text-indigo-600 text-[10px]">✓</span> Prioridad de Trámite
                    </li>
                </ul>

                <a href="https://wa.me/5491141689773" class="block text-center bg-indigo-600 text-white font-black py-5 rounded-2xl uppercase text-xs tracking-widest hover:bg-slate-900 transition-all shadow-lg">
                    Consultar Descuento
                </a>
            </div>

            <div class="bg-white border-2 border-slate-100 rounded-[2.5rem] p-8 shadow-xl flex flex-col order-3">
                <h3 class="text-lg font-black text-slate-900 uppercase tracking-tighter mb-1">Divorcio Unilateral</h3>
                <p class="text-slate-500 text-[10px] font-bold uppercase mb-6 tracking-widest">Plan Cuotas Fijas</p>
                
                <div class="mb-8 flex items-baseline gap-1">
                    <span class="text-4xl font-black text-slate-900 tracking-tighter">$135.000</span>
                    <span class="text-slate-500 font-bold text-xs uppercase">/ mes</span>
                </div>

                <ul class="space-y-3 mb-10 flex-grow">
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-slate-900 font-black">✓</span> Plan de pago mensual
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-slate-900 font-black">✓</span> Patrocinio Exclusivo
                    </li>
                    <li class="flex items-center gap-2 text-xs font-bold text-slate-600">
                        <span class="text-slate-900 font-black">✓</span> Sentencia e Inscripción
                    </li>
                </ul>

                <a href="https://wa.me/5491141689773" class="block text-center border-2 border-slate-900 text-slate-900 font-black py-4 rounded-xl uppercase text-[10px] tracking-widest hover:bg-slate-900 hover:text-white transition-all">
                    Ver Plan
                </a>
            </div>
        </div>

        <p class="text-center text-[10px] text-indigo-300/40 font-black uppercase mt-12 tracking-[0.5em]">Tasa de justicia no incluida</p>
    </div>
</section>

<style>
    /* Animación mucho más sutil y solo perceptible en desktop */
    @keyframes softBeat {
        0%, 100% { transform: scale(1.05); }
        50% { transform: scale(1.06); }
    }

    /* En móvil (menos de 1024px) quitamos la escala y la animación */
    @media (max-width: 1023px) {
        .lg\:scale-105 {
            transform: scale(1) !important;
        }
        .animate-soft-beat {
            animation: none !important;
        }
    }

    /* En escritorio la animación es casi imperceptible */
    @media (min-width: 1024px) {
        .animate-soft-beat {
            animation: softBeat 4s infinite ease-in-out;
        }
    }
</style>