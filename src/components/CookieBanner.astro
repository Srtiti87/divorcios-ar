---
// src/components/CookieBanner.astro
// Banner de consentimiento de cookies. Controla la carga real de GTM/Analytics:
// loadGTM() solo se ejecuta si el usuario acepta, o si ya aceptó en una visita anterior.
---
<div id="cookie-banner" class="fixed bottom-24 md:bottom-10 left-6 right-6 md:left-10 md:right-auto md:max-w-[340px] z-[300] transform translate-y-20 opacity-0 transition-all duration-700 ease-out pointer-events-none">
    <div style="background:rgba(20,21,31,0.97);backdrop-filter:blur(20px)" class="border border-white/10 p-6 rounded-sm shadow-2xl">

        <div class="w-8 h-8 rounded-sm flex items-center justify-center mb-4" style="background:rgba(184,150,90,0.12)">
            <div class="w-2 h-2 rounded-full" style="background:#b8965a"></div>
        </div>

        <p class="text-[11px] leading-relaxed mb-5 font-light" style="color:rgba(245,244,240,0.72)">
            En <span class="font-semibold" style="color:#f5f4f0">divorcios.ar</span> usamos cookies de análisis para mejorar su experiencia. Puede revisar nuestra
            <a href="/privacidad" style="color:#b8965a;text-decoration:underline;text-decoration-color:rgba(184,150,90,0.4)">Política de Privacidad</a>.
        </p>

        <div class="flex gap-2">
            <button id="accept-cookies" style="background:#b8965a;color:#14151f" class="flex-1 text-[10px] font-bold uppercase tracking-[0.12em] py-3 rounded-sm hover:opacity-90 transition-all">
                Aceptar
            </button>
            <button id="reject-cookies" style="border:1px solid rgba(245,244,240,0.15);color:rgba(245,244,240,0.6)" class="flex-1 text-[10px] font-bold uppercase tracking-[0.12em] py-3 rounded-sm hover:bg-white/5 transition-all">
                Rechazar
            </button>
        </div>
    </div>
</div>

<script>
    const initCookieBanner = () => {
        const banner = document.getElementById('cookie-banner');
        const acceptBtn = document.getElementById('accept-cookies');
        const rejectBtn = document.getElementById('reject-cookies');

        if (!banner || !acceptBtn || !rejectBtn) return;

        const consent = localStorage.getItem('cookie-consent-v2');

        function show() {
            banner.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
        }
        function hide() {
            banner.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
        }

        if (consent === 'accepted') {
            // Ya aceptó antes: cargar analytics directamente, sin mostrar el banner.
            window.dispatchEvent(new CustomEvent('cookies-accepted'));
        } else if (consent === 'rejected') {
            // Ya rechazó antes: no mostrar banner, no cargar analytics.
        } else {
            // Sin decisión previa: mostrar banner y esperar.
            setTimeout(show, 1500);
        }

        acceptBtn.addEventListener('click', () => {
            localStorage.setItem('cookie-consent-v2', 'accepted');
            hide();
            window.dispatchEvent(new CustomEvent('cookies-accepted'));
        });

        rejectBtn.addEventListener('click', () => {
            localStorage.setItem('cookie-consent-v2', 'rejected');
            hide();
        });
    };

    initCookieBanner();
</script>
