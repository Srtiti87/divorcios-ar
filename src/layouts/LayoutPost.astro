---
// src/layouts/LayoutPost.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro';
import '@fontsource-variable/inter';

interface Props {
  frontmatter?: { title: string; description: string; category?: string; date?: string; };
  title?: string;
  description?: string;
}

const { frontmatter, title, description } = Astro.props;
const isPost = !!frontmatter;

const metaTitle = title || frontmatter?.title || "Abogados A&G";
const metaDescription = description || frontmatter?.description || "Estudio Jurídico Especialista en Derecho de Familia.";
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metaTitle} | divorcios.ar</title>
    <meta name="description" content={metaDescription} />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'GTM-KPJP7PBP');
    </script>
    <script async src="https://www.googletagmanager.com/gtm.js?id=GTM-KPJP7PBP"></script>

    <link rel="preload" href="/_astro/inter-latin-variable-wght-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    {isPost && <link rel="stylesheet" href="/_astro/blog.css" />}

    <style is:inline>
      /* Estabilizador de CLS: Reserva el espacio del Hero */
      .hero-title { min-height: 1.2em; contain: layout; }
      /* Display Swap para evitar texto invisible */
      :root { font-display: swap; }
    </style>

    <slot name="head" />
</head>

<body class=`flex flex-col min-h-screen ${isPost ? 'bg-indigo-950 text-indigo-100' : 'bg-white text-slate-900'}`>
    <Header />
    <main class="flex-grow">
        {isPost ? (
            <article class="max-w-4xl mx-auto pt-32 px-6">
                <h1 class="text-4xl md:text-7xl font-black text-white uppercase mb-12">{frontmatter.title}</h1>
                <slot />
            </article>
        ) : (
            <slot />
        )}
    </main>
    <Footer />
    <WhatsappFlotante />
</body>
</html>