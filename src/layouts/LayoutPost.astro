---
// src/layouts/LayoutPost.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro';

const { frontmatter } = Astro.props;

// Construimos la URL canónica (ajusta el dominio si es necesario)
const canonicalURL = new URL(Astro.url.pathname, 'https://www.divorcios.ar');
---

<html lang="es">
<head>
        <!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KPJP7PBP');</script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="language" content="es" />
    
    <title>{frontmatter.title} | divorcios.ar</title>
    <meta name="description" content={frontmatter.description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description} />
    <meta property="og:image" content="https://www.divorcios.ar/img/og-image-divorcios.webp" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Abogados especialistas en derecho de familia Divorcios en Capital Federal - divorcios.ar" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={frontmatter.title} />
    <meta name="twitter:description" content={frontmatter.description} />
    <meta name="twitter:image" content="https://www.divorcios.ar/img/og-image-divorcios.webp" />

    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="geo.region" content="AR-C" />
    <meta name="geo.placename" content="Buenos Aires" />
</head>

<body class="bg-indigo-950 text-indigo-100 flex flex-col min-h-screen font-sans selection:bg-indigo-500 selection:text-white">
    <!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KPJP7PBP"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->
    <Header />
    
    <main class="flex-grow pt-32 pb-20 px-6">
        <article class="max-w-4xl mx-auto">
            <header class="mb-16 text-center">
                <div class="flex items-center justify-center gap-4 text-[10px] font-black uppercase tracking-[0.3em] text-indigo-400 mb-8">
                    <span class="bg-indigo-500/10 border border-indigo-500/30 px-4 py-1.5 rounded-full">{frontmatter.category}</span>
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500/40"></span>
                    <span class="text-indigo-100/40">{frontmatter.date}</span>
                </div>
                
                <h1 class="text-4xl md:text-7xl font-black text-white tracking-tighter uppercase leading-[0.9] mb-12">
                    {frontmatter.title}
                </h1>

                <div class="flex items-center justify-center gap-8 border-y border-white/5 py-6">
                    <div class="text-left">
                        <p class="text-[9px] uppercase tracking-widest text-indigo-400 font-black mb-1">Lectura</p>
                        <p class="text-xs font-bold text-white">8 Minutos aprox.</p>
                    </div>
                    <div class="text-left">
                        <p class="text-[9px] uppercase tracking-widest text-indigo-400 font-black mb-1">Autoría</p>
                        <p class="text-xs font-bold text-white">Estudio Jurídico D.AR</p>
                    </div>
                </div>
            </header>

            <div class="prose-legal max-w-3xl mx-auto">
                <slot /> 
            </div>

            <div class="mt-24 max-w-3xl mx-auto">
                <div class="relative p-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-[3rem]">
                    <div class="bg-indigo-950 p-12 rounded-[2.8rem] text-center">
                        <h3 class="text-3xl font-black text-white mb-4 uppercase tracking-tighter">¿Su situación requiere intervención legal?</h3>
                        <p class="text-indigo-200/70 mb-10 text-lg leading-relaxed">
                            No tome decisiones sobre su patrimonio sin asesoramiento profesional. Garantizamos absoluta reserva y una estrategia adaptada a sus intereses.
                        </p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="https://wa.me/5491141689773" class="bg-white text-indigo-950 hover:bg-indigo-400 hover:text-white font-black uppercase tracking-widest px-10 py-5 rounded-2xl transition-all shadow-2xl flex items-center justify-center gap-3">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                                Agendar Consulta Personalizada
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </main>

    <Footer />
    <WhatsappFlotante />

    <style is:global>
        @reference "tailwindcss";

        .prose-legal {
            @apply break-words overflow-x-hidden w-full;
        }

        .prose-legal h1 {
            @apply text-3xl md:text-5xl font-black text-white mb-8 tracking-tighter uppercase leading-tight;
        }

        .prose-legal h2 {
            @apply text-xl md:text-3xl font-black text-white mt-16 mb-6 uppercase tracking-tighter leading-none flex items-center gap-3;
        }
        
        .prose-legal h2::before {
            @apply content-[''] hidden sm:block w-8 h-[2px] bg-indigo-500;
        }

        .prose-legal h3 {
            @apply text-lg md:text-xl font-bold text-indigo-300 mt-10 mb-4 uppercase tracking-tight;
        }

        .prose-legal p {
            @apply text-indigo-100/80 leading-relaxed mb-6 text-base md:text-xl font-light;
        }

        .prose-legal ul {
            @apply bg-white/5 border border-white/10 p-6 md:p-10 rounded-[2rem] space-y-4 mb-10 ml-0;
        }

        .prose-legal ul li {
            @apply flex items-start gap-3 text-indigo-100/70 text-sm md:text-lg leading-snug before:content-['→'] before:text-indigo-500 before:font-black;
        }

        .prose-legal strong {
            @apply text-white font-bold;
        }

        .prose-legal blockquote {
            @apply border-l-4 md:border-l-8 border-indigo-500 bg-white/5 p-6 md:p-10 rounded-r-2xl md:rounded-r-3xl italic text-lg md:text-2xl text-indigo-200 my-10 leading-relaxed mx-0;
        }

        .prose-legal hr {
            @apply border-0 border-t border-white/5 my-12;
        }

        .prose-legal img {
            @apply max-w-full h-auto rounded-2xl my-8;
        }
    </style>
</body>
<style is:global>
    @reference "tailwindcss";

    /* Contenedor del artículo */
    .prose-legal {
        @apply break-words overflow-x-hidden w-full;
    }

    /* ESTILO PARA LOS ENLACES (Interlinking) */
    .prose-legal a {
        @apply text-indigo-400 font-bold underline decoration-indigo-500/50 underline-offset-4 transition-all duration-300 hover:text-white hover:decoration-white hover:bg-indigo-500/10 rounded-sm px-1;
    }

    /* Títulos */
    .prose-legal h1 {
        @apply text-3xl md:text-5xl font-black text-white mb-8 tracking-tighter uppercase leading-tight;
    }

    .prose-legal h2 {
        @apply text-xl md:text-3xl font-black text-white mt-16 mb-6 uppercase tracking-tighter leading-none flex items-center gap-3;
    }
    
    .prose-legal h2::before {
        @apply content-[''] hidden sm:block w-8 h-[2px] bg-indigo-500;
    }

    .prose-legal h3 {
        @apply text-lg md:text-xl font-bold text-indigo-300 mt-10 mb-4 uppercase tracking-tight;
    }

    /* Párrafos y texto */
    .prose-legal p {
        @apply text-indigo-100/80 leading-relaxed mb-6 text-base md:text-xl font-light;
    }

    /* Listas con flechas */
    .prose-legal ul {
        @apply bg-white/5 border border-white/10 p-6 md:p-10 rounded-[2rem] space-y-4 mb-10 ml-0 list-none;
    }

    .prose-legal ul li {
        @apply flex items-start gap-3 text-indigo-100/70 text-sm md:text-lg leading-snug before:content-['→'] before:text-indigo-500 before:font-black;
    }

    .prose-legal strong {
        @apply text-white font-bold;
    }

    /* Citas / Destacados */
    .prose-legal blockquote {
        @apply border-l-4 md:border-l-8 border-indigo-500 bg-white/5 p-6 md:p-10 rounded-r-2xl md:rounded-r-3xl italic text-lg md:text-2xl text-indigo-200 my-10 leading-relaxed mx-0;
    }

    .prose-legal hr {
        @apply border-0 border-t border-white/5 my-12;
    }
</style>
</html>