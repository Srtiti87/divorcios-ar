---
// src/layouts/LayoutPost.astro
import '../styles/global.css';
import '../styles/blog.css'; 
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro';
import '@fontsource-variable/inter';

const { frontmatter } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://www.divorcios.ar');
---

<html lang="es">
<head>
    <link rel="preload" href="/_astro/inter-latin-variable-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <script type="text/partytown" is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-KPJP7PBP');
    </script>
    
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{frontmatter.title} | divorcios.ar</title>
    <meta name="description" content={frontmatter.description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description} />
    <meta property="og:image" content="https://www.divorcios.ar/img/og-image-divorcios.webp" />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="geo.region" content="AR-C" />
    <meta name="geo.placename" content="Buenos Aires" />
</head>

<body class="bg-indigo-950 text-indigo-100 flex flex-col min-h-screen font-sans selection:bg-indigo-500 selection:text-white">
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KPJP7PBP" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    
    <Header />
    
    <main class="flex-grow pt-32 pb-20 px-6">
        <article class="max-w-4xl mx-auto">
            <header class="mb-16 text-center">
                <div class="flex items-center justify-center gap-4 text-[10px] font-black uppercase tracking-[0.3em] text-indigo-400 mb-8">
                    <span class="bg-indigo-500/10 border border-indigo-500/30 px-4 py-1.5 rounded-full">{frontmatter.category}</span>
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500/40"></span>
                    <span class="text-indigo-100/40">{frontmatter.date}</span>
                </div>
                
                <h1 class="text-4xl md:text-7xl font-black text-white tracking-tighter uppercase leading-[0.9] mb-12">
                    {frontmatter.title}
                </h1>

                <div class="flex items-center justify-center gap-8 border-y border-white/5 py-6">
                    <div class="text-left">
                        <p class="text-[9px] uppercase tracking-widest text-indigo-400 font-black mb-1">Lectura</p>
                        <p class="text-xs font-bold text-white">8 Minutos aprox.</p>
                    </div>
                    <div class="text-left">
                        <p class="text-[9px] uppercase tracking-widest text-indigo-400 font-black mb-1">Autoría</p>
                        <p class="text-xs font-bold text-white">Abogados A&G</p>
                    </div>
                </div>
            </header>

            <div class="prose-legal max-w-3xl mx-auto">
                <slot /> 
            </div>

            <div class="mt-24 max-w-3xl mx-auto">
                <div class="relative p-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-[3rem]">
                    <div class="bg-indigo-950 p-12 rounded-[2.8rem] text-center">
                        <h3 class="text-3xl font-black text-white mb-4 uppercase tracking-tighter">¿Su situación requiere intervención legal?</h3>
                        <p class="text-indigo-200/70 mb-10 text-lg leading-relaxed">No tome decisiones sobre su patrimonio sin asesoramiento profesional.</p>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <a href="https://wa.me/5491141689773" class="bg-white text-indigo-950 hover:bg-indigo-400 hover:text-white font-black uppercase tracking-widest px-10 py-5 rounded-2xl transition-all shadow-2xl">
                                Agendar Consulta Personalizada
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </article>
    </main>

    <Footer />
    <WhatsappFlotante />
</body>
</html>

<style is:global>
    /* Eliminamos @reference y @apply en colores para asegurar el build */
    
    .prose-legal { 
        word-break: break-word;
        overflow-x: hidden;
        width: 100%;
    }

    /* Usamos variables de CSS para los colores de Tailwind */
    .prose-legal a { 
        color: var(--color-indigo-400, #818cf8);
        font-weight: 700;
        text-decoration: underline;
        text-decoration-color: rgba(99, 102, 241, 0.5);
        text-underline-offset: 4px;
        transition: all 0.3s;
    }
    .prose-legal a:hover {
        color: white;
        background-color: rgba(99, 102, 241, 0.1);
    }

    .prose-legal h2 { 
        font-size: 1.875rem;
        line-height: 2.25rem;
        font-weight: 900;
        color: white;
        margin-top: 4rem;
        margin-bottom: 1.5rem;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .prose-legal h3 { 
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--color-indigo-300, #a5b4fc);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        text-transform: uppercase;
    }

    .prose-legal p { 
        color: rgba(224, 231, 255, 0.8);
        line-height: 1.625;
        margin-bottom: 1.5rem;
        font-size: 1.125rem;
        font-weight: 300;
    }

    .prose-legal ul { 
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 2.5rem;
        border-radius: 2rem;
        margin-bottom: 2.5rem;
        list-style: none;
    }

    .prose-legal ul li { 
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        color: rgba(224, 231, 255, 0.7);
        font-size: 1.125rem;
        margin-bottom: 1rem;
    }

    .prose-legal ul li::before {
        content: '→';
        color: var(--color-indigo-500, #6366f1);
        font-weight: 900;
    }

    .prose-legal blockquote { 
        border-left: 8px solid var(--color-indigo-500, #6366f1);
        background-color: rgba(255, 255, 255, 0.05);
        padding: 2.5rem;
        border-radius: 0 1rem 1rem 0;
        font-style: italic;
        font-size: 1.5rem;
        color: var(--color-indigo-200, #c7d2fe);
        margin: 2.5rem 0;
    }

    .prose-legal hr { 
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        margin: 3rem 0;
    }
</style>