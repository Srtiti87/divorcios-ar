---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro';
import '@fontsource-variable/inter';

interface Props {
  frontmatter?: { title: string; description: string; category?: string; date?: string; };
  title?: string;
  description?: string;
}

const { frontmatter, title, description } = Astro.props;
const isPost = !!frontmatter;

const metaTitle = title || frontmatter?.title || "Abogados A&G";
const metaDescription = description || frontmatter?.description || "Estudio Jurídico Especialista en Derecho de Familia.";
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metaTitle} | divorcios.ar</title>
    <meta name="description" content={metaDescription} />

    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />

    {/* Astro inyectará automáticamente los estilos de global.css aquí. 
        Para los posts, evitaremos link manuales a "/_astro/blog.css" ya que el hash cambia. 
        Si necesitas estilos de blog, es mejor importarlos en el frontmatter de Astro. */}

    <link rel="preload" as="image" href="/images/bg-tribunales.webp" fetchpriority="high" />

    <script is:inline>
      function loadGTM() {
        if (window.gtmLoaded) return;
        window.gtmLoaded = true;
        window.dataLayer = window.dataLayer || [];
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-KPJP7PBP');
        function gtag(){window.dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'AW-17919248557');
      }
      window.addEventListener('scroll', loadGTM, { once: true });
      window.addEventListener('mousemove', loadGTM, { once: true });
      window.addEventListener('touchstart', loadGTM, { once: true });
      setTimeout(loadGTM, 3500); // Aumentamos un poco el delay para priorizar el renderizado visual
    </script>

    <style is:inline>
      /* Definimos la fuente y el fondo inmediatamente para evitar el CLS (salto de diseño) */
      :root { 
        font-family: 'Inter Variable', system-ui, sans-serif; 
        font-display: swap; 
        background-color: #05051a; 
      }
      /* Reservamos el espacio para evitar saltos de diseño */
      .hero-title { min-height: 1.2em; contain: layout; }
    </style>

    <slot name="head" />
</head>

<body class="flex flex-col min-h-screen bg-[#05051a] text-indigo-100 antialiased">
    <Header />
    <main class="flex-grow">
        {isPost ? (
            <article class="max-w-4xl mx-auto pt-32 px-6">
                <h1 class="text-4xl md:text-7xl font-black text-white uppercase mb-12">{frontmatter.title}</h1>
                <div class="prose prose-invert max-w-none">
                    <slot />
                </div>
            </article>
        ) : (
            <slot />
        )}
    </main>
    <Footer />
    <WhatsappFlotante />
</body>
</html>