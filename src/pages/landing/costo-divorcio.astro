<style>
@font-face{font-family:"Cormorant Garamond";font-style:normal;font-weight:300;font-display:swap;src:url("/fonts/cormorant-garamond-latin-300-normal.woff2") format("woff2")}
@font-face{font-family:"Cormorant Garamond";font-style:italic;font-weight:300;font-display:swap;src:url("/fonts/cormorant-garamond-latin-300-italic.woff2") format("woff2")}
@font-face{font-family:"Cormorant Garamond";font-style:normal;font-weight:600;font-display:swap;src:url("/fonts/cormorant-garamond-latin-600-normal.woff2") format("woff2")}
@font-face{font-family:"Cormorant Garamond";font-style:italic;font-weight:600;font-display:swap;src:url("/fonts/cormorant-garamond-latin-600-italic.woff2") format("woff2")}
@font-face{font-family:"Outfit";font-style:normal;font-weight:300;font-display:swap;src:url("/fonts/outfit-latin-300-normal.woff2") format("woff2")}
@font-face{font-family:"Outfit";font-style:normal;font-weight:400;font-display:swap;src:url("/fonts/outfit-latin-400-normal.woff2") format("woff2")}
@font-face{font-family:"Outfit";font-style:normal;font-weight:600;font-display:swap;src:url("/fonts/outfit-latin-600-normal.woff2") format("woff2")}
@font-face{font-family:"Outfit";font-style:normal;font-weight:700;font-display:swap;src:url("/fonts/outfit-latin-700-normal.woff2") format("woff2")}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#14151f;--ink-2:#1c1e2b;
  --gold:#b8965a;--gold-light:#d4b07a;
  --gold-faint:rgba(184,150,90,0.08);
  --gold-border:rgba(184,150,90,0.25);
  --cream:#f5f4f0;--border:rgba(245,244,240,0.13);
  --green:#4ade80;
  --ff-serif:"Cormorant Garamond",Georgia,serif;
  --ff-sans:"Outfit",system-ui,sans-serif;
  --ease:cubic-bezier(.16,1,.3,1);
}
html{font-size:16px;scroll-behavior:smooth;background:var(--ink)}
body{font-family:var(--ff-sans);background:var(--ink);color:var(--cream);-webkit-font-smoothing:antialiased;overflow-x:hidden;line-height:1.6}
a{color:inherit;text-decoration:none}
body::before{content:"";position:fixed;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");opacity:.4}

/* TOPBAR */
.topbar{background:var(--gold);color:var(--ink);text-align:center;padding:.55rem 1.5rem;font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;position:relative;z-index:200}
/* NAV */
nav{position:sticky;top:0;z-index:150;display:flex;align-items:center;justify-content:space-between;padding:1rem 3rem;background:rgba(20,21,31,0.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:padding .3s var(--ease)}
.nav-logo{font-family:var(--ff-serif);font-size:1.7rem;font-weight:300;color:var(--cream);letter-spacing:-.03em}
.nav-logo span{color:var(--gold);font-weight:600}
.nav-right{display:flex;align-items:center;gap:1rem}
.nav-tel{color:rgba(245,244,240,0.6);font-size:.85rem;text-decoration:none;transition:color .2s}
.nav-tel:hover{color:var(--gold)}
.nav-cta{background:var(--gold);color:var(--ink);padding:.6rem 1.5rem;border-radius:2px;font-weight:700;font-size:.82rem;letter-spacing:.06em;text-transform:uppercase;transition:background .2s,transform .15s}
.nav-cta:hover{background:var(--gold-light);transform:translateY(-1px)}

/* HERO */
.hero{position:relative;min-height:100svh;display:flex;align-items:center;overflow:hidden;border-bottom:1px solid var(--border)}
.hero-img{position:absolute;top:0;left:0;right:0;bottom:0;z-index:0;overflow:hidden}
.hero-img img{width:100%;height:100%;object-fit:cover;object-position:65% 8%;filter:brightness(.85) contrast(1.02) saturate(.85)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(20,21,31,0.96) 0%,rgba(20,21,31,0.90) 35%,rgba(20,21,31,0.52) 55%,rgba(20,21,31,0.12) 72%,rgba(20,21,31,0.02) 100%)}
@media(max-width:768px){
  .hero-img img{object-position:60% 8%;filter:brightness(.55) contrast(1.02) saturate(.85)}
  .hero-overlay{background:linear-gradient(180deg,rgba(20,21,31,0.45) 0%,rgba(20,21,31,0.65) 50%,rgba(20,21,31,0.92) 100%)}
}
.hero-content{position:relative;z-index:2;max-width:1200px;margin:0 auto;padding:6rem 3rem;width:100%}
.hero-left{max-width:580px}
.live-row{display:flex;align-items:center;gap:.6rem;margin-bottom:1.5rem}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse-green 2s infinite;flex-shrink:0}
@keyframes pulse-green{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,.45)}50%{box-shadow:0 0 0 8px rgba(74,222,128,0)}}
.live-text{font-size:.7rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--green)}
.hero-kicker{font-size:.7rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.6rem;margin-bottom:1.25rem}
.hero-kicker::before{content:"";width:2rem;height:1px;background:var(--gold)}
h1.hero-h1{font-family:var(--ff-serif);font-size:clamp(3rem,5.5vw,5.5rem);font-weight:300;line-height:.97;letter-spacing:-.03em;color:var(--cream);margin-bottom:1.5rem}
h1.hero-h1 em{font-style:italic;color:var(--gold)}
.hero-sub{font-size:1.05rem;font-weight:300;color:rgba(245,244,240,0.78);max-width:48ch;margin-bottom:1.75rem;line-height:1.72}
.hero-sub strong{color:var(--cream);font-weight:600}
.hero-precios{display:flex;gap:1.5rem;margin-bottom:2rem;flex-wrap:wrap}
.hero-precio-item{display:flex;flex-direction:column;gap:.15rem}
.hero-precio-label{font-size:.6rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:rgba(184,150,90,.75)}
.hero-precio-num{font-family:var(--ff-serif);font-size:2.1rem;color:var(--cream);line-height:1;letter-spacing:-.03em}
.hero-precio-num sup{font-size:.85rem;color:var(--gold);vertical-align:super}
.hero-precio-period{font-size:.62rem;color:rgba(245,244,240,0.38);letter-spacing:.06em;text-transform:uppercase}
.hero-precio-sep{width:1px;background:var(--border);align-self:stretch}
@media(max-width:768px){
  .hero-precios{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem}
  .hero-precio-sep{display:none}
  .hero-precio-item{background:rgba(245,244,240,0.04);border:1px solid rgba(184,150,90,0.2);border-radius:3px;padding:.6rem .85rem}
  .hero-precio-num{font-size:1.7rem}
  .hero-precio-label{font-size:.55rem}
  .hero-precio-period{font-size:.58rem}
}
.hero-ctas{display:flex;flex-direction:column;gap:.65rem;max-width:420px;margin-bottom:1rem}
.btn-hero-main{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.1rem 1.75rem;background:var(--gold);color:var(--ink);border-radius:2px;font-weight:700;font-size:.92rem;letter-spacing:.04em;transition:background .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 28px rgba(184,150,90,0.3)}
.btn-hero-main:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 8px 36px rgba(184,150,90,0.45)}
.btn-hero-main-text{display:flex;flex-direction:column;gap:.1rem;text-align:left}
.btn-hero-main-label{font-size:.92rem;font-weight:700}
.btn-hero-main-sub{font-size:.7rem;font-weight:400;opacity:.72}
.btn-hero-sec{display:flex;align-items:center;gap:.6rem;padding:.9rem 1.5rem;color:rgba(245,244,240,0.78);border:1px solid rgba(245,244,240,0.15);border-radius:2px;font-size:.88rem;font-weight:500;transition:border-color .2s,color .2s}
.btn-hero-sec:hover{border-color:var(--gold-border);color:var(--cream)}
.hero-disclaimer{font-size:.7rem;color:rgba(245,244,240,0.32);letter-spacing:.05em}


/* FORM SECTION */
.form-section{padding:5rem 3rem;background:var(--ink-2);border-bottom:1px solid var(--border)}
.form-section-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
.form-left h2{font-family:var(--ff-serif);font-size:clamp(2rem,3vw,3rem);font-weight:300;line-height:1.05;letter-spacing:-.02em;color:var(--cream);margin-bottom:1rem}
.form-left h2 em{font-style:italic;color:var(--gold)}
.form-left p{font-size:.95rem;color:rgba(245,244,240,0.58);line-height:1.72;margin-bottom:1.5rem}
.form-trust{display:flex;flex-direction:column;gap:.6rem}
.form-trust-item{display:flex;align-items:center;gap:.6rem;font-size:.83rem;color:rgba(245,244,240,0.55)}
.form-trust-icon{color:var(--gold);flex-shrink:0}
.form-card{background:rgba(10,11,18,0.9);border:1px solid var(--gold-border);border-radius:4px;padding:2.25rem 2rem;backdrop-filter:blur(16px);box-shadow:0 8px 40px rgba(0,0,0,0.35)}
.form-card-tag{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.5rem;margin-bottom:1.25rem}
.form-card-tag::before{content:"";width:1.5rem;height:1px;background:var(--gold)}
.form-card h3{font-family:var(--ff-serif);font-size:1.6rem;font-weight:300;color:var(--cream);margin-bottom:.3rem}
.form-card h3 em{font-style:italic;color:var(--gold)}
.form-card-sub{font-size:.82rem;color:rgba(245,244,240,0.45);margin-bottom:1rem;line-height:1.5}
.form-resp{display:flex;align-items:center;gap:.5rem;font-size:.68rem;color:var(--green);font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.5rem .75rem;background:rgba(74,222,128,0.05);border:1px solid rgba(74,222,128,0.15);border-radius:2px;margin-bottom:1.25rem}
.mini-form{display:flex;flex-direction:column;gap:.75rem}
.fg label{display:block;font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,244,240,0.38);margin-bottom:.35rem}
.fg select,.fg input{width:100%;background:rgba(0,0,0,0.35);border:1px solid rgba(245,244,240,0.1);border-radius:2px;color:var(--cream);font-family:var(--ff-sans);font-size:.9rem;padding:.75rem 1rem;outline:none;transition:border-color .2s,box-shadow .2s;-webkit-appearance:none}
.fg select:focus,.fg input:focus{border-color:var(--gold-border);box-shadow:0 0 0 3px rgba(184,150,90,0.1)}
.fg select option{background:#1c1e2b}
.btn-form{width:100%;padding:.95rem;background:var(--gold);color:var(--ink);font-family:var(--ff-sans);font-size:.88rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border:none;border-radius:2px;cursor:pointer;transition:background .2s,transform .15s,box-shadow .2s;box-shadow:0 4px 20px rgba(184,150,90,0.25);margin-top:.25rem}
.btn-form:hover{background:var(--gold-light);transform:translateY(-1px);box-shadow:0 8px 28px rgba(184,150,90,0.4)}
.form-note{font-size:.65rem;color:rgba(245,244,240,0.25);text-align:center;margin-top:.6rem;line-height:1.5}
.form-success{display:none;text-align:center;padding:2rem 0}
.form-success.show{display:block}
.success-icon{width:3.5rem;height:3.5rem;border-radius:50%;background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.3);color:var(--green);font-size:1.4rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem}
.form-success h4{font-family:var(--ff-serif);font-size:1.3rem;color:var(--gold);margin-bottom:.4rem}
.form-success p{font-size:.82rem;color:rgba(245,244,240,0.48);margin-bottom:1rem}

/* PROOF */
.proof-bar{padding:1.25rem 3rem;background:var(--ink);border-bottom:1px solid var(--border)}
.proof-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:2.5rem;flex-wrap:wrap}
.proof-item{display:flex;align-items:center;gap:.55rem}
.proof-num{font-family:var(--ff-serif);font-size:1.6rem;color:var(--gold);line-height:1;letter-spacing:-.02em}
.proof-label{font-size:.68rem;color:rgba(245,244,240,0.45);line-height:1.3;letter-spacing:.06em;text-transform:uppercase;max-width:8ch}
.proof-sep{width:1px;height:1.75rem;background:var(--border)}
@media(max-width:768px){
  .proof-bar{padding:1rem 1.5rem}
  .proof-inner{display:grid;grid-template-columns:1fr 1fr;gap:1rem 1.5rem}
  .proof-sep{display:none}
  .proof-item{gap:.5rem}
  .proof-num{font-size:1.4rem}
  .proof-label{font-size:.62rem;max-width:none}
}

/* SECTION helpers */
.section-kicker{font-size:.7rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem}
.section-kicker::before{content:"";width:2rem;height:1px;background:var(--gold)}
.section-title{font-family:var(--ff-serif);font-size:clamp(2rem,3vw,3rem);font-weight:300;line-height:1.05;letter-spacing:-.02em;color:var(--cream)}
.section-title em{font-style:italic;color:var(--gold)}

/* TARJETAS DE PRECIO */
.precios-section{padding:7rem 3rem;background:var(--ink-2);border-top:1px solid var(--border);position:relative;overflow:hidden}
.precios-section::before{content:"HONORARIOS";position:absolute;font-family:var(--ff-serif);font-size:clamp(6rem,16vw,18rem);font-weight:300;color:rgba(242,237,228,0.018);letter-spacing:-.06em;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;white-space:nowrap;line-height:1;user-select:none}
.precios-inner{max-width:1280px;margin:0 auto;position:relative;z-index:2}
.precios-head{margin-bottom:4rem}
.precios-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:1.5rem}

/* Tarjeta base */
.pc{background:var(--ink);border:1px solid rgba(184,150,90,0.22);border-radius:6px;padding:2.5rem 2rem;display:flex;flex-direction:column;gap:1.5rem;position:relative;overflow:hidden;transition:transform .35s var(--ease),box-shadow .35s var(--ease),border-color .35s}
.pc::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(184,150,90,0.06),transparent 70%);opacity:0;transition:opacity .35s;pointer-events:none}
.pc:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,0.45),0 0 0 1px rgba(184,150,90,0.4),0 0 40px rgba(184,150,90,0.08);border-color:rgba(184,150,90,0.45)}
.pc:hover::before{opacity:1}

/* Conjunto */
.pc.featured{border-color:rgba(184,150,90,0.45);background:linear-gradient(160deg,rgba(184,150,90,0.07) 0%,var(--ink) 55%);border-top:2px solid var(--gold)}
.pc.featured:hover{transform:translateY(-8px);box-shadow:0 24px 70px rgba(0,0,0,0.5),0 0 0 1px rgba(184,150,90,0.6),0 0 60px rgba(184,150,90,0.12)}

/* Contado */
.pc.contado{border-color:rgba(184,150,90,0.55);background:linear-gradient(145deg,rgba(184,150,90,0.12) 0%,rgba(184,150,90,0.04) 40%,var(--ink) 70%);border-top:3px solid var(--gold)}
.pc.contado:hover{transform:translateY(-8px);box-shadow:0 24px 70px rgba(0,0,0,0.5),0 0 0 1px var(--gold),0 0 80px rgba(184,150,90,0.18);border-color:var(--gold)}
.pc.contado::after{content:"";position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:conic-gradient(from 0deg,transparent 340deg,rgba(184,150,90,0.1) 355deg,rgba(184,150,90,0.2) 360deg);animation:rotate-glow 4s linear infinite;opacity:0;transition:opacity .5s;pointer-events:none}
.pc.contado:hover::after{opacity:1}
@keyframes rotate-glow{to{transform:rotate(360deg)}}

.pc-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--gold);color:var(--ink);font-size:.58rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;padding:.3rem 1rem;border-radius:0 0 6px 6px;white-space:nowrap;box-shadow:0 4px 12px rgba(184,150,90,0.3)}
