  .precio-nota strong { color: var(--text); }

  /* QUÉ INCLUYE — tabla simple */
  .incluye-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; max-width: 860px; margin: 0 auto; }
  .incluye-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 1rem 1.25rem; background: var(--bg-card); border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius-sm); }
  .incluye-icon { width: 36px; height: 36px; border-radius: 8px; background: var(--gold-dim); border: 1px solid var(--gold-border); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
  .incluye-item h4 { font-size: 0.88rem; font-weight: 600; margin-bottom: 0.2rem; }
  .incluye-item p { font-size: 0.78rem; color: var(--text-muted); line-height: 1.5; }

  /* FAQ */
  .faq-list { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.65rem; }
  .faq-item { background: var(--bg-card); border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius-sm); overflow: hidden; transition: border-color 0.2s ease; }
  .faq-item[open] { border-color: var(--gold-border); }
  .faq-item summary { padding: 1rem 1.25rem; font-weight: 600; font-size: 0.9rem; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; cursor: pointer; user-select: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chevron { color: var(--gold); font-size: 1.3rem; font-weight: 300; flex-shrink: 0; transition: transform 0.25s ease; }
  .faq-item[open] .faq-chevron { transform: rotate(45deg); }
  .faq-body { padding: 0 1.25rem 1rem; font-size: 0.85rem; color: var(--text-muted); line-height: 1.75; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.85rem; }
  .faq-body strong { color: var(--text); }

  /* WHY */
  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; max-width: 860px; margin: 0 auto; }
  .why-card { background: linear-gradient(160deg, var(--bg-card), var(--bg-card2)); border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius); padding: 1.4rem 1.5rem; transition: all 0.3s ease; display: flex; flex-direction: column; gap: 0.6rem; }
  .why-card:hover { border-color: var(--gold-border); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }
  .why-card-header { display: flex; align-items: center; gap: 0.75rem; }
  .why-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--gold-dim); border: 1px solid var(--gold-border); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
  .why-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; line-height: 1.2; }
  .why-card p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }

  /* CTA FINAL */
  .cta-final { background: linear-gradient(135deg, rgba(212,175,55,0.07), rgba(212,175,55,0.03)); border-top: 1px solid var(--gold-border); border-bottom: 1px solid var(--gold-border); padding: 3.5rem 0; text-align: center; }
  .cta-final h2 { font-family: var(--font-display); font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 700; margin-bottom: 0.6rem; }
  .cta-final p { font-size: 0.92rem; color: var(--text-muted); max-width: 50ch; margin: 0 auto 1.75rem; line-height: 1.7; }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .trust-final { display: flex; align-items: center; justify-content: center; gap: 1.5rem; flex-wrap: wrap; }
  .trust-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: var(--text-faint); }
  .trust-item svg { color: var(--gold); }

  /* FOOTER */
  .footer-mini { background: rgba(0,0,0,0.4); border-top: 1px solid rgba(255,255,255,0.05); padding: 1.5rem 0; text-align: center; }
  .footer-mini p { font-size: 0.72rem; color: var(--text-faint); }
  .footer-mini a { color: var(--text-faint); text-decoration: underline; }
  .footer-social { display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 0.75rem; }
  .footer-social a { width: 36px; height: 36px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: var(--text-faint); transition: all 0.2s ease; }
  .footer-social a:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }

  /* WA FLOAT */
  .wa-float { position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999; display: flex; align-items: center; gap: 0.6rem; background: #25d366; color: white; padding: 0.8rem 1.25rem; border-radius: 50px; font-family: var(--font-body); font-size: 0.85rem; font-weight: 700; box-shadow: 0 4px 20px rgba(37,211,102,0.45); transition: all 0.25s ease; text-decoration: none; }
  .wa-float:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 28px rgba(37,211,102,0.55); }

  /* RESPONSIVE */
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; }
    .mini-form-card { position: static; }
    .proof-bar-mobile { display: block; background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.06); border-radius: var(--radius); padding: 1rem 1.25rem; margin-top: 0.25rem; }
    .proof-bar-mobile .proof-items { gap: 1rem; justify-content: space-between; }
    .proof-bar-mobile .proof-divider { display: none; }
    .proof-bar-mobile .proof-num { font-size: 1.3rem; }
    .proof-bar-mobile .proof-label { font-size: 0.65rem; max-width: 7ch; }
    .proof-bar-desktop { display: none; }
    .precios-tabla { grid-template-columns: 1fr; max-width: 420px; }
    .why-grid { grid-template-columns: 1fr 1fr; }
    .incluye-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .topbar-tel { display: none; }
    .topbar-social { display: none; }
    .topbar-inner { gap: 0.5rem; }
    .btn-wa-top { font-size: 0.72rem; padding: 0.5rem 0.9rem; gap: 0.35rem; white-space: nowrap; flex-shrink: 0; }
    .btn-wa-top svg { width: 13px; height: 13px; }
    .why-grid { grid-template-columns: 1fr; }
    .hero-ctas { flex-direction: column; }
    .hero-ctas a { width: 100%; justify-content: center; }
    .cta-buttons { flex-direction: column; align-items: center; }
    .wa-float { padding: 0.9rem; border-radius: 50%; }
    .wa-float span { display: none; }
    .hero { padding: 1.4rem 0 1.5rem; }
    h1.hero-title { font-size: 1.9rem; margin-bottom: 0.6rem; }
    .precio-hero-num { font-size: 1.5rem; }
    .hero-sub { font-size: 0.82rem; margin-bottom: 0.9rem; }
    .trust-chips { margin-bottom: 0.9rem; gap: 0.35rem; }
    .chip { font-size: 0.63rem; padding: 0.25rem 0.55rem; }
    .hero-ctas { gap: 0.55rem; margin-bottom: 0.65rem; }
    .btn-primary { padding: 0.8rem 1.1rem; font-size: 0.76rem; }
  }
  </style>
</head>
