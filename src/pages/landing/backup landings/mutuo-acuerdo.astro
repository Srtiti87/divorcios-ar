    .cta-buttons { flex-direction: column; align-items: center; }
    .wa-float { padding: 0.9rem; border-radius: 50%; }
    .wa-float span { display: none; }
    .proceso-grid { grid-template-columns: 1fr; }
    .paso-last { grid-column: auto; }
    .why-grid { grid-template-columns: 1fr; }
    .hero { padding: 1.4rem 0 1.5rem; }
    h1.hero-title { font-size: 2rem; margin-bottom: 0.6rem; }
    .diferencial-badge { flex-direction: column; gap: 0.4rem; }
    .hero-sub { font-size: 0.82rem; margin-bottom: 0.9rem; }
    .trust-chips { margin-bottom: 0.9rem; gap: 0.35rem; }
    .chip { font-size: 0.63rem; padding: 0.25rem 0.55rem; }
    .hero-ctas { gap: 0.55rem; margin-bottom: 0.65rem; }
    .btn-primary { padding: 0.8rem 1.1rem; font-size: 0.76rem; }
    .pc-monto { font-size: 2.2rem; }
  }
