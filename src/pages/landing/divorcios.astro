  <style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0f1e30;
    --bg-card: #16293d;
    --bg-card2: #1a2f45;
    --gold: #d4af37;
    --gold-light: #f0e68c;
    --gold-dim: rgba(212,175,55,0.12);
    --gold-border: rgba(212,175,55,0.22);
    --text: #f0f4f8;
    --text-muted: #d6dbe0;
    --text-faint: #5a7a96;
    --green: #3dba6f;
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'DM Sans', sans-serif;
    --radius: 16px;
    --radius-sm: 8px;
    --red: #e05252;
  }

  html { font-size: 18px; scroll-behavior: smooth; overflow-x: hidden; }
  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  em { font-style: italic; }
  strong { font-weight: 700; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .gold { color: var(--gold); }

  .label {
    display: inline-block; font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--gold); border: 1px solid var(--gold-border);
    background: var(--gold-dim); padding: 0.3rem 0.9rem; border-radius: 50px;
    margin-bottom: 0.85rem;
  }

  /* ===== TOPBAR ===== */
  .topbar {
    background: rgba(10,18,28,0.96);
    border-bottom: 1px solid var(--gold-border);
    padding: 0.6rem 0;
    position: sticky; top: 0; z-index: 100;
    backdrop-filter: blur(12px);
  }
  .topbar-inner {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
  }
  .topbar-brand {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 700;
    color: var(--text); letter-spacing: 0.01em;
  }
  .topbar-brand span { color: var(--gold); }
  .topbar-right { display: flex; align-items: center; gap: 1rem; }
  .topbar-tel {
    font-size: 0.78rem; color: var(--text-muted);
    display: flex; align-items: center; gap: 0.4rem;
  }
  .topbar-tel svg { color: var(--gold); flex-shrink: 0; }
  .topbar-social { display: flex; gap: 0.5rem; }
  .topbar-social a {
    width: 30px; height: 30px; border-radius: 6px;
    border: 1px solid var(--gold-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); transition: all 0.2s ease;
  }
  .topbar-social a:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }
  .btn-wa-top {
    display: flex; align-items: center; gap: 0.5rem;
    background: var(--green); color: white;
    font-family: var(--font-body); font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.5rem 1rem; border-radius: 6px;
    transition: all 0.2s ease; white-space: nowrap;
  }
  .btn-wa-top:hover { background: #32a860; transform: translateY(-1px); }

  /* ===== HERO ===== */
  .hero {
    position: relative; overflow: hidden;
    padding: 4rem 0 3rem;
    background: linear-gradient(160deg, #0a1525 0%, #16293d 50%, #0d1e30 100%);
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 50%, rgba(212,175,55,0.07), transparent 60%),
      radial-gradient(ellipse 40% 60% at 80% 20%, rgba(37,63,95,0.4), transparent 60%);
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 3rem; align-items: start;
    position: relative; z-index: 1;
  }
  .hero-eyebrow {
    display: flex; align-items: center; gap: 0.6rem;
    margin-bottom: 1.1rem;
  }
  .live-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 0 0 rgba(61,186,111,0.4);
    animation: live-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes live-pulse {
    0% { box-shadow: 0 0 0 0 rgba(61,186,111,0.4); }
    70% { box-shadow: 0 0 0 8px rgba(61,186,111,0); }
    100% { box-shadow: 0 0 0 0 rgba(61,186,111,0); }
  }
  .live-text { font-size: 0.7rem; color: var(--green); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; }

