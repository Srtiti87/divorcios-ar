    flex-shrink: 0;
  }
  .autor-info strong { display: block; font-size: 0.82rem; }
  .autor-info span { font-size: 0.72rem; color: var(--text-faint); }
  .google-badge { display: flex; align-items: center; gap: 0.4rem; font-size: 0.68rem; color: var(--text-faint); margin-top: 0.2rem; }

  /* ===== FAQ ===== */
  .faq-list { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.65rem; }
  .faq-item {
    background: var(--bg-card); border: 1px solid rgba(255,255,255,0.07);
    border-radius: var(--radius-sm); overflow: hidden;
