    border: 1px solid rgba(255,255,255,0.08);
    padding: 0.35rem 0.8rem; border-radius: 50px;
  }
  .chip svg { color: var(--gold); flex-shrink: 0; }

  .hero-ctas { display: flex; gap: 0.9rem; flex-wrap: wrap; margin-bottom: 1rem; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: linear-gradient(135deg, #c9a227, #e8cc6a 50%, #c9a227);
    background-size: 200% 100%;
    color: #0a0a0a; font-family: var(--font-body);
    font-size: 0.85rem; font-weight: 800;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 1rem 1.75rem; border-radius: 10px;
    border: none; cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(212,175,55,0.3);
  }
  .btn-primary:hover { background-position: right center; box-shadow: 0 8px 32px rgba(212,175,55,0.45); transform: translateY(-2px); }

  .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.6rem;
    background: transparent; color: var(--gold);
    font-family: var(--font-body); font-size: 0.85rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 1rem 1.5rem; border-radius: 10px;
    border: 1px solid var(--gold-border);
    cursor: pointer; transition: all 0.25s ease;
  }
  .btn-secondary:hover { background: var(--gold-dim); border-color: rgba(212,175,55,0.5); }

  .btn-urgente {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
    background: var(--red); color: #fff;
    font-family: var(--font-body); font-size: 0.85rem; font-weight: 800;
    letter-spacing: 0.06em; text-transform: uppercase;
    padding: 1rem 1.5rem; border-radius: 10px; border: none;
    cursor: pointer; transition: all 0.25s ease; text-decoration: none;
    box-shadow: 0 4px 20px rgba(224,82,82,0.35);
  }
  .btn-urgente:hover { background: #c93c3c; box-shadow: 0 8px 30px rgba(224,82,82,0.5); transform: translateY(-2px); }

  .hero-disclaimer { font-size: 0.72rem; color: var(--text-faint); }
  .hero-disclaimer strong { color: var(--text-muted); }

  /* ===== MINI FORM — simplificado a 2 campos ===== */
  .mini-form-card {
    background: linear-gradient(160deg, var(--bg-card), var(--bg-card2));
    border: 1px solid var(--gold-border);
    border-radius: 20px; padding: 1.75rem;
    box-shadow: 0 8px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(212,175,55,0.1);
    position: sticky; top: 80px;
  }
  .form-header { margin-bottom: 1.25rem; }
  .form-header h3 {
    font-family: var(--font-display);
    font-size: 1.4rem; font-weight: 700;
    margin-bottom: 0.3rem;
  }
  .form-header p { font-size: 0.8rem; color: var(--text-muted); }
  .form-header .response-time {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.7rem; color: var(--green); font-weight: 600;
    margin-top: 0.4rem;
  }
  .mini-form { display: flex; flex-direction: column; gap: 0.85rem; }
  .fg { display: flex; flex-direction: column; gap: 0.3rem; }
  .fg label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .fg input, .fg select {
    background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; color: var(--text);
    font-family: var(--font-body); font-size: 0.9rem;
    padding: 0.75rem 1rem; transition: all 0.2s ease;
    outline: none; width: 100%;
  }
  .fg input::placeholder { color: var(--text-faint); }
  .fg select option { background: #1a2f45; }
  .fg input:focus, .fg select:focus {
    border-color: rgba(212,175,55,0.5);
    box-shadow: 0 0 0 3px rgba(212,175,55,0.1);
    background: rgba(0,0,0,0.35);
  }
  .btn-form {
    width: 100%; padding: 1rem;
    background: linear-gradient(135deg, #c9a227, #e8cc6a 50%, #c9a227);
    background-size: 200% 100%;
    color: #0a0a0a; font-family: var(--font-body);
    font-size: 0.82rem; font-weight: 800;
    letter-spacing: 0.08em; text-transform: uppercase;
    border: none; border-radius: 10px; cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(212,175,55,0.3);
    margin-top: 0.25rem;
  }
  .btn-form:hover { background-position: right center; transform: translateY(-1px); box-shadow: 0 8px 28px rgba(212,175,55,0.45); }
  .form-disclaimer { font-size: 0.68rem; color: var(--text-faint); text-align: center; margin-top: 0.5rem; }
  .form-success { text-align: center; padding: 1.5rem 0; display: none; }
  .form-success.show { display: block; }
  .success-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: rgba(61,186,111,0.1); border: 2px solid var(--green);
    color: var(--green); font-size: 1.5rem;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 1rem;
  }
  .form-success h4 { color: var(--gold); font-family: var(--font-display); font-size: 1.2rem; margin-bottom: 0.5rem; }
  .form-success p { font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; }

  /* ===== SOCIAL PROOF dentro del hero ===== */
  .proof-bar-mobile {
    display: none; /* oculto en desktop — desktop usa proof-bar externo */
  }
  /* proof-bar desktop: se muestra como sección separada fuera del hero */
  .proof-bar {
    background: rgba(0,0,0,0.3);
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding: 1.25rem 0;
  }
  .proof-items {
    display: flex; align-items: center; justify-content: center;
    gap: 2.5rem; flex-wrap: wrap;
  }
  .proof-item { display: flex; align-items: center; gap: 0.6rem; }
  .proof-num {
    font-family: var(--font-display);
    font-size: 1.6rem; font-weight: 700; color: var(--gold); line-height: 1;
  }
  .proof-label { font-size: 0.72rem; color: var(--text-muted); line-height: 1.3; max-width: 8ch; }
  .proof-divider { width: 1px; height: 36px; background: rgba(255,255,255,0.1); }

  /* ===== SECTION BASE ===== */
  section { padding: 3.5rem 0; }
  section.alt { background: rgba(0,0,0,0.2); }
  .section-head { text-align: center; margin-bottom: 2.25rem; }
  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 700; line-height: 1.1; margin-bottom: 0.6rem;
  }
  .section-head p { font-size: 0.9rem; color: var(--text-muted); max-width: 54ch; margin: 0 auto; line-height: 1.65; }

  /* ===== WHY — 4 cards en lugar de 6 ===== */
  .why-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; max-width: 860px; margin: 0 auto; }
  .why-card {
    background: linear-gradient(160deg, var(--bg-card), var(--bg-card2));
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: var(--radius); padding: 1.4rem 1.5rem;
    transition: all 0.3s ease;
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .why-card:hover { border-color: var(--gold-border); transform: translateY(-3px); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }
  .why-card-header { display: flex; align-items: center; gap: 0.75rem; }
  .why-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--gold-dim); border: 1px solid var(--gold-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--gold); flex-shrink: 0;
  }
  .why-card h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; line-height: 1.2; }
  .why-card p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }

  /* ===== TIPOS CARDS ===== */
  .tipos-grid {
    display: grid; grid-template-columns: 1fr 1.06fr 1fr;
    gap: 1.25rem; align-items: stretch;
  }
  .tipo-card {
    border-radius: 20px; position: relative; overflow: hidden;
    background: linear-gradient(160deg, rgba(37,63,95,0.95), rgba(26,45,69,0.98));
    border: 1px solid rgba(212,175,55,0.2);
    box-shadow: 0 4px 24px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.06);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1), box-shadow 0.35s cubic-bezier(0.4,0,0.2,1);
  }
  .tipo-card:hover { transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(212,175,55,0.3); }
  .tipo-glow { position: absolute; inset: 0; border-radius: 20px; background: radial-gradient(ellipse 80% 40% at 50% 0%, rgba(212,175,55,0.08), transparent 60%); opacity: 0; transition: opacity 0.4s; pointer-events: none; }
  .tipo-card:hover .tipo-glow { opacity: 1; }
  .tipo-featured {
    background: linear-gradient(160deg, rgba(45,72,105,0.98), rgba(30,50,78,0.99) 60%, rgba(20,35,58,1));
    border: 1px solid rgba(212,175,55,0.55);
    box-shadow: 0 8px 40px rgba(0,0,0,0.5), 0 0 80px rgba(212,175,55,0.08), inset 0 1px 0 rgba(212,175,55,0.18);
    transform: translateY(-10px);
  }
  .tipo-featured:hover { transform: translateY(-16px); }
  .tf-glow { position: absolute; top: -60px; left: 50%; transform: translateX(-50%); width: 280px; height: 160px; background: radial-gradient(ellipse, rgba(212,175,55,0.32), transparent 70%); filter: blur(20px); pointer-events: none; z-index: 0; }
  .tf-shine { position: absolute; top: 0; left: -100%; width: 60%; height: 100%; background: linear-gradient(105deg, transparent 20%, rgba(212,175,55,0.05) 40%, rgba(212,175,55,0.1) 50%, rgba(212,175,55,0.05) 60%, transparent 80%); animation: shine 4.5s ease-in-out infinite; pointer-events: none; z-index: 0; }
  @keyframes shine { 0% { left:-100%; } 28% { left:120%; } 100% { left:120%; } }
  .tipo-inner { position: relative; z-index: 1; padding: 1.6rem; display: flex; flex-direction: column; gap: 0.9rem; height: 100%; }
  .tipo-badge { display: inline-flex; align-items: center; gap: 0.4rem; align-self: flex-start; background: var(--gold); color: #0a0a0a; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.28rem 0.8rem; border-radius: 50px; box-shadow: 0 4px 16px rgba(212,175,55,0.4); }
  .tipo-eyebrow { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); }
  .tipo-eyebrow-gold { color: var(--gold); }
  .tipo-title { font-family: var(--font-display); font-size: clamp(1.4rem, 2vw, 1.8rem); font-weight: 700; line-height: 1.05; color: var(--text); }
  .tipo-title-gold { background: linear-gradient(135deg, #f0e68c, #d4af37 45%, #f5d060); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .tipo-sub { font-size: 0.8rem; color: var(--text-muted); line-height: 1.55; }
  .tipo-price { background: rgba(0,0,0,0.22); border: 1px solid rgba(212,175,55,0.15); border-radius: 12px; padding: 1rem 1.2rem; display: flex; flex-direction: column; gap: 0.12rem; }
  .tipo-price-featured { background: rgba(212,175,55,0.08); border-color: rgba(212,175,55,0.28); }
  .tp-desde { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-faint); }
  .tp-desde-gold { color: var(--gold); font-weight: 700; font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; }
