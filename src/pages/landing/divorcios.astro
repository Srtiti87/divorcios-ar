  .bienes-left p { font-size: 0.8rem; color: var(--text-muted); margin: 0; }
  .btn-ghost { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gold); border: 1px solid var(--gold-border); padding: 0.7rem 1.25rem; border-radius: 8px; transition: all 0.2s ease; white-space: nowrap; }
  .btn-ghost:hover { background: var(--gold-dim); border-color: rgba(212,175,55,0.5); }

  /* ===== PROCESO — compacto horizontal ===== */
  .proceso-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem; max-width: 900px; margin: 0 auto;
    counter-reset: paso-counter;
  }
  .paso-h {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.4rem; border-radius: var(--radius);
    background: linear-gradient(160deg, var(--bg-card), var(--bg-card2));
    border: 1px solid rgba(255,255,255,0.07);
    position: relative;
  }
  .paso-h::before {
    counter-increment: paso-counter;
    content: counter(paso-counter);
    font-family: var(--font-display); font-size: 0.8rem; font-weight: 700;
    color: var(--gold); background: var(--gold-dim);
    border: 1px solid var(--gold-border);
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .paso-h::before { display: block; text-align: center; line-height: 26px; }
  .paso-h h3 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; line-height: 1.2; }
  .paso-h p { font-size: 0.8rem; color: var(--text-muted); line-height: 1.55; }
  .paso-connector {
    display: none; /* sólo en desktop se muestra con pseudo-elementos */
  }

  @media (max-width: 960px) {
    .proof-bar-desktop { display: none; }
  }

  /* paso 5 centrado en desktop */
  .paso-last { grid-column: 2; }
  @media (max-width: 960px) {
    .paso-last { grid-column: auto; }
  }

  @media (max-width: 960px) {
    .paso-last { grid-column: auto; }
  }

  .testimonios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .testimonio-card {
    background: linear-gradient(160deg, var(--bg-card), var(--bg-card2));
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: var(--radius); padding: 1.4rem;
    display: flex; flex-direction: column; gap: 0.85rem;
    transition: border-color 0.3s ease;
  }
  .testimonio-card:hover { border-color: var(--gold-border); }
  .estrellas { color: var(--gold); font-size: 0.85rem; letter-spacing: 0.1em; }
  .testimonio-text { font-size: 0.86rem; color: var(--text-muted); line-height: 1.7; font-style: italic; flex: 1; }
  .testimonio-text::before { content: '"'; font-family: var(--font-display); font-size: 2rem; color: var(--gold); line-height: 0; vertical-align: -0.5rem; margin-right: 0.2rem; }
  .testimonio-autor { display: flex; align-items: center; gap: 0.75rem; }
  .autor-avatar {
    width: 36px; height: 36px; border-radius: 50%;
