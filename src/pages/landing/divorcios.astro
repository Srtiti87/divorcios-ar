  .tipo-cta-outline { background: transparent; color: var(--gold); border: 1px solid rgba(212,175,55,0.3); }
  .tipo-cta-outline:hover { background: var(--gold-dim); border-color: rgba(212,175,55,0.55); }
  .tipo-cta-primary { background: linear-gradient(135deg, #c9a227, #e8cc6a 50%, #c9a227); background-size: 200% 100%; color: #0a0a0a; border: none; font-weight: 800; box-shadow: 0 4px 20px rgba(212,175,55,0.35); }
  .tipo-cta-primary:hover { background-position: right; box-shadow: 0 8px 32px rgba(212,175,55,0.5); }

  .bienes-banner {
