  .footer-social a:hover { border-color: var(--gold); color: var(--gold); background: var(--gold-dim); }

  /* ===== WA FLOAT ===== */
  .wa-float {
    position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 999;
    display: flex; align-items: center; gap: 0.6rem;
