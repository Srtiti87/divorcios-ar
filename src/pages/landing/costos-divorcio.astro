            }
          }
        ]
      }
    ]
  }
  </script>

  <style>
    /* ============================================
       CSS VARIABLES — OPCIÓN A "Autoridad Serena"
       Para cambiar a Opción B: reemplazar los valores
       de --primary, --accent y --cta en :root
    ============================================ */
    :root {
      /* Opción A — Autoridad Serena (activa) */
      --primary:     #1B2A4A;
      --primary-mid: #243a65;
      --primary-light:#2f4d87;
      --accent:      #C9A84C;
      --accent-light: #e0c070;
      --cta:         #1a7a3a;
      --cta-hover:   #145e2c;
      --bg:          #FFFFFF;
      --bg-soft:     #F7F8FA;
      --bg-dark:     #111927;
      --text:        #1a1a2e;
      --text-mid:    #3d4a5c;
      --text-light:  #6b7a8d;
      --border:      #e2e8f0;
      --whatsapp:    #25D366;
      --whatsapp-hover: #1da851;

      /* Opción B — descomentar para activar
      --primary:     #2D5016;
      --accent:      #E8DCC8;
      --cta:         #D4580A;
      --bg-soft:     #faf8f4;
      */

      /* Tipografía */
      --font-display: 'DM Serif Display', Georgia, serif;
      --font-body:    'DM Sans', system-ui, sans-serif;

      /* Espaciado */
      --section-gap: clamp(64px, 8vw, 112px);
      --container:   1140px;
      --radius:      12px;
      --radius-lg:   20px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
    }

    body {
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      color: var(--text);
      background: var(--bg);
      overflow-x: hidden;
    }

    img { max-width: 100%; height: auto; display: block; }
    a { color: inherit; text-decoration: none; }

    .container {
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 clamp(20px, 5vw, 48px);
    }

    /* ── HEADER ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--primary);
      height: 60px;
      display: flex;
      align-items: center;
      box-shadow: 0 2px 12px rgba(0,0,0,.18);
    }

    .site-header .container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    .logo {
      font-family: var(--font-display);
      font-size: 1.25rem;
      color: #fff;
      letter-spacing: .04em;
    }
    .logo span { color: var(--accent); }

    .header-right {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .header-tel {
      color: var(--accent-light);
      font-size: .9rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .header-tel svg { width: 15px; height: 15px; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: .9rem;
      padding: 11px 22px;
      border-radius: 8px;
      border: none;
      cursor: pointer;
      transition: background .18s, transform .12s, box-shadow .18s;
      white-space: nowrap;
      text-decoration: none;
    }
    .btn:hover { transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }

    .btn-primary {
      background: var(--cta);
      color: #fff;
      box-shadow: 0 3px 14px rgba(26,122,58,.28);
    }
    .btn-primary:hover { background: var(--cta-hover); box-shadow: 0 5px 18px rgba(26,122,58,.38); }

    .btn-outline {
      background: transparent;
      color: var(--primary);
      border: 2px solid var(--primary);
    }
    .btn-outline:hover { background: var(--primary); color: #fff; }

    .btn-ghost {
      background: rgba(255,255,255,.12);
      color: #fff;
      border: 1px solid rgba(255,255,255,.3);
      padding: 9px 18px;
    }
    .btn-ghost:hover { background: rgba(255,255,255,.22); }

    .btn-wa {
      background: var(--whatsapp);
      color: #fff;
      box-shadow: 0 3px 14px rgba(37,211,102,.3);
    }
    .btn-wa:hover { background: var(--whatsapp-hover); }

    /* ── AVAILABILITY BADGE ── */
    .badge-live {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      font-size: .82rem;
      font-weight: 500;
      color: #2ecc71;
      background: rgba(46,204,113,.12);
      border: 1px solid rgba(46,204,113,.3);
      border-radius: 100px;
      padding: 5px 13px;
      margin-bottom: 18px;
    }
    .badge-live::before {
      content: '';
      width: 8px; height: 8px;
      background: #2ecc71;
      border-radius: 50%;
      animation: pulse 1.8s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: .5; transform: scale(1.3); }
    }

    /* ── HERO ── */
    .hero {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-mid) 60%, var(--primary-light) 100%);
      position: relative;
      overflow: hidden;
      padding: clamp(52px, 7vw, 96px) 0 clamp(48px, 6vw, 80px);
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 100% 50%, rgba(201,168,76,.07) 0%, transparent 70%),
        radial-gradient(ellipse 40% 40% at 0% 100%, rgba(201,168,76,.05) 0%, transparent 60%);
      pointer-events: none;
    }

    /* Decorative lines */
    .hero::after {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 380px; height: 380px;
      border: 1px solid rgba(201,168,76,.12);
      border-radius: 50%;
      pointer-events: none;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(32px, 5vw, 72px);
      align-items: start;
      position: relative;
      z-index: 1;
    }

    .hero-copy { color: #fff; }

    .hero-eyebrow {
      font-size: .8rem;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }

    .hero-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 3.5vw, 3rem);
      line-height: 1.15;
      margin-bottom: 20px;
      color: #fff;
    }

    .hero-title em {
      font-style: italic;
      color: var(--accent-light);
    }

    .hero-subtitle {
      font-size: 1.05rem;
      color: rgba(255,255,255,.8);
      margin-bottom: 28px;
      line-height: 1.65;
    }

    .hero-trust {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 20px;
      margin-bottom: 28px;
    }
    .hero-trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: .85rem;
      color: rgba(255,255,255,.75);
    }
    .hero-trust-item svg { color: var(--accent); flex-shrink: 0; }

    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 18px;
    }

    .hero-disclaimer {
      font-size: .78rem;
      color: rgba(255,255,255,.5);
    }
    .hero-disclaimer svg { display: inline; width: 12px; height: 12px; margin-right: 4px; }

    /* ── QUIZ CARD ── */
    .quiz-card {
      background: #fff;
      border-radius: var(--radius-lg);
      padding: clamp(24px, 3vw, 36px);
      box-shadow: 0 20px 60px rgba(0,0,0,.25), 0 4px 16px rgba(0,0,0,.12);
      position: relative;
    }

    .quiz-card-header {
      margin-bottom: 22px;
    }
    .quiz-card-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      color: var(--primary);
      margin-bottom: 5px;
    }
    .quiz-card-sub {
      font-size: .85rem;
      color: var(--text-light);
    }

    .quiz-step { display: none; }
    .quiz-step.active { display: block; }

    .quiz-label {
      font-size: .88rem;
      font-weight: 600;
      color: var(--text-mid);
      margin-bottom: 12px;
      display: block;
    }

    .quiz-options {
      display: grid;
      gap: 9px;
      margin-bottom: 18px;
    }

    .quiz-option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      border: 2px solid var(--border);
      border-radius: 9px;
      cursor: pointer;
      transition: border-color .15s, background .15s;
      font-size: .9rem;
      color: var(--text);
      background: var(--bg);
    }
    .quiz-option:hover { border-color: var(--primary-light); background: var(--bg-soft); }
    .quiz-option.selected { border-color: var(--primary); background: rgba(27,42,74,.05); }
    .quiz-option-icon { font-size: 1.1rem; flex-shrink: 0; }

    .quiz-progress {
      display: flex;
      gap: 6px;
      margin-bottom: 18px;
    }
    .quiz-dot {
      height: 4px;
      flex: 1;
      background: var(--border);
      border-radius: 4px;
      transition: background .3s;
    }
    .quiz-dot.done { background: var(--primary); }

    .quiz-card-footer {
      border-top: 1px solid var(--border);
      padding-top: 16px;
      margin-top: 6px;
    }

    .quiz-social {
      display: flex;
      flex-wrap: wrap;
      gap: 12px 18px;
      margin-top: 14px;
    }
    .quiz-social-item {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: .8rem;
      color: var(--text-light);
    }
    .quiz-social-item strong { color: var(--text); }

    /* ── TRUST BAR ── */
    .trust-bar {
      background: var(--bg-soft);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 20px 0;
    }
    .trust-bar-inner {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px 36px;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: .88rem;
      font-weight: 500;
      color: var(--text-mid);
    }
    .trust-item-icon {
      width: 34px; height: 34px;
      background: var(--primary);
      color: #fff;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .trust-item-icon svg { width: 17px; height: 17px; }

    /* ── SECCIÓN GENÉRICA ── */
    .section { padding: var(--section-gap) 0; }
    .section-dark { background: var(--bg-dark); color: #fff; }
    .section-soft { background: var(--bg-soft); }
    .section-accent { background: var(--primary); color: #fff; }

    .section-label {
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      line-height: 1.2;
      color: var(--primary);
      margin-bottom: 14px;
    }
    .section-dark .section-title,
    .section-accent .section-title { color: #fff; }
    .section-title em { font-style: italic; color: var(--accent); }
    .section-dark .section-title em { color: var(--accent-light); }

    .section-subtitle {
      font-size: 1.05rem;
      color: var(--text-mid);
      max-width: 560px;
      line-height: 1.65;
    }
    .section-dark .section-subtitle { color: rgba(255,255,255,.7); }

    .section-header { margin-bottom: clamp(36px, 5vw, 56px); }

    /* ── PRECIOS ── */
    .prices-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      align-items: start;
    }

    .price-card {
      background: #fff;
      border: 2px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 32px 28px;
      position: relative;
      transition: box-shadow .2s, transform .2s;
    }
    .price-card:hover {
      box-shadow: 0 12px 40px rgba(27,42,74,.1);
      transform: translateY(-3px);
    }
    .price-card.featured {
      border-color: var(--primary);
      box-shadow: 0 8px 32px rgba(27,42,74,.14);
    }

    .price-badge {
      position: absolute;
      top: -14px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: var(--primary);
      font-size: .75rem;
      font-weight: 700;
      padding: 5px 14px;
      border-radius: 100px;
      white-space: nowrap;
    }

    .price-label {
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--text-light);
      margin-bottom: 8px;
    }

    .price-name {
      font-family: var(--font-display);
      font-size: 1.4rem;
      color: var(--primary);
      margin-bottom: 6px;
    }

    .price-desc {
      font-size: .88rem;
      color: var(--text-light);
      margin-bottom: 20px;
      min-height: 38px;
    }

    .price-amount {
      margin-bottom: 22px;
    }
    .price-desde { font-size: .82rem; color: var(--text-light); }
    .price-number {
      font-family: var(--font-display);
      font-size: 2.4rem;
      color: var(--primary);
      line-height: 1;
    }
    .price-period { font-size: .85rem; color: var(--text-light); }
    .price-cuotas {
      font-size: .8rem;
      color: var(--cta);
      font-weight: 600;
      margin-top: 3px;
    }

    .price-features {
      list-style: none;
      margin-bottom: 24px;
      display: flex;
      flex-direction: column;
      gap: 9px;
    }
    .price-features li {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      font-size: .875rem;
      color: var(--text-mid);
    }
    .price-features li svg {
      flex-shrink: 0;
      margin-top: 2px;
      color: var(--cta);
    }

    .price-card.special {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-mid) 100%);
      border-color: transparent;
      color: #fff;
    }
    .price-card.special .price-name,
    .price-card.special .price-number,
    .price-card.special .price-label { color: #fff; }
    .price-card.special .price-desc,
    .price-card.special .price-period { color: rgba(255,255,255,.65); }
    .price-card.special .price-cuotas { color: var(--accent-light); }
    .price-card.special .price-features li { color: rgba(255,255,255,.8); }
    .price-card.special .price-features li svg { color: var(--accent); }

    /* ── QUÉ INCLUYE ── */
    .includes-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .include-item {
      display: flex;
      gap: 18px;
      align-items: flex-start;
    }

    .include-icon {
      width: 48px; height: 48px;
      background: rgba(27,42,74,.07);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--primary);
    }
    .include-icon svg { width: 22px; height: 22px; }

    .include-body h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--primary);
      margin-bottom: 5px;
    }
    .include-body p { font-size: .9rem; color: var(--text-mid); line-height: 1.55; }

    /* ── DESCARGA GRATUITA ── */
    .download-section {
      background: linear-gradient(135deg, #0f1e36 0%, var(--primary) 100%);
      position: relative;
      overflow: hidden;
    }
    .download-section::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 320px; height: 320px;
      border: 1px solid rgba(201,168,76,.15);
      border-radius: 50%;
      pointer-events: none;
    }

    .download-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: center;
      position: relative;
      z-index: 1;
    }

    .download-pretitle {
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .download-title {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      color: #fff;
      margin-bottom: 12px;
      line-height: 1.25;
    }

    .download-desc {
      font-size: .95rem;
      color: rgba(255,255,255,.7);
      margin-bottom: 26px;
      max-width: 520px;
      line-height: 1.65;
    }

    .download-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 20px;
      margin-top: 18px;
    }
    .download-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: .8rem;
      color: rgba(255,255,255,.55);
    }
    .download-meta-item svg { color: var(--accent); }

    .download-visual {
      width: 160px;
      flex-shrink: 0;
    }

    .pdf-mockup {
      width: 130px;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 20px 50px rgba(0,0,0,.4), 8px 8px 0 var(--accent);
      padding: 16px 14px;
      margin: 0 auto;
    }
    .pdf-mockup-header {
      background: var(--primary);
      height: 6px;
      border-radius: 4px;
      margin-bottom: 10px;
    }
    .pdf-mockup-line {
      height: 6px;
      background: var(--border);
      border-radius: 4px;
      margin-bottom: 7px;
    }
    .pdf-mockup-line.short { width: 70%; }
    .pdf-mockup-line.shorter { width: 50%; }
    .pdf-mockup-logo {
      font-family: var(--font-display);
      font-size: .6rem;
      color: var(--primary);
      font-weight: 700;
      margin-top: 12px;
      letter-spacing: .06em;
    }

    /* ── ABOGADOS ── */
    .lawyers-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
      max-width: 800px;
      margin: 0 auto;
    }

    .lawyer-card {
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 32px 28px;
      text-align: center;
      transition: box-shadow .2s, transform .2s;
    }
    .lawyer-card:hover {
      box-shadow: 0 12px 40px rgba(27,42,74,.1);
      transform: translateY(-3px);
    }

    .lawyer-photo {
      width: 90px; height: 90px;
      border-radius: 50%;
      margin: 0 auto 16px;
      background: var(--bg-soft);
      border: 3px solid var(--accent);
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-light);
      font-size: 2rem;
    }
    .lawyer-photo img {
      width: 100%; height: 100%;
      object-fit: cover;
    }

    .lawyer-name {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--primary);
      margin-bottom: 4px;
    }

    .lawyer-title {
      font-size: .83rem;
      color: var(--text-light);
      margin-bottom: 10px;
    }

    .lawyer-matricula {
      display: inline-block;
      background: rgba(27,42,74,.07);
      color: var(--primary);
      font-size: .75rem;
      font-weight: 600;
      padding: 4px 12px;
      border-radius: 100px;
      margin-bottom: 14px;
    }

    .lawyer-quote {
      font-size: .88rem;
      color: var(--text-mid);
      font-style: italic;
      line-height: 1.55;
      border-top: 1px solid var(--border);
      padding-top: 14px;
      margin-bottom: 18px;
    }

    /* ── PROCESO ── */
    .process-steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      position: relative;
    }

    .process-steps::before {
      content: '';
      position: absolute;
      top: 28px;
      left: calc(100% / 6);
      right: calc(100% / 6);
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--primary-light), var(--accent));
    }

    .process-step {
      text-align: center;
      padding: 0 20px;
    }

    .process-number {
      width: 56px; height: 56px;
      background: var(--primary);
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      font-family: var(--font-display);
      font-size: 1.4rem;
      position: relative;
      z-index: 1;
      box-shadow: 0 4px 16px rgba(27,42,74,.25);
    }

    .process-step-title {
      font-family: var(--font-display);
      font-size: 1.1rem;
      color: var(--primary);
      margin-bottom: 8px;
    }

    .process-step-desc {
      font-size: .88rem;
      color: var(--text-mid);
      line-height: 1.55;
    }

    /* ── FAQ ── */
    .faq-list {
      max-width: 760px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .faq-item {
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color .2s;
    }
    .faq-item.open { border-color: var(--primary); }

    .faq-question {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 18px 22px;
      cursor: pointer;
      font-weight: 600;
      font-size: .95rem;
      color: var(--primary);
      gap: 12px;
      user-select: none;
      background: #fff;
    }
    .faq-item.open .faq-question { background: rgba(27,42,74,.03); }

    .faq-chevron {
      flex-shrink: 0;
      color: var(--text-light);
      transition: transform .25s;
    }
    .faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--primary); }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height .3s ease;
    }
    .faq-answer-inner {
      padding: 0 22px 18px;
      font-size: .92rem;
      color: var(--text-mid);
      line-height: 1.65;
    }

    /* ── CTA FINAL ── */
    .cta-final {
      background: linear-gradient(135deg, var(--primary) 0%, #0f1e36 100%);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-final::before {
      content: '';
      position: absolute;
      bottom: -100px; left: 50%;
      transform: translateX(-50%);
      width: 500px; height: 500px;
      border: 1px solid rgba(201,168,76,.1);
      border-radius: 50%;
      pointer-events: none;
    }

    .cta-final-title {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.6rem);
      color: #fff;
      margin-bottom: 12px;
    }
    .cta-final-sub {
      font-size: 1.05rem;
      color: rgba(255,255,255,.7);
      margin-bottom: 34px;
    }
    .cta-final-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-bottom: 26px;
    }
    .cta-final-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px 24px;
    }
    .cta-badge {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: .82rem;
      color: rgba(255,255,255,.55);
    }
    .cta-badge svg { color: var(--accent); }

    /* ── FOOTER ── */
    .site-footer {
      background: #0a1220;
      color: rgba(255,255,255,.5);
      text-align: center;
      padding: 28px 20px;
      font-size: .82rem;
      line-height: 1.7;
    }
    .site-footer a { color: rgba(255,255,255,.4); text-decoration: underline; }
    .site-footer a:hover { color: rgba(255,255,255,.65); }

    /* ── WHATSAPP FLOTANTE ── */
    .wa-float {
      display: none;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 999;
      width: 56px; height: 56px;
      background: var(--whatsapp);
      border-radius: 50%;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 24px rgba(37,211,102,.45);
      transition: transform .2s, box-shadow .2s;
    }
    .wa-float:hover { transform: scale(1.08); box-shadow: 0 8px 30px rgba(37,211,102,.55); }
    .wa-float svg { width: 28px; height: 28px; color: #fff; }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
      .quiz-card { order: -1; }
      .prices-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
      .includes-grid { grid-template-columns: 1fr; }
      .lawyers-grid { grid-template-columns: 1fr; max-width: 420px; }
      .process-steps { grid-template-columns: 1fr; gap: 28px; }
      .process-steps::before { display: none; }
      .download-grid { grid-template-columns: 1fr; }
      .download-visual { display: none; }
    }

    @media (max-width: 600px) {
      .wa-float { display: flex; }
      .header-tel { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
    }

    /* ── UTILIDADES ── */
    .text-center { text-align: center; }
    .mb-0 { margin-bottom: 0; }
    .mt-auto { margin-top: auto; }
    .w-full { width: 100%; }

    /* ── SVG ICONS inline ── */
    .icon { display: inline-flex; vertical-align: middle; }
  </style>
</head>
