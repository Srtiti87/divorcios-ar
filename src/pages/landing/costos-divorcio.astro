<script>
  // ── QUIZ LÓGICA ──
  const WA = "https://wa.me/541159360995";
  let answers = { step1: null, step2: null };

  const msgs = {
    si: {
      solo:   "Hola, quisiera saber cuánto cuesta el divorcio. Somos dos y estamos de acuerdo. No tenemos hijos ni bienes.",
      hijos:  "Hola, quisiera saber cuánto cuesta el divorcio. Estamos de acuerdo pero tenemos hijos menores.",
      bienes: "Hola, quisiera saber cuánto cuesta el divorcio. Estamos de acuerdo pero tenemos bienes en común.",
      ambos:  "Hola, quisiera saber cuánto cuesta el divorcio. Estamos de acuerdo y tenemos hijos y bienes.",
    },
    no: {
      solo:   "Hola, necesito hacer un divorcio unilateral. El otro cónyuge no coopera. Sin hijos ni bienes.",
      hijos:  "Hola, necesito hacer un divorcio unilateral. El otro no coopera y tenemos hijos menores.",
      bienes: "Hola, necesito hacer un divorcio unilateral. El otro no coopera y tenemos bienes en común.",
      ambos:  "Hola, necesito hacer un divorcio unilateral. El otro no coopera y tenemos hijos y bienes.",
    },
    nose: {
      solo:   "Hola, quisiera consultar sobre mi divorcio. No sé si el otro estará de acuerdo. No tenemos hijos ni bienes.",
      hijos:  "Hola, quisiera consultar sobre mi divorcio. No sé si el otro estará de acuerdo. Tenemos hijos menores.",
      bienes: "Hola, quisiera consultar sobre mi divorcio. No sé si el otro estará de acuerdo. Tenemos bienes en común.",
      ambos:  "Hola, quisiera consultar sobre mi divorcio. No sé si el otro estará de acuerdo. Tenemos hijos y bienes.",
    },
  };

  document.querySelectorAll('.quiz-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const step = btn.dataset.step;
      const val  = btn.dataset.val;

      // Deselect siblings
      btn.closest('.quiz-options').querySelectorAll('.quiz-option').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      if (step === '1') {
        answers.step1 = val;
        // Go to step 2
        setTimeout(() => {
          document.getElementById('step1').classList.remove('active');
          document.getElementById('step2').classList.add('active');
          document.getElementById('dot2').classList.add('done');
        }, 200);
      } else {
        answers.step2 = val;
        // Build WhatsApp URL
        const msg = (msgs[answers.step1] || msgs['nose'])[val] || "Hola, quisiera consultar el costo de mi divorcio.";
        const url = `${WA}?text=${encodeURIComponent(msg)}`;
        const cta = document.getElementById('quiz-cta');
        cta.href = url;
        cta.style.display = 'flex';
        // Auto-open after short delay
        setTimeout(() => window.open(url, '_blank', 'noopener'), 400);
      }
    });
  });

  // ── FAQ ACORDEÓN ──
  document.querySelectorAll('.faq-question').forEach(q => {
    q.addEventListener('click', () => {
      const item   = q.parentElement;
      const answer = item.querySelector('.faq-answer');
      const isOpen = item.classList.contains('open');

      // Close all
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-answer').style.maxHeight = '0';
      });

      // Open clicked
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });
</script>

</body>
</html>
