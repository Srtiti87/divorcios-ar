---
// Importamos estilos y componentes
import '../styles/global.css'; 
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro'; // <--- Importamos el botón
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    
    <title>Página no encontrada | divorcios.ar</title>
    
    <meta name="robots" content="noindex, follow" />

    <link rel="canonical" href="https://www.divorcios.ar/404" />
</head>
<body class="bg-indigo-950 flex flex-col min-h-screen font-sans">
    
    <Header />

    <main class="flex-grow flex items-center justify-center px-6 py-20 relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-[15rem] md:text-[25rem] font-black text-white/[0.03] select-none">
                404
            </span>
        </div>

        <div class="relative z-10 text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight">
                Parece que te has perdido
            </h1>
            <p class="text-indigo-200/70 mb-10 max-w-md mx-auto text-lg leading-relaxed">
                La página que buscas no existe. No te preocupes, puedes volver al inicio o contactarnos directamente.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a 
                    href="/" 
                    class="bg-indigo-500 hover:bg-indigo-400 text-white font-bold py-4 px-10 rounded-full transition-all shadow-xl hover:shadow-indigo-500/40 w-full sm:w-auto text-center"
                >
                    Volver al Inicio
                </a>
            </div>
        </div>
    </main>

    <Footer />

    <WhatsappFlotante />

</body>
</html>