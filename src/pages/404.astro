---
// Importamos estilos y componentes
import '../styles/global.css'; 
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsappFlotante from '../components/WhatsappFlotante.astro'; // <--- Importamos el botón
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width" />
    
    <title>Página no encontrada | divorcios.ar</title>
    
    <meta name="robots" content="noindex, follow" />

    <link rel="canonical" href="https://www.divorcios.ar/404" />
</head>
<body class="bg-ink flex flex-col min-h-screen overflow-x-hidden">
    
    <Header />

    <main class="flex-grow flex items-center justify-center px-6 py-20 relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center">
            <span class="font-serif text-[15rem] md:text-[25rem] font-light text-cream/[0.03] select-none">
                404
            </span>
        </div>

        <div class="relative z-10 text-center">
            <div class="flex items-center gap-2 mb-6 justify-center">
                <span class="w-8 h-px bg-gold"></span>
                <p class="text-gold font-bold uppercase tracking-[0.25em] text-[11px]">Error 404</p>
                <span class="w-8 h-px bg-gold"></span>
            </div>
            <h1 class="font-serif text-4xl md:text-5xl font-light text-cream mb-6 tracking-tight">
                Parece que te has <em class="italic text-gold">perdido</em>
            </h1>
            <p class="text-cream/60 mb-10 max-w-md mx-auto text-lg leading-relaxed font-light">
                La página que buscas no existe. No te preocupes, puedes volver al inicio o contactarnos directamente.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
                <a 
                    href="/" 
                    class="bg-gold hover:bg-gold-light text-ink font-bold py-4 px-10 rounded-sm transition-all shadow-xl hover:-translate-y-0.5 w-full sm:w-auto text-center uppercase text-sm tracking-wide"
                >
                    Volver al Inicio
                </a>
            </div>
        </div>
    </main>

    <Footer />

    <WhatsappFlotante />

</body>
</html>