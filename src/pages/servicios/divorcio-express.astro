---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import WhatsappFlotante from "../../components/WhatsappFlotante.astro";
import PreciosDivorcio from "../../components/PreciosDivorcio.astro";
import "../../styles/global.css";
---

<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Divorcio Express en CABA | Abogado Dr. Santibáñez Héctor David</title>
    <meta name="description" content="Abogado de Divorcio Express en Capital Federal. Gestión ágil con inscripción registral." />
</head>
<body class="bg-slate-50 antialiased">
    <Header />
    
    <main class="pt-32 pb-20 px-6">
        <div class="max-w-6xl mx-auto">
            
            <a href="/#servicios" class="inline-flex items-center gap-2 text-indigo-600 font-black text-[10px] uppercase tracking-[0.2em] mb-10 hover:translate-x-[-5px] transition-all">
                <span>←</span> Volver a Especialidades
            </a>

            <div class="bg-indigo-950 p-12 md:p-20 rounded-[3rem] shadow-2xl mb-12 relative overflow-hidden border-2 border-slate-800">
                <div class="absolute top-0 right-0 p-10 opacity-10">
                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="relative z-10 text-center md:text-left">
                    <span class="text-amber-400 font-black text-[10px] uppercase tracking-[0.4em] block mb-6">Derecho de Familia</span>
                    <h1 class="text-4xl md:text-7xl font-black text-white mb-8 uppercase tracking-tight leading-[0.9]">Divorcio <br/><span class="text-indigo-400">Express</span><br/><span class="text-indigo-400">Caba</span></h1>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                
                <div class="lg:col-span-2 space-y-16">
                    
                    <section>
                        <div class="text-center md:text-left mb-8">
                            <h2 class="text-2xl font-black text-slate-900 uppercase tracking-tight">Honorarios del <span class="text-indigo-600">Proceso</span></h2>
                            <p class="text-slate-500 font-bold text-[10px] uppercase tracking-widest mt-2">Planes mensuales adaptados a su necesidad</p>
                        </div>
                        <PreciosDivorcio />
                    </section>

                    <section class="bg-white p-10 md:p-14 rounded-[3rem] border-2 border-slate-500 shadow-xl relative overflow-hidden">
                        <h2 class="text-xl font-black text-slate-900 uppercase tracking-tight mb-16 flex items-center gap-3">
                            <span class="relative flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-indigo-600"></span>
                            </span>
                            Hoja de Ruta del Proceso
                        </h2>

                        <div class="relative space-y-16">
                            <div class="absolute left-[19px] top-2 w-[4px] h-[calc(100%-32px)] bg-slate-100 rounded-full"></div>
                            <div class="absolute left-[19px] top-2 w-[4px] bg-indigo-600 shadow-[0_0_15px_rgba(79,70,229,0.8)] animate-draw-line origin-top z-10"></div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-slate-100 bg-white text-slate-300 rounded-full flex items-center justify-center font-black z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 0.2s;">1</div>
                                <div class="pt-1">
                                    <h4 class="font-black text-slate-900 uppercase text-xs mb-1 tracking-wider">Contacto Inicial</h4>
                                    <p class="text-slate-600 text-sm leading-relaxed font-medium">Análisis de situación y definición de estrategia legal mediante canales digitales o presenciales.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-slate-100 bg-white text-slate-300 rounded-full flex items-center justify-center font-black z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 1.0s;">2</div>
                                <div class="pt-1">
                                    <h4 class="font-black text-slate-900 uppercase text-xs mb-1 tracking-wider">Documentación</h4>
                                    <p class="text-slate-600 text-sm leading-relaxed font-medium">Recepción de documentación necesaria para el inicio inmediato del expediente.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-slate-100 bg-white text-slate-300 rounded-full flex items-center justify-center font-black z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 1.8s;">3</div>
                                <div class="pt-1">
                                    <h4 class="font-black text-slate-900 uppercase text-xs mb-1 tracking-wider">Redacción de Documentación</h4>
                                    <p class="text-slate-600 text-sm leading-relaxed font-medium">Elaboración del convenio regulador protegiendo los intereses y deseos de las partes.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-slate-100 bg-white text-slate-300 rounded-full flex items-center justify-center font-black z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 2.6s;">4</div>
                                <div class="pt-1">
                                    <h4 class="font-black text-slate-900 uppercase text-xs mb-1 tracking-wider">Presentación Judicial</h4>
                                    <p class="text-slate-600 text-sm leading-relaxed font-medium">Seguimiento diario en Tribunales de CABA hasta obtener la sentencia definitiva.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-slate-100 bg-white text-slate-300 rounded-full flex items-center justify-center font-black z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 3.4s;">5</div>
                                <div class="pt-1">
                                    <h4 class="font-black text-indigo-700 uppercase text-xs mb-1 tracking-wider">Certificado de Divorcio</h4>
                                    <p class="text-slate-600 text-sm leading-relaxed font-bold">Inscripción registral y entrega del certificado final con firma digital.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <aside class="space-y-6">
                    <div class="bg-slate-900 p-8 rounded-[3rem] text-white border-2 border-slate-700 shadow-2xl sticky top-24">
                        <h3 class="text-lg font-black uppercase tracking-widest mb-8 text-amber-400 text-center">Documentación</h3>
                        <ul class="space-y-6">
                            <li class="flex items-start gap-3 text-sm font-bold"><span class="text-indigo-400">✓</span> DNI de ambos cónyuges.</li>
                            <li class="flex items-start gap-3 text-sm font-bold"><span class="text-indigo-400">✓</span> Acta de Matrimonio.</li>
                            <li class="flex items-start gap-3 text-sm font-bold"><span class="text-indigo-400">✓</span> Partidas Nacimiento de Hijos.</li>
                        </ul>
                    </div>
                    <a href="https://wa.me/5491159360995" class="block w-full bg-green-600 hover:bg-green-700 text-white text-center p-8 rounded-[2.5rem] shadow-xl transition-all hover:scale-[1.03] uppercase font-black tracking-widest text-sm">Consultar ahora</a>
                </aside>
            </div>

            <section class="mt-24 border-t border-slate-200 pt-20">
                <div class="text-center mb-16">
                    <h2 class="text-2xl md:text-4xl font-black text-slate-900 uppercase tracking-tight">Preguntas <span class="text-indigo-600">Frecuentes</span></h2>
                    <div class="w-16 h-1 bg-amber-400 mx-auto mt-4 rounded-full"></div>
                </div>

                <div class="max-w-3xl mx-auto space-y-4">
                    <details class="group bg-white border-2 border-slate-500 rounded-[2rem] overflow-hidden transition-all duration-300 open:shadow-xl">
                        <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
                            <h3 class="text-sm md:text-base font-black text-slate-900 uppercase tracking-wide pr-4">¿Cuánto tiempo demora el trámite en CABA?</h3>
                            <span class="text-indigo-600 transition-transform duration-300 group-open:rotate-180">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </span>
                        </summary>
                        <div class="px-6 md:px-8 pb-8">
                            <p class="text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-6">
                                En la Ciudad Autónoma de Buenos Aires, según nuestra experiencia, un divorcio por presentación conjunta suele demorar entre 7 a 45 días hasta obtener la sentencia.
                            </p>
                        </div>
                    </details>

                    <details class="group bg-white border-2 border-slate-500 rounded-[2rem] overflow-hidden transition-all duration-300 open:shadow-xl">
                        <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
                            <h3 class="text-sm md:text-base font-black text-slate-900 uppercase tracking-wide pr-4">¿Es necesario que ambos estemos de acuerdo?</h3>
                            <span class="text-indigo-600 transition-transform duration-300 group-open:rotate-180">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </span>
                        </summary>
                        <div class="px-6 md:px-8 pb-8">
                            <p class="text-slate-600 font-medium leading-relaxed border-t border-slate-100 pt-6">
                                No. El actual Código Civil permite el "divorcio unilateral", donde uno de los cónyuges solicita la disolución sin necesidad del consentimiento del otro.
                            </p>
                        </div>
                    </details>
                </div>
            </section>
        </div>
    </main>

    <Footer />
    <WhatsappFlotante />

    <style>
        @keyframes draw-line {
            0% { height: 0; }
            100% { height: calc(100% - 32px); }
        }
        .animate-draw-line {
            animation: draw-line 3.8s linear forwards;
        }

        @keyframes fill-step {
            0% { 
                background-color: white; 
                border-color: #f1f5f9; 
                color: #cbd5e1; 
                transform: scale(0.9);
            }
            100% { 
                background-color: #4f46e5; 
                border-color: #ffffff; 
                color: #ffffff;
                transform: scale(1);
                box-shadow: 0 0 20px rgba(79, 70, 229, 0.4);
            }
        }
        .animate-fill-step {
            animation: fill-step 0.4s ease-out forwards;
        }
    </style>
</body>
</html>