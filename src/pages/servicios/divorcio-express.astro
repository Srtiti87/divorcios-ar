---
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import WhatsappFlotante from "../../components/WhatsappFlotante.astro";
import PreciosDivorcio from "../../components/PreciosDivorcio.astro";
import "../../styles/global.css";
---

<html lang="es" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Divorcio Express en CABA | Abogado Dr. Santibáñez Héctor David</title>
    <meta name="description" content="Abogado de Divorcio Express en Capital Federal. Gestión ágil con inscripción registral." />
</head>
<body class="bg-ink antialiased overflow-x-hidden">
    <Header />
    
    <main class="pt-32 pb-20 px-6">
        <div class="max-w-6xl mx-auto">
            
            <a href="/#servicios" class="inline-flex items-center gap-2 text-gold font-bold text-[10px] uppercase tracking-[0.2em] mb-10 hover:translate-x-[-5px] transition-all">
                <span>←</span> Volver a Especialidades
            </a>

            <div class="bg-ink-2 p-12 md:p-20 rounded-sm shadow-2xl mb-12 relative overflow-hidden border border-white/10">
                <div class="absolute top-0 right-0 p-10 opacity-10">
                    <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
                </div>
                <div class="relative z-10 text-center md:text-left">
                    <span class="text-gold font-bold text-[10px] uppercase tracking-[0.4em] block mb-6">Derecho de Familia</span>
                    <h1 class="font-serif text-4xl md:text-7xl font-light text-cream mb-8 tracking-tight leading-[0.95]">Divorcio <br/><em class="italic text-gold">Express</em><br/><em class="italic text-gold">CABA</em></h1>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
                
                <div class="lg:col-span-2 space-y-16">
                    
                    <section>
                        <div class="text-center md:text-left mb-8">
                            <h2 class="font-serif text-2xl font-semibold text-cream tracking-tight">Honorarios del <em class="italic text-gold">Proceso</em></h2>
                            <p class="text-cream/40 font-bold text-[10px] uppercase tracking-widest mt-2">Planes mensuales adaptados a su necesidad</p>
                        </div>
                        <PreciosDivorcio />
                    </section>

                    <section class="bg-ink-2 p-10 md:p-14 rounded-sm border border-white/10 shadow-xl relative overflow-hidden">
                        <h2 class="font-serif text-xl font-semibold text-cream tracking-tight mb-16 flex items-center gap-3">
                            <span class="relative flex h-3 w-3">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold opacity-60"></span>
                                <span class="relative inline-flex rounded-full h-3 w-3 bg-gold"></span>
                            </span>
                            Hoja de Ruta del Proceso
                        </h2>

                        <div class="relative space-y-16">
                            <div class="absolute left-[19px] top-2 w-[4px] h-[calc(100%-32px)] bg-white/10 rounded-full"></div>
                            <div class="absolute left-[19px] top-2 w-[4px] bg-gold shadow-[0_0_15px_rgba(184,150,90,0.6)] animate-draw-line origin-top z-10"></div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-white/10 bg-ink text-cream/30 rounded-full flex items-center justify-center font-bold z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 0.2s;">1</div>
                                <div class="pt-1">
                                    <h4 class="font-bold text-cream uppercase text-xs mb-1 tracking-wider">Contacto Inicial</h4>
                                    <p class="text-cream/55 text-sm leading-relaxed font-light">Análisis de situación y definición de estrategia legal mediante canales digitales o presenciales.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-white/10 bg-ink text-cream/30 rounded-full flex items-center justify-center font-bold z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 1.0s;">2</div>
                                <div class="pt-1">
                                    <h4 class="font-bold text-cream uppercase text-xs mb-1 tracking-wider">Documentación</h4>
                                    <p class="text-cream/55 text-sm leading-relaxed font-light">Recepción de documentación necesaria para el inicio inmediato del expediente.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-white/10 bg-ink text-cream/30 rounded-full flex items-center justify-center font-bold z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 1.8s;">3</div>
                                <div class="pt-1">
                                    <h4 class="font-bold text-cream uppercase text-xs mb-1 tracking-wider">Redacción de Documentación</h4>
                                    <p class="text-cream/55 text-sm leading-relaxed font-light">Elaboración del convenio regulador protegiendo los intereses y deseos de las partes.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-white/10 bg-ink text-cream/30 rounded-full flex items-center justify-center font-bold z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 2.6s;">4</div>
                                <div class="pt-1">
                                    <h4 class="font-bold text-cream uppercase text-xs mb-1 tracking-wider">Presentación Judicial</h4>
                                    <p class="text-cream/55 text-sm leading-relaxed font-light">Seguimiento diario en Tribunales de CABA hasta obtener la sentencia definitiva.</p>
                                </div>
                            </div>

                            <div class="relative flex gap-8 group">
                                <div class="step-circle flex-shrink-0 w-10 h-10 border-4 border-white/10 bg-ink text-cream/30 rounded-full flex items-center justify-center font-bold z-20 transition-all duration-500 animate-fill-step" style="animation-delay: 3.4s;">5</div>
                                <div class="pt-1">
                                    <h4 class="font-bold text-gold uppercase text-xs mb-1 tracking-wider">Certificado de Divorcio</h4>
                                    <p class="text-cream/55 text-sm leading-relaxed font-medium">Inscripción registral y entrega del certificado final con firma digital.</p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <aside class="space-y-6">
                    <div class="bg-ink-2 p-8 rounded-sm text-cream border border-white/10 shadow-2xl sticky top-24">
                        <h3 class="font-serif text-lg font-semibold uppercase tracking-widest mb-8 text-gold text-center">Documentación</h3>
                        <ul class="space-y-6">
                            <li class="flex items-start gap-3 text-sm font-medium"><span class="text-gold">✓</span> DNI de ambos cónyuges.</li>
                            <li class="flex items-start gap-3 text-sm font-medium"><span class="text-gold">✓</span> Acta de Matrimonio.</li>
                            <li class="flex items-start gap-3 text-sm font-medium"><span class="text-gold">✓</span> Partidas Nacimiento de Hijos.</li>
                        </ul>
                    </div>
                    <a href="https://wa.me/5491159360995" class="block w-full bg-gold hover:bg-gold-light text-ink text-center p-8 rounded-sm shadow-xl transition-all hover:-translate-y-0.5 uppercase font-bold tracking-widest text-sm">Consultar ahora</a>
                </aside>
            </div>

            <section class="mt-24 border-t border-white/10 pt-20">
                <div class="text-center mb-16">
                    <h2 class="font-serif text-2xl md:text-4xl font-light text-cream tracking-tight">Preguntas <em class="italic text-gold">Frecuentes</em></h2>
                    <div class="w-16 h-0.5 bg-gold mx-auto mt-4"></div>
                </div>

                <div class="max-w-3xl mx-auto space-y-4">
                    <details class="group bg-ink-2 border border-white/10 rounded-sm overflow-hidden transition-all duration-300 open:border-gold/30">
                        <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
                            <h3 class="font-serif text-base md:text-lg font-medium text-cream pr-4">¿Cuánto tiempo demora el trámite en CABA?</h3>
                            <span class="text-gold transition-transform duration-300 group-open:rotate-180">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </span>
                        </summary>
                        <div class="px-6 md:px-8 pb-8">
                            <p class="text-cream/65 font-light leading-relaxed border-t border-white/10 pt-6">
                                En la Ciudad Autónoma de Buenos Aires, según nuestra experiencia, un divorcio por presentación conjunta suele demorar entre 15 y 60 días hasta obtener la sentencia.
                            </p>
                        </div>
                    </details>

                    <details class="group bg-ink-2 border border-white/10 rounded-sm overflow-hidden transition-all duration-300 open:border-gold/30">
                        <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer list-none">
                            <h3 class="font-serif text-base md:text-lg font-medium text-cream pr-4">¿Es necesario que ambos estemos de acuerdo?</h3>
                            <span class="text-gold transition-transform duration-300 group-open:rotate-180">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                            </span>
                        </summary>
                        <div class="px-6 md:px-8 pb-8">
                            <p class="text-cream/65 font-light leading-relaxed border-t border-white/10 pt-6">
                                No. El actual Código Civil permite el "divorcio unilateral", donde uno de los cónyuges solicita la disolución sin necesidad del consentimiento del otro.
                            </p>
                        </div>
                    </details>
                </div>
            </section>
        </div>
    </main>

    <Footer />
    <WhatsappFlotante />

    <style>
        @keyframes draw-line {
            0% { height: 0; }
            100% { height: calc(100% - 32px); }
        }
        .animate-draw-line {
            animation: draw-line 3.8s linear forwards;
        }

        @keyframes fill-step {
            0% { 
                background-color: #14151f; 
                border-color: rgba(255,255,255,0.1); 
                color: rgba(245,244,240,0.3); 
                transform: scale(0.9);
            }
            100% { 
                background-color: #b8965a; 
                border-color: #14151f; 
                color: #14151f;
                transform: scale(1);
                box-shadow: 0 0 20px rgba(184,150,90,0.35);
            }
        }
        .animate-fill-step {
            animation: fill-step 0.4s ease-out forwards;
        }
    </style>
</body>
</html>
