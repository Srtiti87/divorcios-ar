    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;
  }
  .hero::after{
    content:'';position:absolute;inset:0;
    background:linear-gradient(
      to bottom,
      rgba(20,21,31,0.78) 0%,
      rgba(20,21,31,0.70) 60%,
      rgba(20,21,31,0.82) 100%
    );
    pointer-events:none;z-index:0;
  }
  .hero-left{position:relative;z-index:1;justify-content:flex-start;min-height:auto}
  .hero-right{display:none}
  /* En mobile la imagen viene del background-image del section, ocultamos el wrap de desktop */
  .hero-img-wrap{display:none}
  .hero-left{padding:.75rem 1.25rem 3rem}
  .why-inner{grid-template-columns:1fr;gap:3rem}
  .servicios-grid{grid-template-columns:1fr 1fr}
  .precios-grid{grid-template-columns:1fr}
  .proceso-steps{grid-template-columns:1fr;gap:2rem}
  .proceso-line{display:none}
  .equipo-grid{grid-template-columns:1fr}
  .equipo-sello{grid-template-columns:1fr 1fr}
  .faq-inner{grid-template-columns:1fr;gap:3rem}
  .faq-sticky{position:relative;top:0}
  .footer-grid{grid-template-columns:1fr 1fr;gap:2rem}
  nav{padding:1rem 1.5rem}
  .nav-links{display:none}
  .nav-tel{display:none}
  .nav-cta{padding:.5rem 1rem;font-size:.78rem}
  .nav-burger{display:flex}
  .credentials-band{gap:1.5rem}
  /* Reducir padding vertical en todas las secciones para mobile */
  .why{padding:4rem 3rem}
  .servicios{padding:4rem 3rem}
  .precios{padding:4rem 3rem}
  .testimonios{padding:4rem 3rem}
  .testimonios-grid{grid-template-columns:1fr}
  .faq-honorarios{padding:4rem 3rem}
  .proceso{padding:4rem 3rem}
  .equipo{padding:4rem 3rem 2rem}
  .faq{padding:4rem 3rem}
  .cta-final{padding:5rem 3rem}
  /* Reducir margin-top del equipo-sello para eliminar espacio vacío */
  .equipo-sello{margin-top:2rem}
}
@media(max-width:640px){
  section,nav,footer,.hero-left,.credentials-band,.why{padding-left:1.25rem;padding-right:1.25rem}
  .servicios-grid{grid-template-columns:1fr}
  .compare-table{overflow-x:auto;display:block}
  .precios-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
}

