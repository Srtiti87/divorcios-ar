}

/* ══════════════════════════════════════
   FAQ HONORARIOS
══════════════════════════════════════ */
.faq-honorarios{
  padding:7rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.faq-hon-inner{max-width:900px;margin:0 auto}
.faq-hon-grid{margin-top:2.5rem}
.faq-sticky{position:sticky;top:7rem}
.faq-list{display:flex;flex-direction:column}
.faq-item{
  border-bottom:1px solid var(--border);
  overflow:hidden;
}
.faq-q{
  padding:1.5rem 0;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  cursor:pointer;
  list-style:none;
  font-family:var(--ff-serif);
  font-size:1.1rem;color:var(--cream);font-weight:400;
  transition:color .2s;
}
.faq-q:hover{color:var(--gold)}
.faq-q::marker{display:none}
.faq-icon{
  width:1.5rem;height:1.5rem;border:1px solid var(--border);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:var(--gold);font-size:.83rem;flex-shrink:0;
  transition:transform .3s var(--ease), border-color .2s;
}
details[open] .faq-icon{transform:rotate(45deg);border-color:var(--gold)}
.faq-a{
  font-size:.93rem;font-weight:300;
  color:rgba(245,244,240,0.72);line-height:1.75;
  padding-bottom:1.5rem;
}

/* ══════════════════════════════════════
   CTA FINAL — Máximo impacto
══════════════════════════════════════ */
.cta-final{
  padding:10rem 3rem;
  background:var(--ink);
  border-top:1px solid var(--border);
  text-align:center;
  position:relative;overflow:hidden;
}
.cta-final::before{
  content:'';position:absolute;
  width:60rem;height:60rem;border-radius:50%;
  background:radial-gradient(circle,rgba(184,150,90,0.06) 0%,transparent 65%);
  top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;
}
.cta-inner{position:relative;z-index:2;max-width:680px;margin:0 auto}
.cta-final .section-kicker{justify-content:center;margin-bottom:1.5rem}
.cta-h2{
  font-family:var(--ff-serif);
  font-size:clamp(2.8rem,5vw,5rem);
  font-weight:300;color:var(--cream);
  line-height:1;letter-spacing:-.03em;
  margin-bottom:1.25rem;
}
.cta-h2 em{font-style:italic;color:var(--gold)}
.cta-lead{
  font-size:1rem;font-weight:300;
  color:rgba(245,244,240,0.68);line-height:1.7;
  margin-bottom:3rem;
}
.cta-actions{
  display:flex;flex-direction:column;align-items:center;gap:.75rem;
  margin:0 auto;max-width:380px;
}
.cta-guarantee{
  display:flex;align-items:center;gap:.5rem;
  font-size:.8rem;color:rgba(245,244,240,0.46);
  margin-top:1.5rem;
}
.cta-guarantee-icon{color:var(--gold)}

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer{
  background:var(--ink-2);
  border-top:1px solid var(--border);
  padding:5rem 3rem 2.5rem;
}
.footer-grid{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:2.5fr 1fr 1fr 1fr;gap:4rem;
  margin-bottom:4rem;
}
.footer-logo{
  font-family:var(--ff-serif);font-size:2rem;font-weight:300;
  text-decoration:none;color:var(--cream);letter-spacing:-.02em;
}
.footer-logo span{color:var(--gold)}
.footer-tagline{
  font-size:.88rem;font-weight:300;
  color:rgba(245,244,240,0.46);
  line-height:1.7;margin-top:.75rem;max-width:260px;
}
.footer-matricula-text{
  font-size:.7rem;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;
  color:rgba(184,150,90,0.45);
  margin-top:1.25rem;line-height:1.7;
}
.footer-col h5{
  font-size:.7rem;font-weight:700;letter-spacing:.2em;
  text-transform:uppercase;
  color:rgba(245,244,240,0.38);
  margin-bottom:1.25rem;
}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.7rem}
.footer-col a{
  font-size:.9rem;font-weight:300;
  color:rgba(245,244,240,0.62);text-decoration:none;
  transition:color .2s;
}
.footer-col a:hover{color:var(--cream)}
.footer-bottom{
  max-width:1200px;margin:0 auto;
  padding-top:2rem;border-top:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;
  font-size:.8rem;color:rgba(245,244,240,0.30);
}
.footer-legal{display:flex;gap:2rem}
.footer-legal a{color:rgba(245,244,240,0.30);text-decoration:none;transition:color .2s}
.footer-legal a:hover{color:rgba(245,244,240,0.72)}

/* Estrellas hero card */
.hero-stars{
  margin:.75rem 0 1.25rem;
  display:flex;flex-direction:column;gap:.3rem;
}
.stars-row{display:flex;gap:2px}
.star{
  color:#f5c518;font-size:1rem;
  text-shadow:0 0 6px rgba(245,197,24,0.4);
}
.stars-label{
  font-size:.7rem;color:rgba(245,244,240,0.52);
  letter-spacing:.06em;
}

/* Logos institucionales hero card */
.hero-card-logos{
  display:flex;gap:1rem;
  padding-top:1.25rem;
  border-top:1px solid var(--border);
  margin-top:1rem;
}
.inst-logo{
  display:flex;flex-direction:column;align-items:center;gap:.35rem;
}
.inst-label{
  font-size:.65rem;font-weight:600;letter-spacing:.08em;
  text-transform:uppercase;color:rgba(245,244,240,0.46);
  white-space:nowrap;
}
.inst-img{
  opacity:.7;
  filter:drop-shadow(0 0 4px rgba(184,150,90,0.15));
  transition:opacity .2s;
}
.inst-logo:hover .inst-img{opacity:1}

/* ══════════════════════════════════════
   TICKER DE ACTIVIDAD FLOTANTE
══════════════════════════════════════ */
#activity-ticker{
  position:fixed;
  bottom:2rem;left:2rem;
  z-index:400;
  background:rgba(8,9,15,0.95);
  border:1px solid var(--border-gold);
  border-radius:4px;
  padding:.65rem 1rem .65rem .85rem;
  display:flex;align-items:center;gap:.65rem;
  backdrop-filter:blur(12px);
  max-width:280px;
  box-shadow:0 4px 24px rgba(0,0,0,0.4);
  transform:translateY(0);
  transition:opacity .4s, transform .4s var(--ease);
  pointer-events:none;
}
#activity-ticker.hide{
  opacity:0;transform:translateY(8px);
}
.act-dot{
  width:7px;height:7px;border-radius:50%;
  background:#4ade80;flex-shrink:0;
  animation:pulse-green 2s infinite;
}
.act-text{
  font-size:.75rem;color:rgba(245,244,240,0.76);
  line-height:1.35;
}
.act-text strong{color:var(--cream);font-weight:600}
.act-close{
  font-size:.78rem;color:rgba(245,244,240,0.30);
  cursor:pointer;flex-shrink:0;pointer-events:all;
  padding:.1rem .2rem;
  transition:color .2s;
}
.act-close:hover{color:rgba(245,244,240,0.72)}

/* Estructura precio con referencia tachada + promo */
.precio-anchor-wrap{
  display:flex;flex-direction:column;gap:.4rem;
  padding:.75rem 0;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}
.precio-anchor-ref{
  display:flex;align-items:baseline;gap:.4rem;
}
.precio-anchor-ref-num{
  font-family:var(--ff-serif);
  font-size:1.5rem;color:rgba(245,244,240,0.35);
  letter-spacing:-.02em;line-height:1;
  text-decoration:line-through;
  text-decoration-color:rgba(245,244,240,0.25);
}
.precio-anchor-ref-label{
  font-size:.78rem;color:rgba(245,244,240,0.30);
}
.precio-anchor-sep{
  display:flex;align-items:center;gap:.5rem;
  margin:.2rem 0;
}
.precio-anchor-sep span{
  font-size:.7rem;font-weight:700;letter-spacing:.12em;
  text-transform:uppercase;color:var(--gold);
  background:var(--gold-faint);
  border:1px solid var(--border-gold);
  padding:.2rem .6rem;border-radius:2px;
}
.precio-real{
  display:flex;align-items:baseline;gap:.3rem;
}
.precio-real-note{
  font-size:.78rem;color:#4ade80;font-weight:600;
  letter-spacing:.02em;
}


.download-strip{
  background:var(--gold-faint);
  border:1px solid var(--border-gold);
  border-radius:2px;
  padding:1.5rem 2rem;
  display:flex;align-items:center;justify-content:space-between;gap:1.5rem;
  margin-top:3rem;
  flex-wrap:wrap;
}
.download-strip-text{}
.download-strip-text p{
  font-size:.75rem;font-weight:700;letter-spacing:.15em;
  text-transform:uppercase;color:var(--gold);margin-bottom:.3rem;
}
.download-strip-text h4{
  font-family:var(--ff-serif);
  font-size:1.1rem;color:var(--cream);font-weight:400;
}
.btn-download{
  display:flex;align-items:center;gap:.6rem;
  background:var(--gold);color:var(--ink);
  padding:.65rem 1.4rem;border-radius:2px;
  font-weight:700;font-size:.83rem;letter-spacing:.06em;
  text-transform:uppercase;text-decoration:none;
  transition:background .2s,transform .15s;
  white-space:nowrap;flex-shrink:0;
}
.btn-download:hover{background:var(--gold-light);transform:translateY(-1px)}
.btn-download-icon{font-size:1rem}

/* ══════════════════════════════════════
   IMÁGENES NEUROMARKETING
══════════════════════════════════════ */

/* Why section — imagen firma */
.why-img-wrap{
  position:relative;
  margin-bottom:2rem;
  border-radius:3px;
  overflow:hidden;
  border:1px solid var(--border);
}
.why-img-wrap img{
  width:100%;height:220px;
  object-fit:cover;object-position:center 40%;
  display:block;
  filter:brightness(.55) saturate(.5) sepia(.2);
  transition:filter .6s var(--ease), transform .6s var(--ease);
}
.why-img-wrap:hover img{
  filter:brightness(.65) saturate(.6) sepia(.15);
  transform:scale(1.02);
}
.why-img-caption{
  position:absolute;bottom:0;left:0;right:0;
  padding:.6rem 1rem;
  font-size:.72rem;font-weight:500;letter-spacing:.12em;
  text-transform:uppercase;color:rgba(245,244,240,0.5);
  background:linear-gradient(transparent, rgba(14,15,20,.75));
}

/* Equipo — placeholder foto abogado */
.ab-photo-wrap{margin-bottom:1.75rem}
.ab-photo-placeholder{
  width:100px;height:100px;border-radius:50%;
  background:linear-gradient(135deg,var(--ink-2),rgba(184,150,90,0.06));
  border:1.5px solid var(--border-gold);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:.25rem;
  position:relative;overflow:hidden;
}
.ab-photo-placeholder::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(circle at 50% 35%,rgba(184,150,90,0.08),transparent 70%);
}
.ab-photo-initials{
  font-family:var(--ff-serif);font-size:2rem;font-weight:300;
  color:rgba(184,150,90,0.55);line-height:1;
}
.ab-photo-label{
  font-size:.52rem;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;color:rgba(245,244,240,0.2);
}
/* Foto real del abogado — sangra hasta los bordes */
.ab-photo-wrap{
  margin:0;
  width:100%;
  overflow:hidden;
  position:relative;
}
.ab-photo-img{
  width:100%;
  height:380px;
  object-fit:cover;
  object-position:center 15%;
  display:block;
  filter:brightness(.97) contrast(1.02);
  transition:transform .5s var(--ease), filter .4s;
}
.abogado-card:hover .ab-photo-img{
  transform:scale(1.02);
  filter:brightness(1) contrast(1.03);
}
/* Degradado sutil sobre la foto hacia el contenido */
.ab-photo-wrap::after{
  content:'';
  position:absolute;bottom:0;left:0;right:0;height:5rem;
  background:linear-gradient(transparent, var(--ink-2));
  pointer-events:none;
}
/* Contenido debajo de la foto */
.ab-card-body{
  padding:1.75rem 2.5rem 2.5rem;
}

/* CTA final — imagen de fondo */
.cta-bg-img{
  position:absolute;inset:0;z-index:0;overflow:hidden;
}
.cta-bg-img img{
  width:100%;height:100%;object-fit:cover;
  object-position:center 30%;
  filter:brightness(.12) saturate(.3) sepia(.2);
}
.cta-final{position:relative;overflow:hidden}
.cta-final::before{z-index:1}
.cta-inner{position:relative;z-index:2}


.wa-float{
  position:fixed;bottom:2.5rem;right:2.5rem;z-index:500;
  width:3.5rem;height:3.5rem;
  background:#25d366;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 32px rgba(37,211,102,0.35);
  text-decoration:none;
  transition:transform .2s var(--ease),box-shadow .2s;
  animation:fadeIn 1s 1.5s var(--ease) both;
}
.wa-float:hover{
  transform:scale(1.1) translateY(-2px);
  box-shadow:0 8px 48px rgba(37,211,102,0.5);
}
.wa-float svg{width:1.6rem;height:1.6rem}

/* ══════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════ */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(20px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes fadeIn{
  from{opacity:0}
  to{opacity:1}
}

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal{
  opacity:0;transform:translateY(24px);
  transition:opacity .8s var(--ease), transform .8s var(--ease);
}
.reveal.visible{opacity:1;transform:translateY(0)}
.reveal-delay-1{transition-delay:.1s}
.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}
.reveal-delay-4{transition-delay:.4s}

