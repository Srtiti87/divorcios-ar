}
.testimonio-footer{
  display:flex;align-items:flex-end;
  justify-content:space-between;gap:1rem;
  border-top:1px solid var(--border);
  padding-top:1rem;
}
.testimonio-nombre{
  font-size:.9rem;font-weight:600;
  color:var(--cream);
}
.testimonio-tipo{
  font-size:.75rem;color:rgba(245,244,240,0.45);
