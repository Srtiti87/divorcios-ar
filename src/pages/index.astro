<style>

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:       #14151f;
  --ink-2:     #1c1e2b;
  --paper:     #f2ede4;
  --paper-2:   #e8e1d4;
  --gold:      #b8965a;
  --gold-light:#d4b07a;
  --gold-faint:rgba(184,150,90,0.08);
  --cream:     #f5f4f0;
  --fog:       rgba(245,244,240,0.58);
  --fog-2:     rgba(245,244,240,0.10);
  --border:    rgba(245,244,240,0.13);
  --border-gold:rgba(184,150,90,0.25);
  --ff-serif:  'Cormorant Garamond', Georgia, serif;
  --ff-sans:   'Outfit', system-ui, sans-serif;
  --ease:      cubic-bezier(.16,1,.3,1);
}

html{scroll-behavior:smooth;background:var(--ink);font-size:16px}
body{
  font-family:var(--ff-sans);
  background:var(--ink);
  color:var(--cream);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

/* ══════════════════════════════════════
   CURSOR — flechita clásica del sistema
══════════════════════════════════════ */
/* cursor por defecto del navegador */

/* ══════════════════════════════════════
   GRAIN OVERLAY
══════════════════════════════════════ */
body::before{
  content:'';position:fixed;inset:0;z-index:1;
  pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  opacity:0.4;
}

/* ══════════════════════════════════════
   TOPBAR URGENCIA (Neuromarketing)
══════════════════════════════════════ */
.topbar{
  background:var(--gold);
  color:var(--ink);
  text-align:center;
  padding:.55rem 1.5rem;
  font-size:.8rem;
  font-weight:700;
  letter-spacing:.12em;
  text-transform:uppercase;
  position:relative;z-index:200;
}
.topbar span{opacity:.7;margin:0 .6rem}

/* ══════════════════════════════════════
   NAV
══════════════════════════════════════ */
nav{
  position:sticky;top:0;z-index:150;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem 3rem;
  background:rgba(20,21,31,0.94);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  transition:padding .3s var(--ease);
}
.nav-logo{
  text-decoration:none;
  display:flex;align-items:baseline;gap:.5rem;
}
.logo-d{
  font-family:var(--ff-serif);
  font-size:1.9rem;font-weight:300;
  color:var(--cream);letter-spacing:-.03em;
  line-height:1;
}
.logo-ar{
  font-family:var(--ff-serif);
  font-size:1.9rem;font-weight:600;
  color:var(--gold);letter-spacing:-.03em;
  line-height:1;
}
.logo-dot{color:var(--gold)}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{
  color:rgba(245,244,240,0.72);text-decoration:none;
  font-size:.9rem;font-weight:500;letter-spacing:.04em;
  transition:color .2s;text-transform:uppercase;
}
.nav-links a:hover{color:var(--cream)}
.nav-right{display:flex;align-items:center;gap:1rem}
.nav-tel{
  color:rgba(245,244,240,0.62);font-size:.86rem;
  text-decoration:none;font-weight:400;
  transition:color .2s;
}
.nav-tel:hover{color:var(--gold)}

/* HAMBURGER — oculto en desktop */
.nav-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:2.4rem;height:2.4rem;background:transparent;border:1px solid var(--border);border-radius:2px;cursor:pointer;padding:0;flex-shrink:0}
.nav-burger span{display:block;width:1.2rem;height:2px;background:var(--cream);margin:0 auto;transition:transform .25s var(--ease),opacity .25s var(--ease)}
.nav-burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-burger[aria-expanded="true"] span:nth-child(2){opacity:0}
.nav-burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* MOBILE PANEL — oculto por defecto, se activa solo en mobile via JS+clase */
.nav-mobile-panel{position:fixed;top:0;right:0;height:100vh;width:min(82vw,360px);background:var(--ink-2);border-left:1px solid var(--border);z-index:250;padding:5.5rem 2rem 2rem;display:flex;flex-direction:column;justify-content:space-between;transform:translateX(100%);transition:transform .35s var(--ease);overflow-y:auto}
.nav-mobile-panel.open{transform:translateX(0)}
.nav-mobile-links{list-style:none;display:flex;flex-direction:column;gap:1.5rem}
.nav-mobile-links a{color:rgba(245,244,240,0.82);text-decoration:none;font-size:1.05rem;font-weight:500;letter-spacing:.02em;font-family:var(--ff-serif);transition:color .2s}
.nav-mobile-links a:hover{color:var(--gold)}
.nav-mobile-actions{display:flex;flex-direction:column;gap:.75rem;padding-top:2rem;border-top:1px solid var(--border)}
.nav-mobile-tel{color:rgba(245,244,240,0.62);text-decoration:none;font-size:.9rem;text-align:center;padding:.7rem;border:1px solid var(--border);border-radius:2px}
.nav-mobile-cta{background:var(--gold);color:var(--ink);text-decoration:none;font-weight:700;font-size:.9rem;text-align:center;padding:.85rem;border-radius:2px;letter-spacing:.02em}
.nav-mobile-overlay{position:fixed;inset:0;background:rgba(10,11,17,0.6);z-index:240;opacity:0;pointer-events:none;transition:opacity .3s var(--ease)}
.nav-mobile-overlay.open{opacity:1;pointer-events:auto}
.nav-cta{
  background:var(--gold);
  color:var(--ink);
  padding:.6rem 1.5rem;
  border-radius:2px;
  font-weight:700;font-size:.86rem;
  text-decoration:none;
  letter-spacing:.06em;text-transform:uppercase;
  transition:background .2s, transform .15s;
  white-space:nowrap;
}
.nav-cta:hover{background:var(--gold-light);transform:translateY(-1px)}

/* ══════════════════════════════════════
   HERO
══════════════════════════════════════ */
.hero{
  min-height:100svh;
  display:grid;
  grid-template-columns:55% 45%;
  position:relative;overflow:hidden;
}
/* BG Lines decorativas */
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    linear-gradient(90deg,rgba(184,150,90,0.04) 1px,transparent 1px),
    linear-gradient(0deg,rgba(184,150,90,0.04) 1px,transparent 1px);
  background-size:80px 80px;
  pointer-events:none;
}
.hero-left{
  display:flex;flex-direction:column;justify-content:center;
  padding:2rem 4rem 3rem 3rem;
  position:relative;z-index:2;
}
.hero-eyebrow{
  display:flex;align-items:center;gap:.75rem;
  margin-bottom:1.25rem;
  animation:fadeUp .8s var(--ease) both;
}
.eyebrow-line{
  width:2.5rem;height:1px;background:var(--gold);
}
.eyebrow-text{
  font-size:.75rem;font-weight:600;letter-spacing:.2em;
  color:var(--gold);text-transform:uppercase;
}
.hero-h1{
  font-family:var(--ff-serif);
  font-size:clamp(3.5rem,6vw,6.5rem);
  font-weight:300;
  line-height:.95;
  letter-spacing:-.02em;
  color:var(--cream);
  margin-bottom:1rem;
  animation:fadeUp .9s .1s var(--ease) both;
}
.hero-h1 .accent{
  font-style:italic;color:var(--gold);font-weight:600;
  display:block;
}
.hero-h1 .sub-word{
  font-size:.55em;letter-spacing:.1em;
  font-style:normal;font-weight:300;
  color:rgba(245,244,240,0.68);
  display:block;text-transform:uppercase;
  margin-top:.3rem;font-family:var(--ff-sans);
}
.hero-lead{
  font-size:1.05rem;font-weight:300;
  color:rgba(245,244,240,0.82);
  line-height:1.7;max-width:420px;
  margin-bottom:3rem;
  animation:fadeUp 1s .2s var(--ease) both;
}
.hero-ctas{
  display:flex;flex-direction:column;gap:.75rem;
  animation:fadeUp 1s .3s var(--ease) both;
  max-width:380px;
}
/* BOTÓN PRINCIPAL — Neuromarketing máximo */
.btn-lead{
  position:relative;overflow:hidden;
  background:var(--gold);
  color:var(--ink);
  padding:1.1rem 2rem;
  border-radius:2px;
  font-weight:700;font-size:.95rem;
  text-decoration:none;
  display:flex;align-items:center;justify-content:space-between;
  gap:1rem;
  transition:background .2s, transform .2s var(--ease), box-shadow .2s;
  box-shadow:0 4px 32px rgba(184,150,90,0.2);
}
.btn-lead::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.12),transparent);
  transform:translateX(-100%);
  transition:transform .5s var(--ease);
}
.btn-lead:hover::after{transform:translateX(100%)}
.btn-lead:hover{
  background:var(--gold-light);
  transform:translateY(-2px);
  box-shadow:0 8px 48px rgba(184,150,90,0.35);
}
.btn-lead-text{display:flex;flex-direction:column;gap:.1rem}
.btn-lead-main{font-weight:700;font-size:.95rem;letter-spacing:.01em}
.btn-lead-sub{font-size:.75rem;font-weight:400;opacity:.7;letter-spacing:.04em}
.btn-lead-arrow{
  font-size:1.2rem;flex-shrink:0;
  transition:transform .2s var(--ease);
}
.btn-lead:hover .btn-lead-arrow{transform:translateX(4px)}
/* Botón secundario */
.btn-sec{
  color:rgba(245,244,240,0.82);
  padding:.85rem 2rem;
  border:1px solid rgba(242,237,228,0.12);
  border-radius:2px;
  font-size:.93rem;font-weight:500;
  text-decoration:none;
  display:flex;align-items:center;gap:.75rem;
  transition:border-color .2s, color .2s;
  backdrop-filter:blur(4px);
}
.btn-sec:hover{border-color:var(--border-gold);color:var(--cream)}
.btn-sec-icon{color:var(--gold);font-size:1rem}
/* Prueba social inline */
.hero-social-proof{
  display:flex;align-items:center;gap:1rem;
  margin-top:2rem;
  animation:fadeUp 1s .4s var(--ease) both;
}
.proof-faces{
  display:flex;
}
.proof-face{
  width:2.2rem;height:2.2rem;border-radius:50%;
  background:linear-gradient(135deg,var(--ink-2),#1e2236);
  border:2px solid var(--ink);
  margin-right:-.6rem;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--ff-serif);font-size:.88rem;color:var(--gold);
}
.proof-text{font-size:.83rem;color:rgba(245,244,240,0.68)}
.proof-text strong{color:var(--cream);font-weight:600}
.proof-stars{color:var(--gold);font-size:.83rem;letter-spacing:.1em}

/* Hero — imagen de fondo absoluta en todo el section */
.hero-img-wrap{
  position:absolute;inset:0;z-index:0;pointer-events:none;
}
.hero-img-wrap img{
  width:100%;height:100%;object-fit:cover;
  /* Rostro en el tercio derecho, bien visible */
  object-position:60% center;
  filter:brightness(.88) contrast(1.05) saturate(.82);
}
.hero-img-overlay{
  position:absolute;inset:0;
  /* Izquierda muy oscura para texto → derecha transparente para el rostro */
  background:linear-gradient(
    90deg,
    rgba(20,21,31,0.95) 0%,
    rgba(20,21,31,0.85) 35%,
    rgba(20,21,31,0.50) 55%,
    rgba(20,21,31,0.12) 75%,
    rgba(20,21,31,0.05) 100%
  );
}

/* Hero right — sólo contiene la tarjeta, sin imagen propia */
.hero-right{
  display:flex;align-items:center;justify-content:flex-end;
  padding-right:3rem;
  position:relative;z-index:2;
}
.hero-card{
  position:relative;z-index:2;
  background:rgba(14,16,24,0.88);
  border:1px solid var(--border-gold);
  border-radius:4px;
  padding:2.5rem 2rem;
  backdrop-filter:blur(16px);
  /* Ancho fijo para que el rostro quede libre a la derecha */
  width:260px;flex-shrink:0;
  animation:fadeIn 1.2s .5s var(--ease) both;
}
.hero-card-tag{
  font-size:.7rem;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:var(--gold);
  margin-bottom:1.25rem;
  display:flex;align-items:center;gap:.5rem;
}
.hero-card-tag::before{content:'';width:1.5rem;height:1px;background:var(--gold)}
.hero-stat-big{
  font-family:var(--ff-serif);
  font-size:4.5rem;font-weight:300;
  color:var(--cream);line-height:1;
  letter-spacing:-.04em;
}
.hero-stat-big sup{font-size:1.5rem;vertical-align:super;color:var(--gold)}
.hero-stat-label{
  font-size:.83rem;color:rgba(245,244,240,0.68);
  margin-top:.25rem;margin-bottom:2rem;
  letter-spacing:.06em;text-transform:uppercase;
}
.hero-mini-stats{
  display:flex;flex-direction:column;gap:1rem;
  border-top:1px solid var(--border);
  padding-top:1.5rem;
}
.mini-stat{display:flex;align-items:center;justify-content:space-between}
.mini-stat-val{
  font-family:var(--ff-serif);font-size:1.5rem;
  color:var(--gold);letter-spacing:-.02em;
}
.mini-stat-label{
  font-size:.78rem;color:rgba(245,244,240,0.62);
  text-align:right;max-width:120px;line-height:1.3;
}
/* Ticker en vivo (urgencia) */
.hero-ticker{
  position:absolute;bottom:2rem;left:2rem;right:2rem;z-index:10;
  background:rgba(8,9,15,0.9);
  border:1px solid var(--border);
  border-radius:2px;
  padding:.75rem 1.25rem;
  display:flex;align-items:center;gap:.75rem;
  backdrop-filter:blur(8px);
  animation:fadeUp .8s 1s var(--ease) both;
}
.ticker-dot{
  width:8px;height:8px;border-radius:50%;
  background:#4ade80;flex-shrink:0;
  animation:pulse-green 2s infinite;
}
@keyframes pulse-green{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,.4)}50%{box-shadow:0 0 0 6px rgba(74,222,128,0)}}
.ticker-text{font-size:.8rem;color:rgba(245,244,240,0.82);flex:1}
.ticker-text strong{color:var(--cream)}
.ticker-badge{
  font-size:.7rem;font-weight:700;letter-spacing:.08em;
  background:rgba(74,222,128,.1);
  border:1px solid rgba(74,222,128,.2);
  color:#4ade80;
  padding:.2rem .6rem;border-radius:2rem;
  text-transform:uppercase;white-space:nowrap;
}

/* ══════════════════════════════════════
   BANDA CREDENCIALES
══════════════════════════════════════ */
.credentials-band{
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
  padding:1.5rem 3rem;
  display:flex;align-items:center;justify-content:center;gap:3rem;
  flex-wrap:wrap;
  background:var(--ink-2);
}
.cred-item{
  display:flex;align-items:center;gap:.6rem;
  color:rgba(245,244,240,0.52);
  font-size:.8rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;
}
.cred-item strong{color:rgba(242,237,228,0.7)}
.cred-sep{width:1px;height:1.5rem;background:var(--border)}

/* ══════════════════════════════════════
   SECCIÓN RAZONES / WHY US
══════════════════════════════════════ */
.why{padding:9rem 3rem}
.why-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:center;
}
.why-left .section-kicker{margin-bottom:1.5rem}
.why-title{
  font-family:var(--ff-serif);
  font-size:clamp(2.5rem,4vw,4rem);
  font-weight:300;line-height:1.05;
  letter-spacing:-.02em;color:var(--cream);
  margin-bottom:1.5rem;
}
.why-title em{font-style:italic;color:var(--gold)}
.why-lead{
  font-size:1rem;font-weight:300;
  color:rgba(245,244,240,0.72);line-height:1.75;
  margin-bottom:2.5rem;
}
/* Tabla comparativa */
.compare-table{width:100%}
.compare-row{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  border-bottom:1px solid var(--border);
}
.compare-row:first-child{
  background:var(--gold-faint);
  border-radius:2px 2px 0 0;
}
.compare-cell{
  padding:1rem .75rem;
  font-size:.88rem;color:rgba(245,244,240,0.62);
}
.compare-cell:first-child{color:rgba(245,244,240,0.72);font-weight:500}
.compare-cell.us{color:var(--cream);font-weight:600}
.compare-cell.yes{color:#4ade80}
.compare-cell.no{color:rgba(245,244,240,0.30);text-decoration:line-through}
.compare-cell.head{
  font-size:.72rem;font-weight:700;letter-spacing:.15em;
  text-transform:uppercase;color:rgba(245,244,240,0.46);
  padding:.75rem .75rem;
}
.compare-cell.head.us{color:var(--gold)}
.why-right{display:flex;flex-direction:column;gap:1.25rem}
.why-card{
  background:var(--ink-2);
  border:1px solid var(--border);
  border-left:3px solid transparent;
  border-radius:2px;
  padding:1.75rem 1.5rem;
  transition:border-left-color .3s, background .3s, transform .2s var(--ease);
  cursor:default;
}
.why-card:hover{
  border-left-color:var(--gold);
  background:rgba(14,16,24,0.8);
  transform:translateX(4px);
}
.why-card-head{
  display:flex;align-items:center;gap:.75rem;
  margin-bottom:.6rem;
}
.why-card-icon{
  width:2rem;height:2rem;
  background:var(--gold-faint);
  border:1px solid var(--border-gold);
  border-radius:2px;
  display:flex;align-items:center;justify-content:center;
  font-size:.98rem;flex-shrink:0;
}
.why-card h4{
  font-family:var(--ff-serif);
  font-size:1.1rem;color:var(--cream);font-weight:600;
}
.why-card p{
  font-size:.9rem;font-weight:300;
  color:rgba(245,244,240,0.68);line-height:1.6;
  padding-left:2.75rem;
}

/* ══════════════════════════════════════
   SERVICIOS
══════════════════════════════════════ */
.servicios{
  background:var(--ink-2);
  border-top:1px solid var(--border);
  padding:9rem 3rem;
}
.section-header{
  max-width:1200px;margin:0 auto 4rem;
  display:grid;grid-template-columns:1fr auto;align-items:end;gap:2rem;
}
.section-kicker{
  font-size:.72rem;font-weight:700;letter-spacing:.25em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:.6rem;
  margin-bottom:.75rem;
}
.section-kicker::before{content:'';width:2rem;height:1px;background:var(--gold)}
.section-title-lg{
  font-family:var(--ff-serif);
  font-size:clamp(2.2rem,3.5vw,3.5rem);
  font-weight:300;line-height:1.05;
  letter-spacing:-.02em;color:var(--cream);
}
.section-title-lg em{font-style:italic;color:var(--gold)}
.servicios-grid{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);gap:1.5px;
  background:var(--border);
  border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
}
.servicio-card{
  background:var(--ink-2);
  padding:3rem 2rem 2rem;
  text-decoration:none;
  display:flex;flex-direction:column;gap:1rem;
  transition:background .3s;
  position:relative;overflow:hidden;
}
.servicio-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;
  transition:transform .35s var(--ease);
}
.servicio-card:hover{background:rgba(20,22,34,1)}
.servicio-card:hover::before{transform:scaleX(1)}
.servicio-num{
  font-family:var(--ff-serif);
  font-size:3.5rem;font-weight:300;
  color:rgba(242,237,228,0.05);
  line-height:1;letter-spacing:-.05em;
  position:absolute;top:1rem;right:1.25rem;
}
.servicio-icon-wrap{
  width:2.5rem;height:2.5rem;
  border:1px solid var(--border-gold);
  border-radius:2px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;
  background:var(--gold-faint);
  margin-bottom:.5rem;
}
.servicio-card h3{
  font-family:var(--ff-serif);
  font-size:1.35rem;color:var(--cream);
  font-weight:600;line-height:1.15;
}
.servicio-card p{
  font-size:.88rem;font-weight:300;
  color:rgba(245,244,240,0.62);line-height:1.65;
  flex:1;
}
.servicio-link{
  font-size:.8rem;font-weight:600;letter-spacing:.1em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:.4rem;
  margin-top:auto;
  transition:gap .2s;
}
.servicio-card:hover .servicio-link{gap:.7rem}
.servicio-cta{
  display:block;
  margin-top:.75rem;
  padding:.55rem 1rem;
  background:var(--gold);
  color:var(--ink);
  font-size:.78rem;font-weight:700;
  letter-spacing:.06em;text-transform:uppercase;
  text-decoration:none;border-radius:2px;
  text-align:center;
  transition:background .2s,transform .15s;
}
.servicio-cta:hover{background:var(--gold-light);transform:translateY(-1px)}
.servicio-actions{
  display:flex;flex-direction:column;gap:.5rem;
  margin-top:auto;padding-top:1rem;
}

/* ══════════════════════════════════════
   PRECIOS — sección de máximo impacto
══════════════════════════════════════ */
.precios{
  padding:9rem 3rem;
  background:var(--ink);
  position:relative;overflow:hidden;
}
.precios::before{
  content:'HONORARIOS';
  position:absolute;
  font-family:var(--ff-serif);
  font-size:clamp(8rem,18vw,20rem);
  font-weight:300;
  color:rgba(242,237,228,0.018);
  letter-spacing:-.05em;
  top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;white-space:nowrap;
  line-height:1;
}
.precios-inner{max-width:1200px;margin:0 auto}
.precios-top{
  display:grid;grid-template-columns:1fr auto;align-items:end;
  margin-bottom:4rem;gap:2rem;
}
.anchor-text{
  font-size:.9rem;color:rgba(245,244,240,0.52);
  max-width:320px;line-height:1.65;
}
/* Ancla de precio (Neuromarketing) */
.anchor-badge{
  background:var(--gold-faint);
  border:1px solid var(--border-gold);
  border-radius:2px;
  padding:1.25rem 1.75rem;
  text-align:center;
  flex-shrink:0;
}
.anchor-badge p{font-size:.72rem;letter-spacing:.15em;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:.4rem}
.anchor-badge span{
  font-family:var(--ff-serif);font-size:2.5rem;
  color:var(--cream);line-height:1;letter-spacing:-.03em;
}
.anchor-badge em{font-style:normal;font-size:.83rem;color:rgba(245,244,240,0.62)}
.precios-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
}
.precio-card{
  background:var(--ink-2);
  padding:3rem 2.5rem;
  display:flex;flex-direction:column;gap:1.5rem;
  position:relative;
}
.precio-card.featured{
  background:linear-gradient(160deg,rgba(184,150,90,0.06) 0%,var(--ink-2) 50%);
  border-top:2px solid var(--gold);
}
.precio-featured-label{
  position:absolute;top:-1px;left:50%;transform:translateX(-50%);
  background:var(--gold);color:var(--ink);
  font-size:.6rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;
  padding:.3rem 1rem;border-radius:0 0 4px 4px;
  white-space:nowrap;
}
.precio-tipo{
  font-size:.72rem;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:var(--gold);
}
.precio-nombre{
  font-family:var(--ff-serif);
  font-size:1.75rem;color:var(--cream);
  font-weight:300;line-height:1.1;
}
.precio-amount{
  display:flex;align-items:baseline;gap:.3rem;
  padding:.75rem 0;
  border-top:1px solid var(--border);
  border-bottom:1px solid var(--border);
}
.precio-cur{font-size:.98rem;color:var(--gold);font-weight:600;margin-top:.4rem}
.precio-num{
  font-family:var(--ff-serif);
  font-size:3.5rem;color:var(--cream);
  line-height:1;letter-spacing:-.04em;
}
.precio-period{font-size:.88rem;color:rgba(245,244,240,0.52)}
.precio-consult{
  font-family:var(--ff-serif);
  font-size:1.6rem;color:var(--gold);
  font-style:italic;
}
.precio-features{
  list-style:none;display:flex;flex-direction:column;gap:.7rem;
  flex:1;
}
.precio-features li{
  font-size:.9rem;font-weight:300;
  color:rgba(245,244,240,0.76);
  display:flex;align-items:flex-start;gap:.6rem;
  line-height:1.4;
}
.precio-features li::before{
  content:'✓';color:var(--gold);font-weight:700;flex-shrink:0;font-size:.88rem;
}
.precio-btn{
  margin-top:auto;
  display:block;text-align:center;
  padding:.9rem 1.5rem;border-radius:2px;
  font-weight:700;font-size:.9rem;letter-spacing:.06em;
  text-transform:uppercase;text-decoration:none;
  transition:all .2s;
}
.precio-card.featured .precio-btn{
  background:var(--gold);color:var(--ink);
  box-shadow:0 4px 24px rgba(184,150,90,0.2);
}
.precio-card.featured .precio-btn:hover{
  background:var(--gold-light);
  box-shadow:0 6px 32px rgba(184,150,90,0.35);
  transform:translateY(-1px);
}
.precio-card:not(.featured) .precio-btn{
  background:transparent;
  color:rgba(245,244,240,0.82);
  border:1px solid var(--border);
}
.precio-card:not(.featured) .precio-btn:hover{
  border-color:var(--border-gold);color:var(--cream);
}
.precio-disclaimer{
  text-align:center;margin-top:2rem;
  font-size:.8rem;color:rgba(245,244,240,0.38);
}

/* ══════════════════════════════════════
   PROCESO — Timeline horizontal
══════════════════════════════════════ */
.proceso{
  padding:9rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.proceso-inner{max-width:1200px;margin:0 auto}
.proceso-steps{
  display:grid;grid-template-columns:repeat(5,1fr);
  margin-top:5rem;
  position:relative;
}
.proceso-line{
  position:absolute;top:1.5rem;left:2rem;right:2rem;height:1px;
  background:linear-gradient(90deg,var(--gold) 0%,rgba(184,150,90,0.1) 100%);
}
.step{
  display:flex;flex-direction:column;gap:1.25rem;
  padding:0 1.5rem;
  position:relative;
}
.step-bubble{
  width:3rem;height:3rem;border-radius:50%;
  border:1px solid var(--border-gold);
  background:var(--ink-2);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--ff-serif);font-size:1rem;color:var(--gold);
  position:relative;z-index:1;
  transition:background .3s, border-color .3s;
}
.step:hover .step-bubble{
  background:var(--gold-faint);
  border-color:var(--gold);
}
.step h4{
  font-family:var(--ff-serif);
  font-size:1rem;color:var(--cream);font-weight:600;
  line-height:1.2;
}
.step p{
  font-size:.83rem;color:rgba(245,244,240,0.62);
  font-weight:300;line-height:1.6;
}

/* ══════════════════════════════════════
   EQUIPO
══════════════════════════════════════ */
.equipo{
  padding:9rem 3rem;
  background:var(--ink);
  border-top:1px solid var(--border);
}
.equipo-inner{max-width:1200px;margin:0 auto}
.equipo-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5px;
  margin-top:4rem;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
}
.abogado-card{
  background:var(--ink-2);
  padding:0;
  position:relative;overflow:hidden;
}
.abogado-card::after{
  content:'';position:absolute;bottom:0;right:0;
  width:10rem;height:10rem;
  background:radial-gradient(circle,rgba(184,150,90,0.06) 0%,transparent 70%);
  pointer-events:none;
}
.ab-initials{
  font-family:var(--ff-serif);
  font-size:5rem;font-weight:300;
  color:rgba(184,150,90,0.1);
  line-height:1;letter-spacing:-.04em;
  margin-bottom:2rem;
}
.ab-nombre{
  font-family:var(--ff-serif);
  font-size:1.8rem;color:var(--cream);
  font-weight:300;line-height:1.1;
  margin-bottom:.4rem;
}
.ab-matricula{
  font-size:.72rem;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:var(--gold);
  margin-bottom:1.5rem;
  display:flex;align-items:center;gap:.6rem;
}
.ab-matricula::before{content:'';width:1.5rem;height:1px;background:var(--gold)}
.ab-bio{
  font-size:.96rem;font-weight:300;
  color:rgba(245,244,240,0.72);line-height:1.75;
  margin-bottom:2rem;max-width:340px;
}
.ab-tags{display:flex;flex-wrap:wrap;gap:.5rem}
.ab-tag{
  font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
  padding:.25rem .75rem;border-radius:2px;
  background:var(--gold-faint);
  border:1px solid var(--border-gold);
  color:var(--gold);
}
/* Sello UBA */
.equipo-sello{
  margin-top:4rem;
  border-top:1px solid var(--border);
  padding-top:3rem;
  display:grid;grid-template-columns:repeat(4,1fr);gap:2rem;
  text-align:center;
}
.sello-item{display:flex;flex-direction:column;align-items:center;gap:.5rem}
.sello-icon{font-size:1.5rem;color:var(--gold)}
.sello-val{
  font-family:var(--ff-serif);font-size:1.5rem;
  color:var(--cream);letter-spacing:-.02em;
}
.sello-label{
  font-size:.75rem;color:rgba(245,244,240,0.52);
  letter-spacing:.1em;text-transform:uppercase;
}

/* ══════════════════════════════════════
   FAQ
══════════════════════════════════════ */
.faq{
  padding:9rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.faq-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 2fr;gap:6rem;align-items:start;
}

/* ══════════════════════════════════════
