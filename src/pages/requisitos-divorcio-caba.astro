          { "@type": "ListItem", "position": 2, "name": "Requisitos para divorciarse en CABA", "item": "https://www.divorcios.ar/requisitos-divorcio-caba" }
        ]
      }
    },
    {
      "@type": "LegalService",
      "@id": "https://www.divorcios.ar/#legalservice",
      "name": "Abogados AyG — Divorcios.ar",
      "url": "https://www.divorcios.ar",
      "telephone": "+5491159360995",
