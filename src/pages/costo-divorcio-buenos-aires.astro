<style>
/* ══════════════════════════════════════
   DESIGN TOKENS — idénticos a index.astro v2
══════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --ink:       #14151f;
  --ink-2:     #1c1e2b;
  --paper:     #f2ede4;
  --paper-2:   #e8e1d4;
  --gold:      #b8965a;
  --gold-light:#d4b07a;
  --gold-faint:rgba(184,150,90,0.08);
  --cream:     #f5f4f0;
  --fog:       rgba(245,244,240,0.58);
  --fog-2:     rgba(245,244,240,0.10);
  --border:    rgba(245,244,240,0.13);
  --border-gold:rgba(184,150,90,0.25);
  --ff-serif:  'Cormorant Garamond', Georgia, serif;
  --ff-sans:   'Outfit', system-ui, sans-serif;
  --ease:      cubic-bezier(.16,1,.3,1);
}

html{scroll-behavior:smooth;background:var(--ink);font-size:16px}
body{
  font-family:var(--ff-sans);
  background:var(--ink);
  color:var(--cream);
  -webkit-font-smoothing:antialiased;
  overflow-x:hidden;
}

/* Grain overlay */
body::before{
  content:'';position:fixed;inset:0;z-index:1;
  pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  opacity:0.4;
}

/* ══════════════════════════════════════
   TOPBAR
══════════════════════════════════════ */
.topbar{
  background:var(--gold);color:var(--ink);
  text-align:center;padding:.55rem 1.5rem;
  font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;
  position:relative;z-index:200;
}
.topbar span{opacity:.7;margin:0 .6rem}

/* ══════════════════════════════════════
   NAV
══════════════════════════════════════ */
nav{
  position:sticky;top:0;z-index:150;
  display:flex;align-items:center;justify-content:space-between;
  padding:1.1rem 3rem;
  background:rgba(20,21,31,0.94);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  transition:padding .3s var(--ease);
}
.nav-logo{text-decoration:none;display:flex;align-items:baseline;gap:.5rem}
.logo-d{font-family:var(--ff-serif);font-size:1.9rem;font-weight:300;color:var(--cream);letter-spacing:-.03em;line-height:1}
.logo-ar{font-family:var(--ff-serif);font-size:1.9rem;font-weight:600;color:var(--gold);letter-spacing:-.03em;line-height:1}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{color:rgba(245,244,240,0.72);text-decoration:none;font-size:.9rem;font-weight:500;letter-spacing:.04em;transition:color .2s;text-transform:uppercase}
.nav-links a:hover{color:var(--cream)}
.nav-links a.active{color:var(--gold)}
.nav-right{display:flex;align-items:center;gap:1rem}
.nav-tel{color:rgba(245,244,240,0.62);font-size:.86rem;text-decoration:none;font-weight:400;transition:color .2s}
.nav-tel:hover{color:var(--gold)}
.nav-cta{
  background:var(--gold);color:var(--ink);
  padding:.6rem 1.5rem;border-radius:2px;
  font-weight:700;font-size:.86rem;text-decoration:none;
  letter-spacing:.06em;text-transform:uppercase;
  transition:background .2s,transform .15s;
}
.nav-cta:hover{background:var(--gold-light);transform:translateY(-1px)}

/* ══════════════════════════════════════
   BREADCRUMB
══════════════════════════════════════ */
.breadcrumb{
  padding:.75rem 3rem;
  background:var(--ink-2);
  border-bottom:1px solid var(--border);
  position:relative;z-index:2;
}
.breadcrumb-inner{
  max-width:1200px;margin:0 auto;
  display:flex;align-items:center;gap:.5rem;
  font-size:.78rem;color:rgba(245,244,240,0.42);
  font-weight:400;
}
.breadcrumb a{color:rgba(245,244,240,0.42);text-decoration:none;transition:color .2s}
.breadcrumb a:hover{color:var(--gold)}
.breadcrumb-sep{opacity:.35}
.breadcrumb-current{color:rgba(245,244,240,0.68)}

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.reveal.visible{opacity:1;transform:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* ══════════════════════════════════════
   HERO RESPUESTA DIRECTA
   Diseño: La respuesta es lo primero.
   Fondo tipográfico con el precio grande —
   signature: el número responde antes que el texto.
══════════════════════════════════════ */
.hero-respuesta{
  padding:7rem 3rem 6rem;
  background:var(--ink);
  position:relative;overflow:hidden;
  border-bottom:1px solid var(--border);
}
/* Watermark tipográfico de fondo */
.hero-respuesta::before{
  content:'$';
  position:absolute;
  font-family:var(--ff-serif);
  font-size:clamp(20rem,45vw,55rem);
  font-weight:300;
  color:rgba(184,150,90,0.025);
  line-height:1;
  top:50%;left:-2%;
  transform:translateY(-50%);
  pointer-events:none;
  letter-spacing:-.06em;
  user-select:none;
}
.hero-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 400px;gap:5rem;align-items:center;
  position:relative;z-index:2;
}
.hero-kicker{
  font-size:.72rem;font-weight:700;letter-spacing:.25em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:.6rem;
  margin-bottom:1.5rem;
  animation:fadeUp .8s var(--ease) both;
}
.hero-kicker::before{content:'';width:2rem;height:1px;background:var(--gold)}
/* Pregunta como H1 — explícita para AEO */
.hero-h1{
  font-family:var(--ff-serif);
  font-size:clamp(2.8rem,5vw,5rem);
  font-weight:300;line-height:1.0;
  letter-spacing:-.03em;color:var(--cream);
  margin-bottom:1.5rem;
  animation:fadeUp .8s .1s var(--ease) both;
}
.hero-h1 em{font-style:italic;color:var(--gold)}
/* Respuesta directa — párrafo que las IAs van a citar */
.hero-answer{
  font-size:1.1rem;font-weight:300;
  color:rgba(245,244,240,0.82);line-height:1.75;
  margin-bottom:2rem;
  animation:fadeUp .8s .2s var(--ease) both;
  max-width:560px;
}
.hero-answer strong{color:var(--cream);font-weight:600}
.hero-update{
  display:inline-flex;align-items:center;gap:.5rem;
  font-size:.75rem;color:rgba(245,244,240,0.42);
  letter-spacing:.1em;text-transform:uppercase;
  animation:fadeUp .8s .3s var(--ease) both;
}
.hero-update::before{
  content:'';width:.5rem;height:.5rem;border-radius:50%;
  background:var(--gold);opacity:.6;
}

/* Tarjeta respuesta rápida — lado derecho */
.hero-price-card{
  background:rgba(14,16,24,0.9);
  border:1px solid var(--border-gold);
  border-radius:4px;
  padding:2.5rem 2rem;
  backdrop-filter:blur(16px);
  animation:fadeIn 1s .4s var(--ease) both;
  position:relative;z-index:2;
}
.hpc-tag{
  font-size:.65rem;font-weight:700;letter-spacing:.2em;
  text-transform:uppercase;color:var(--gold);
  margin-bottom:1.5rem;
  display:flex;align-items:center;gap:.5rem;
}
.hpc-tag::before{content:'';width:1.5rem;height:1px;background:var(--gold)}
.hpc-row{
  display:flex;justify-content:space-between;align-items:flex-start;
  padding:1.1rem 0;
  border-bottom:1px solid var(--border);
}
.hpc-row:last-of-type{border-bottom:none;padding-bottom:0}
.hpc-tipo{
  font-family:var(--ff-serif);
  font-size:1rem;color:var(--cream);font-weight:400;
  line-height:1.3;
}
.hpc-tipo small{
  display:block;font-size:.72rem;
  color:rgba(245,244,240,0.45);font-family:var(--ff-sans);
  margin-top:.2rem;letter-spacing:.04em;
}
.hpc-precio{text-align:right}
.hpc-monto{
  font-family:var(--ff-serif);
  font-size:1.65rem;color:var(--cream);
  line-height:1;letter-spacing:-.03em;
}
.hpc-monto sup{font-size:.8rem;color:var(--gold);vertical-align:super}
.hpc-cuota{
  font-size:.68rem;color:rgba(245,244,240,0.45);
  letter-spacing:.06em;text-transform:uppercase;
  margin-top:.15rem;
}
.hpc-lista{
  font-size:.72rem;color:rgba(245,244,240,0.35);
  text-decoration:line-through;margin-top:.1rem;
}
.hpc-disclaimer{
  font-size:.72rem;color:rgba(245,244,240,0.35);
  margin-top:1.25rem;padding-top:1.25rem;
  border-top:1px solid var(--border);
  line-height:1.5;
}
.hpc-cta{
  display:block;text-align:center;
  margin-top:1.25rem;padding:.85rem 1.5rem;
  background:var(--gold);color:var(--ink);
  font-weight:700;font-size:.85rem;letter-spacing:.06em;
  text-transform:uppercase;text-decoration:none;border-radius:2px;
  transition:background .2s,transform .15s;
  box-shadow:0 4px 20px rgba(184,150,90,0.18);
}
.hpc-cta:hover{background:var(--gold-light);transform:translateY(-1px)}

/* ══════════════════════════════════════
   BANDA CREDENCIALES
══════════════════════════════════════ */
.credentials-band{
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
  padding:1.5rem 3rem;
  display:flex;align-items:center;justify-content:center;gap:3rem;flex-wrap:wrap;
  background:var(--ink-2);
}
.cred-item{
  display:flex;align-items:center;gap:.6rem;
  color:rgba(245,244,240,0.52);font-size:.8rem;font-weight:500;
  letter-spacing:.1em;text-transform:uppercase;
}
.cred-item strong{color:rgba(242,237,228,0.7)}
.cred-sep{width:1px;height:1.5rem;background:var(--border)}

/* ══════════════════════════════════════
   SECCIÓN KICKER (shared)
══════════════════════════════════════ */
.section-kicker{
  font-size:.72rem;font-weight:700;letter-spacing:.25em;
  text-transform:uppercase;color:var(--gold);
  display:flex;align-items:center;gap:.6rem;
  margin-bottom:.75rem;
}
.section-kicker::before{content:'';width:2rem;height:1px;background:var(--gold)}
.section-title-lg{
  font-family:var(--ff-serif);
  font-size:clamp(2.2rem,3.5vw,3.5rem);
  font-weight:300;line-height:1.05;letter-spacing:-.02em;color:var(--cream);
}
.section-title-lg em{font-style:italic;color:var(--gold)}

/* ══════════════════════════════════════
   TIPOS DE COSTO — Explicación editorial
══════════════════════════════════════ */
.costos-explicacion{
  padding:7rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.costos-inner{max-width:1200px;margin:0 auto}
.costos-header{margin-bottom:4rem}
.costos-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5px;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
}
.costo-bloque{
  background:var(--ink-2);
  padding:3rem 2.5rem;
}
.costo-bloque.highlight{
  background:linear-gradient(160deg,rgba(184,150,90,0.05) 0%,var(--ink-2) 60%);
}
.costo-icon-row{
  display:flex;align-items:center;gap:.75rem;
  margin-bottom:1.5rem;
}
.costo-icon{
  width:2.5rem;height:2.5rem;
  background:var(--gold-faint);border:1px solid var(--border-gold);
  border-radius:2px;display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0;
}
.costo-tipo-label{
  font-size:.68rem;font-weight:700;letter-spacing:.18em;
  text-transform:uppercase;color:var(--gold);
}
.costo-nombre{
  font-family:var(--ff-serif);
  font-size:1.5rem;color:var(--cream);font-weight:300;
  line-height:1.1;margin-bottom:.75rem;
}
.costo-desc{
  font-size:.92rem;font-weight:300;
  color:rgba(245,244,240,0.70);line-height:1.7;
  margin-bottom:1.5rem;
}
.costo-items{list-style:none;display:flex;flex-direction:column;gap:.5rem}
.costo-items li{
  font-size:.88rem;font-weight:300;
  color:rgba(245,244,240,0.72);
  display:flex;align-items:flex-start;gap:.6rem;line-height:1.4;
}
.costo-items li::before{content:'→';color:var(--gold);font-size:.8rem;margin-top:.1rem;flex-shrink:0}
.costo-nota{
  margin-top:1.5rem;padding:1rem 1.25rem;
  background:var(--gold-faint);border:1px solid var(--border-gold);
  border-radius:2px;
  font-size:.82rem;color:rgba(245,244,240,0.65);line-height:1.55;
}
.costo-nota strong{color:var(--gold)}

/* ══════════════════════════════════════
   TABLA COMPARATIVA DE MODALIDADES
══════════════════════════════════════ */
.modalidades{
  padding:7rem 3rem;
  background:var(--ink);
  border-top:1px solid var(--border);
  position:relative;overflow:hidden;
}
.modalidades::before{
  content:'HONORARIOS';
  position:absolute;
  font-family:var(--ff-serif);
  font-size:clamp(6rem,14vw,16rem);
  font-weight:300;
  color:rgba(242,237,228,0.018);
  letter-spacing:-.05em;
  top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;white-space:nowrap;line-height:1;
}
.modalidades-inner{max-width:1200px;margin:0 auto;position:relative;z-index:2}
.modalidades-header{margin-bottom:4rem}

/* Grilla de precios 2 columnas */
.precios-grid{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5px;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
  margin-bottom:2rem;
}
.precio-card{
  background:var(--ink-2);
  padding:3rem 2.5rem;
  display:flex;flex-direction:column;gap:1.5rem;
  position:relative;
}
.precio-card.featured{
  background:linear-gradient(160deg,rgba(184,150,90,0.06) 0%,var(--ink-2) 50%);
  border-top:2px solid var(--gold);
}
.precio-featured-label{
  position:absolute;top:-1px;left:50%;transform:translateX(-50%);
  background:var(--gold);color:var(--ink);
  font-size:.6rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;
  padding:.3rem 1rem;border-radius:0 0 4px 4px;white-space:nowrap;
}
.precio-tipo{font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold)}
.precio-nombre{
  font-family:var(--ff-serif);
  font-size:1.75rem;color:var(--cream);font-weight:300;line-height:1.1;
}
.precio-desc{font-size:.9rem;font-weight:300;color:rgba(245,244,240,0.62);line-height:1.6}
.precio-amount{
  display:flex;align-items:baseline;gap:.3rem;
  padding:.75rem 0;
  border-top:1px solid var(--border);border-bottom:1px solid var(--border);
}
.precio-cur{font-size:.98rem;color:var(--gold);font-weight:600;margin-top:.4rem}
.precio-num{
  font-family:var(--ff-serif);
  font-size:3.5rem;color:var(--cream);line-height:1;letter-spacing:-.04em;
}
.precio-period{font-size:.88rem;color:rgba(245,244,240,0.52)}
.precio-lista{
  font-size:.8rem;color:rgba(245,244,240,0.35);
  text-decoration:line-through;margin-left:.3rem;
}
.precio-features{
  list-style:none;display:flex;flex-direction:column;gap:.7rem;flex:1;
}
.precio-features li{
  font-size:.9rem;font-weight:300;
  color:rgba(245,244,240,0.76);
  display:flex;align-items:flex-start;gap:.6rem;line-height:1.4;
}
.precio-features li::before{content:'✓';color:var(--gold);font-weight:700;flex-shrink:0;font-size:.88rem}
.precio-btn{
  margin-top:auto;display:block;text-align:center;
  padding:.9rem 1.5rem;border-radius:2px;
  font-weight:700;font-size:.9rem;letter-spacing:.06em;
  text-transform:uppercase;text-decoration:none;transition:all .2s;
}
.precio-card.featured .precio-btn{
  background:var(--gold);color:var(--ink);
  box-shadow:0 4px 24px rgba(184,150,90,0.2);
}
.precio-card.featured .precio-btn:hover{background:var(--gold-light);box-shadow:0 6px 32px rgba(184,150,90,0.35);transform:translateY(-1px)}
.precio-card:not(.featured) .precio-btn{
  background:transparent;color:rgba(245,244,240,0.82);
  border:1px solid var(--border);
}
.precio-card:not(.featured) .precio-btn:hover{border-color:var(--border-gold);color:var(--cream)}
.precio-disclaimer{
  text-align:center;font-size:.8rem;color:rgba(245,244,240,0.38);
  margin-top:.5rem;
}

/* Diferenciador visual: cuota vs. contado */
.pago-opciones{
  display:grid;grid-template-columns:1fr 1fr;gap:1.5px;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
  margin-top:1.5px;
}
.pago-opcion{
  background:var(--ink-2);padding:1.75rem 2rem;
  display:flex;align-items:center;gap:1rem;
}
.pago-opcion-icon{
  width:2rem;height:2rem;flex-shrink:0;
  background:var(--gold-faint);border:1px solid var(--border-gold);
  border-radius:2px;display:flex;align-items:center;justify-content:center;font-size:.9rem;
}
.pago-opcion-texto h4{
  font-family:var(--ff-serif);font-size:1rem;color:var(--cream);font-weight:600;
}
.pago-opcion-texto p{
  font-size:.82rem;color:rgba(245,244,240,0.52);font-weight:300;margin-top:.2rem;
}

/* ══════════════════════════════════════
   SECCIÓN TASA DE JUSTICIA
   (La pregunta más frecuente y la más ignorada)
══════════════════════════════════════ */
.tasa{
  padding:7rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.tasa-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;gap:6rem;align-items:start;
}
.tasa-left .section-kicker{margin-bottom:1.5rem}
.tasa-title{
  font-family:var(--ff-serif);
  font-size:clamp(2rem,3vw,3rem);
  font-weight:300;line-height:1.05;letter-spacing:-.02em;color:var(--cream);
  margin-bottom:1.25rem;
}
.tasa-title em{font-style:italic;color:var(--gold)}
.tasa-body{
  font-size:.96rem;font-weight:300;
  color:rgba(245,244,240,0.72);line-height:1.75;
  margin-bottom:1.5rem;
}
.tasa-alerta{
  padding:1.25rem 1.5rem;
  background:rgba(184,150,90,0.07);
  border:1px solid var(--border-gold);
  border-left:3px solid var(--gold);
  border-radius:2px;
  font-size:.88rem;color:rgba(245,244,240,0.72);line-height:1.6;
}
.tasa-alerta strong{color:var(--gold)}

.tasa-right{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:2px;overflow:hidden}
.tasa-item{
  background:var(--ink-2);
  padding:1.5rem 1.75rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  transition:background .25s;
}
.tasa-item:hover{background:rgba(20,22,34,1)}
.tasa-item-label{
  font-size:.9rem;font-weight:400;color:rgba(245,244,240,0.72);
}
.tasa-item-label small{display:block;font-size:.75rem;color:rgba(245,244,240,0.40);margin-top:.15rem}
.tasa-item-val{
  font-family:var(--ff-serif);
  font-size:1.25rem;color:var(--gold);
  text-align:right;white-space:nowrap;
}
.tasa-item-val.incluido{
  font-family:var(--ff-sans);
  font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(74,222,128,0.9);
}

/* ══════════════════════════════════════
   FAQ — Preguntas de costos
══════════════════════════════════════ */
.faq-costos{
  padding:7rem 3rem;
  background:var(--ink);
  border-top:1px solid var(--border);
}
.faq-costos-inner{max-width:900px;margin:0 auto}
.faq-costos-header{margin-bottom:3.5rem}
.faq-grid{display:flex;flex-direction:column;gap:.75rem}
.faq-item{
  background:var(--ink-2);
  border:1px solid var(--border);border-radius:2px;
  overflow:hidden;
  transition:border-color .25s;
}
.faq-item:hover,.faq-item[open]{border-color:var(--border-gold)}
.faq-q{
  list-style:none;cursor:pointer;
  padding:1.25rem 1.5rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;
  font-size:1rem;font-weight:400;
  color:rgba(245,244,240,0.88);
  font-family:var(--ff-serif);
  transition:color .2s;
}
.faq-q::-webkit-details-marker{display:none}
.faq-item[open] .faq-q{color:var(--cream)}
.faq-icon{
  color:var(--gold);font-size:1.25rem;font-weight:300;flex-shrink:0;
  transition:transform .3s var(--ease);
}
.faq-item[open] .faq-icon{transform:rotate(45deg)}
.faq-a{
  padding:0 1.5rem 1.25rem;
  font-size:.9rem;font-weight:300;
  color:rgba(245,244,240,0.65);line-height:1.7;
}

/* ══════════════════════════════════════
   PROCESO — Cómo empezar (3 pasos)
══════════════════════════════════════ */
.como-empezar{
  padding:7rem 3rem;
  background:var(--ink-2);
  border-top:1px solid var(--border);
}
.como-inner{max-width:1200px;margin:0 auto}
.como-header{margin-bottom:4rem}
.como-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;
  background:var(--border);border:1px solid var(--border);
  border-radius:2px;overflow:hidden;
}
.como-step{
  background:var(--ink-2);
  padding:3rem 2rem;
  position:relative;overflow:hidden;
  transition:background .3s;
}
.como-step:hover{background:rgba(20,22,34,1)}
.como-step::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--gold);transform:scaleX(0);transform-origin:left;
  transition:transform .35s var(--ease);
}
.como-step:hover::before{transform:scaleX(1)}
.como-num{
  font-family:var(--ff-serif);
  font-size:4rem;font-weight:300;
  color:rgba(242,237,228,0.05);
  line-height:1;letter-spacing:-.05em;
  position:absolute;top:1rem;right:1.25rem;
}
.como-step-icon{
  width:2.5rem;height:2.5rem;
  background:var(--gold-faint);border:1px solid var(--border-gold);
  border-radius:2px;display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;margin-bottom:1.25rem;
}
.como-step h3{
  font-family:var(--ff-serif);
  font-size:1.3rem;color:var(--cream);font-weight:600;
  line-height:1.2;margin-bottom:.75rem;
}
.como-step p{
  font-size:.88rem;font-weight:300;
  color:rgba(245,244,240,0.62);line-height:1.65;
}

/* ══════════════════════════════════════
   CTA FINAL
══════════════════════════════════════ */
.cta-final{
  padding:8rem 3rem;
  background:var(--ink);
  border-top:1px solid var(--border);
  text-align:center;
  position:relative;overflow:hidden;
}
.cta-final::before{
  content:'';position:absolute;
  top:50%;left:50%;transform:translate(-50%,-50%);
  width:600px;height:400px;
  background:radial-gradient(ellipse,rgba(184,150,90,0.06) 0%,transparent 70%);
  pointer-events:none;
}
.cta-inner{max-width:600px;margin:0 auto;position:relative;z-index:2}
.cta-h2{
  font-family:var(--ff-serif);
  font-size:clamp(2.5rem,4vw,4rem);
  font-weight:300;line-height:1.05;
  letter-spacing:-.03em;color:var(--cream);
  margin-bottom:1rem;
}
.cta-h2 em{font-style:italic;color:var(--gold)}
.cta-lead{
  font-size:1rem;font-weight:300;
  color:rgba(245,244,240,0.65);line-height:1.7;
  margin-bottom:2.5rem;
}
.cta-actions{display:flex;flex-direction:column;gap:.75rem;margin-bottom:1.5rem}
.btn-lead{
  display:flex;align-items:center;justify-content:space-between;
  gap:1rem;padding:1rem 1.75rem;
  background:var(--gold);color:var(--ink);
  border-radius:2px;text-decoration:none;
  transition:background .2s,transform .15s,box-shadow .2s;
  box-shadow:0 4px 24px rgba(184,150,90,0.2);
}
.btn-lead:hover{background:var(--gold-light);transform:translateY(-2px);box-shadow:0 8px 32px rgba(184,150,90,0.3)}
.btn-lead-text{display:flex;flex-direction:column;gap:.1rem}
.btn-lead-main{font-weight:700;font-size:.95rem;letter-spacing:.01em}
.btn-lead-sub{font-size:.75rem;font-weight:400;opacity:.7;letter-spacing:.04em}
.btn-lead-arrow{font-size:1.2rem;flex-shrink:0;transition:transform .2s var(--ease)}
.btn-lead:hover .btn-lead-arrow{transform:translateX(4px)}
.btn-sec{
  color:rgba(245,244,240,0.82);
  padding:.85rem 2rem;border:1px solid rgba(242,237,228,0.12);
  border-radius:2px;font-size:.93rem;font-weight:500;
  text-decoration:none;display:flex;align-items:center;justify-content:center;gap:.75rem;
  transition:border-color .2s,color .2s;
}
.btn-sec:hover{border-color:var(--border-gold);color:var(--cream)}
.btn-sec-icon{color:var(--gold)}
.cta-guarantee{
  display:flex;align-items:center;justify-content:center;gap:.5rem;
  font-size:.78rem;color:rgba(245,244,240,0.38);
  letter-spacing:.06em;text-transform:uppercase;
}

/* ══════════════════════════════════════
   FOOTER
══════════════════════════════════════ */
footer{
  background:var(--ink-2);
  border-top:1px solid var(--border);
  padding:4rem 3rem 2rem;
}
.footer-grid{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;
  padding-bottom:3rem;
  border-bottom:1px solid var(--border);
}
.footer-logo{
  text-decoration:none;
  font-family:var(--ff-serif);font-size:1.5rem;
  color:var(--cream);letter-spacing:-.03em;
  display:block;margin-bottom:1rem;
}
.footer-logo span{color:var(--gold)}
.footer-tagline{
  font-size:.82rem;font-weight:300;
  color:rgba(245,244,240,0.42);line-height:1.6;
  margin-bottom:1rem;
}
.footer-matricula-text{
  font-size:.72rem;letter-spacing:.05em;
  color:rgba(245,244,240,0.28);line-height:1.7;
}
.footer-col h5{
  font-size:.72rem;font-weight:700;letter-spacing:.2em;
  text-transform:uppercase;color:var(--gold);
  margin-bottom:1rem;
}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.footer-col ul a{
  font-size:.86rem;color:rgba(245,244,240,0.52);
  text-decoration:none;transition:color .2s;
}
.footer-col ul a:hover{color:var(--cream)}
.footer-bottom{
  max-width:1200px;margin:0 auto;
  display:flex;justify-content:space-between;align-items:center;
  padding-top:1.5rem;
  font-size:.78rem;color:rgba(245,244,240,0.28);
}
.footer-legal{display:flex;gap:1.5rem}
.footer-legal a{color:rgba(245,244,240,0.28);text-decoration:none;transition:color .2s}
.footer-legal a:hover{color:rgba(245,244,240,0.6)}

/* WhatsApp flotante */
.wa-float{
  position:fixed;bottom:2rem;right:2rem;z-index:500;
  width:3.5rem;height:3.5rem;border-radius:50%;
  background:#25D366;
  display:flex;align-items:center;justify-content:center;
