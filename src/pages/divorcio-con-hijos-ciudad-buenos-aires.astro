<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#14151f;--ink-2:#1c1e2b;
  --gold:#b8965a;--gold-light:#d4b07a;--gold-faint:rgba(184,150,90,0.08);
  --gold-border:rgba(184,150,90,0.25);
  --cream:#f5f4f0;--border:rgba(245,244,240,0.13);
  --ff-serif:'Cormorant Garamond',Georgia,serif;
  --ff-sans:'Outfit',system-ui,sans-serif;
  --ease:cubic-bezier(.16,1,.3,1);
}
html{scroll-behavior:smooth;background:var(--ink);font-size:16px}
body{font-family:var(--ff-sans);background:var(--ink);color:var(--cream);-webkit-font-smoothing:antialiased;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;z-index:1;pointer-events:none;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");opacity:0.4}
a{color:inherit;text-decoration:none}

/* TOPBAR */
.topbar{background:var(--gold);color:var(--ink);text-align:center;padding:.55rem 1.5rem;font-size:.8rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;position:relative;z-index:200}
.topbar span{opacity:.7;margin:0 .6rem}

/* NAV */
nav{position:sticky;top:0;z-index:150;display:flex;align-items:center;justify-content:space-between;padding:1.1rem 3rem;background:rgba(20,21,31,0.94);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);transition:padding .3s var(--ease)}
.nav-logo{text-decoration:none;display:flex;align-items:baseline;gap:.5rem}
.logo-d{font-family:var(--ff-serif);font-size:1.9rem;font-weight:300;color:var(--cream);letter-spacing:-.03em;line-height:1}
.logo-ar{font-family:var(--ff-serif);font-size:1.9rem;font-weight:600;color:var(--gold);letter-spacing:-.03em;line-height:1}
.nav-links{display:flex;gap:2.5rem;list-style:none}
.nav-links a{color:rgba(245,244,240,0.72);text-decoration:none;font-size:.9rem;font-weight:500;letter-spacing:.04em;transition:color .2s;text-transform:uppercase}
.nav-links a:hover{color:var(--cream)}
.nav-right{display:flex;align-items:center;gap:1rem}
.nav-tel{color:rgba(245,244,240,0.62);font-size:.86rem;text-decoration:none;font-weight:400;transition:color .2s}
.nav-tel:hover{color:var(--gold)}
.nav-cta{background:var(--gold);color:var(--ink);padding:.6rem 1.5rem;border-radius:2px;font-weight:700;font-size:.86rem;text-decoration:none;letter-spacing:.06em;text-transform:uppercase;transition:background .2s,transform .15s}
.nav-cta:hover{background:var(--gold-light);transform:translateY(-1px)}

/* HAMBURGER — oculto en desktop */
.nav-burger{display:none;flex-direction:column;justify-content:center;gap:5px;width:2.4rem;height:2.4rem;background:transparent;border:1px solid var(--border);border-radius:2px;cursor:pointer;padding:0;flex-shrink:0}
.nav-burger span{display:block;width:1.2rem;height:2px;background:var(--cream);margin:0 auto;transition:transform .25s var(--ease),opacity .25s var(--ease)}
.nav-burger[aria-expanded="true"] span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-burger[aria-expanded="true"] span:nth-child(2){opacity:0}
.nav-burger[aria-expanded="true"] span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* MOBILE PANEL */
.nav-mobile-panel{position:fixed;top:0;right:0;height:100vh;width:min(82vw,360px);background:var(--ink-2);border-left:1px solid var(--border);z-index:250;padding:5.5rem 2rem 2rem;display:flex;flex-direction:column;justify-content:space-between;transform:translateX(100%);transition:transform .35s var(--ease);overflow-y:auto}
.nav-mobile-panel.open{transform:translateX(0)}
.nav-mobile-links{list-style:none;display:flex;flex-direction:column;gap:1.5rem}
.nav-mobile-links a{color:rgba(245,244,240,0.82);text-decoration:none;font-size:1.05rem;font-weight:500;letter-spacing:.02em;font-family:var(--ff-serif);transition:color .2s}
.nav-mobile-links a:hover{color:var(--gold)}
.nav-mobile-actions{display:flex;flex-direction:column;gap:.75rem;padding-top:2rem;border-top:1px solid var(--border)}
.nav-mobile-tel{color:rgba(245,244,240,0.62);text-decoration:none;font-size:.9rem;text-align:center;padding:.7rem;border:1px solid var(--border);border-radius:2px}
.nav-mobile-cta{background:var(--gold);color:var(--ink);text-decoration:none;font-weight:700;font-size:.9rem;text-align:center;padding:.85rem;border-radius:2px;letter-spacing:.02em}
.nav-mobile-overlay{position:fixed;inset:0;background:rgba(10,11,17,0.6);z-index:240;opacity:0;pointer-events:none;transition:opacity .3s var(--ease)}
.nav-mobile-overlay.open{opacity:1;pointer-events:auto}

/* BREADCRUMB */
.breadcrumb{padding:.75rem 3rem;background:var(--ink-2);border-bottom:1px solid var(--border);position:relative;z-index:2}
.breadcrumb-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:rgba(245,244,240,0.42)}
.breadcrumb a{color:rgba(245,244,240,0.42);text-decoration:none;transition:color .2s}
.breadcrumb a:hover{color:var(--gold)}
.breadcrumb-sep{opacity:.35}
.breadcrumb-current{color:rgba(245,244,240,0.68)}

/* SCROLL REVEAL */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.reveal.visible{opacity:1;transform:none}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}

/* HERO */
.hero-respuesta{padding:6rem 3rem 5rem;background:var(--ink);position:relative;overflow:hidden;border-bottom:1px solid var(--border);min-height:480px;display:flex;align-items:center}
.hero-img-wrap{position:absolute;inset:0;z-index:0;pointer-events:none}
.hero-img-wrap img{width:100%;height:100%;object-fit:cover;object-position:62% 45%;filter:brightness(.80) contrast(1.05) saturate(.82)}
.hero-img-overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(20,21,31,0.97) 0%,rgba(20,21,31,0.92) 45%,rgba(20,21,31,0.55) 65%,rgba(20,21,31,0.15) 85%,rgba(20,21,31,0.05) 100%)}
.hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 380px;gap:5rem;align-items:center;position:relative;z-index:2}
.hero-kicker{font-size:.72rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;gap:.6rem;margin-bottom:1.5rem;animation:fadeUp .8s var(--ease) both}
.hero-kicker::before{content:'';width:2rem;height:1px;background:var(--gold)}
.hero-h1{font-family:var(--ff-serif);font-size:clamp(2.6rem,4.5vw,4.5rem);font-weight:300;line-height:1.0;letter-spacing:-.03em;color:var(--cream);margin-bottom:1.5rem;animation:fadeUp .8s .1s var(--ease) both}
.hero-h1 em{font-style:italic;color:var(--gold)}
.hero-answer{font-size:1.1rem;font-weight:300;color:rgba(245,244,240,0.82);line-height:1.75;margin-bottom:2rem;animation:fadeUp .8s .2s var(--ease) both;max-width:560px}
.hero-answer strong{color:var(--cream);font-weight:600}
.hero-update{display:inline-flex;align-items:center;gap:.5rem;font-size:.75rem;color:rgba(245,244,240,0.42);letter-spacing:.1em;text-transform:uppercase;animation:fadeUp .8s .3s var(--ease) both}
.hero-update::before{content:'';width:.5rem;height:.5rem;border-radius:50%;background:var(--gold);opacity:.6}

/* TARJETA HERO */
.hero-card{background:rgba(14,16,24,0.9);border:1px solid var(--gold-border);border-radius:4px;padding:2.5rem 2rem;backdrop-filter:blur(16px);animation:fadeIn 1s .4s var(--ease) both;position:relative;z-index:2}
.hero-card-tag{font-size:.65rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.5rem;display:flex;align-items:center;gap:.5rem}
.hero-card-tag::before{content:'';width:1.5rem;height:1px;background:var(--gold)}
.card-row{display:flex;justify-content:space-between;align-items:flex-start;padding:1rem 0;border-bottom:1px solid var(--border)}
.card-row:last-of-type{border-bottom:none;padding-bottom:0}
.card-label{font-family:var(--ff-serif);font-size:1rem;color:var(--cream);line-height:1.3}
.card-label small{display:block;font-size:.72rem;color:rgba(245,244,240,0.45);font-family:var(--ff-sans);margin-top:.2rem;letter-spacing:.04em}
.card-val{text-align:right}
.card-val-main{font-family:var(--ff-serif);font-size:1.4rem;color:var(--gold);line-height:1}
.card-val-sub{font-size:.68rem;color:rgba(245,244,240,0.45);letter-spacing:.06em;text-transform:uppercase;margin-top:.15rem}
.card-disclaimer{font-size:.72rem;color:rgba(245,244,240,0.35);margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border);line-height:1.5}
.card-cta{display:block;text-align:center;margin-top:1.25rem;padding:.85rem 1.5rem;background:var(--gold);color:var(--ink);font-weight:700;font-size:.85rem;letter-spacing:.06em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background .2s,transform .15s;box-shadow:0 4px 20px rgba(184,150,90,0.18)}
