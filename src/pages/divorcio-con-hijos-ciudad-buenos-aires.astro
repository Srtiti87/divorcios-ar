const title = "Divorcio con Hijos en Buenos Aires: Cómo Funciona en 2026 | Divorcios.ar";
const description = "El divorcio con hijos en CABA requiere un Plan de Parentalidad. No es más difícil ni más lento. Guía completa: cuidado personal, cuota alimentaria y régimen de comunicación.";
---
