      <div style="width:.5rem;height:.5rem;border-radius:50%;background:var(--gold)"></div>
    </div>
    <p style="font-size:.72rem;line-height:1.6;color:rgba(245,244,240,0.72);font-weight:300;margin-bottom:1.25rem">
      En <strong style="color:var(--cream);font-weight:600">divorcios.ar</strong> usamos cookies de análisis para mejorar su experiencia. Puede revisar nuestra
      <a href="/privacidad" style="color:var(--gold);text-decoration:underline">Política de Privacidad</a>.
    </p>
    <div style="display:flex;gap:.5rem">
      <button id="accept-cookies" style="flex:1;background:var(--gold);color:var(--ink);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:.75rem;border-radius:2px;border:none;cursor:pointer">Aceptar</button>
      <button id="reject-cookies" style="flex:1;background:transparent;color:rgba(245,244,240,0.6);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:.75rem;border-radius:2px;border:1px solid var(--border);cursor:pointer">Rechazar</button>
    </div>
  </div>
</div>
<script>
(function(){
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('accept-cookies');
  const rejectBtn = document.getElementById('reject-cookies');
  if (!banner || !acceptBtn || !rejectBtn) return;
  const consent = localStorage.getItem('cookie-consent-v2');
  function show() { banner.style.transform = 'translateY(0)'; banner.style.opacity = '1'; banner.style.pointerEvents = 'auto'; }
  function hide() { banner.style.transform = 'translateY(5rem)'; banner.style.opacity = '0'; banner.style.pointerEvents = 'none'; }
  if (consent === 'accepted') {
    window.dispatchEvent(new CustomEvent('cookies-accepted'));
  } else if (consent !== 'rejected') {
    setTimeout(show, 1500);
  }
  acceptBtn.addEventListener('click', () => {
    localStorage.setItem('cookie-consent-v2', 'accepted');
    hide();
    window.dispatchEvent(new CustomEvent('cookies-accepted'));
  });
  rejectBtn.addEventListener('click', () => {
    localStorage.setItem('cookie-consent-v2', 'rejected');
    hide();
  });
})();
</script>

<script>
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
  });
}, { threshold: 0.10 });
reveals.forEach(r => observer.observe(r));
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.style.padding = window.scrollY > 60 ? '.75rem 3rem' : '1.1rem 3rem';
}, { passive: true });

// Menú hamburguesa mobile
const burger = document.getElementById('nav-burger');
const mobilePanel = document.getElementById('nav-mobile-panel');
const mobileOverlay = document.getElementById('nav-mobile-overlay');

function closeMobileMenu() {
  burger.setAttribute('aria-expanded', 'false');
  mobilePanel.classList.remove('open');
  mobileOverlay.classList.remove('open');
  mobilePanel.setAttribute('aria-hidden', 'true');
  mobilePanel.querySelectorAll('a, button').forEach(el => el.setAttribute('tabindex', '-1'));
  document.body.style.overflow = '';
}
function openMobileMenu() {
  burger.setAttribute('aria-expanded', 'true');
  mobilePanel.classList.add('open');
  mobileOverlay.classList.add('open');
  mobilePanel.setAttribute('aria-hidden', 'false');
  mobilePanel.querySelectorAll('a, button').forEach(el => el.removeAttribute('tabindex'));
  document.body.style.overflow = 'hidden';
}
if (burger) {
  burger.addEventListener('click', () => {
    const isOpen = burger.getAttribute('aria-expanded') === 'true';
    isOpen ? closeMobileMenu() : openMobileMenu();
  });
  mobileOverlay.addEventListener('click', closeMobileMenu);
  mobilePanel.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMobileMenu);
  });
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobileMenu();
  });
}
</script>
