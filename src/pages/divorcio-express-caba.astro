// divorcios.ar — divorcio-express-caba.astro
// Página AEO: respuesta directa a "¿qué es el divorcio express?"
// Intención: definición y características legales del divorcio incausado en CABA
const title = "Divorcio Express en CABA: Qué Es y Cómo Funciona 2026 | Divorcios.ar";
const description = "El divorcio express es el divorcio incausado: sin causa, sin plazo mínimo de matrimonio, por mutuo acuerdo. Tarda entre 15 y 60 días en CABA. Qué es y cómo iniciarlo en 2026.";
---
<!DOCTYPE html>
<html lang="es">
<head>
