      <button id="reject-cookies" style="flex:1;background:transparent;color:rgba(245,244,240,0.6);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:.75rem;border-radius:2px;border:1px solid var(--border);cursor:pointer">Rechazar</button>
