---
// src/pages/blog.astro
import '../styles/global.css';
import LayoutPost from '../layouts/LayoutPost.astro'; 

const postFiles = import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.values(postFiles).map((post: any) => ({ url: post.url, frontmatter: post.frontmatter }));
const sortedPosts = posts.sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<LayoutPost 
  title="Blog Jurídico | Especialistas en Derecho de Familia"
  description="Artículos de actualidad sobre divorcio express y derecho de familia en Argentina."
>
    <div class="max-w-6xl mx-auto pt-32 pb-20 px-6">
        <header class="mb-16">
            <p class="text-indigo-400 font-black uppercase tracking-[0.4em] text-[10px] mb-4">Recursos y Actualidad</p>
            <h1 class="text-5xl md:text-7xl font-black text-white tracking-tighter uppercase leading-none">Blog <span class="text-indigo-400">Legal</span></h1>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {sortedPosts.map((post) => (
                <a href={post.url} class="group bg-white/5 border border-white/10 rounded-[2.5rem] p-8 hover:bg-white/10 hover:border-indigo-500 transition-all duration-500">
                    <div class="flex items-center justify-between mb-8">
                        <span class="bg-indigo-500/20 text-indigo-300 text-[10px] font-black px-3 py-1 rounded-full uppercase">{post.frontmatter.category}</span>
                        <span class="text-indigo-100/30 text-[10px] font-bold uppercase">{post.frontmatter.date}</span>
                    </div>
                    <h2 class="text-2xl font-black text-white mb-4 group-hover:text-indigo-400 tracking-tight uppercase">{post.frontmatter.title}</h2>
                    <p class="text-indigo-100/60 text-sm leading-relaxed mb-8">{post.frontmatter.description}</p>
                    <div class="flex items-center gap-2 text-white font-black text-[10px] uppercase pt-6 border-t border-white/5">Leer Guía <span class="text-indigo-400 group-hover:translate-x-2 transition-transform">→</span></div>
                </a>
            ))}
        </div>
    </div>
</LayoutPost>